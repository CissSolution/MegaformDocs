@*
    CalendarFromSQL — month-grid calendar that places SQL rows on the
    day cells they fall on.

    Default widgetProps:
      {
        "template": "CalendarFromSQL",
        "useSql": true,
        "connectionKey": "DashboardDatabase",
        "masterQuery": "SELECT RoundId, RoundLabel, RoundDate FROM GG_Rounds ORDER BY RoundDate",
        "parameters": {
          "dateColumn":  "RoundDate",
          "titleColumn": "RoundLabel",
          "monthAnchor": ""
        }
      }
*@
@using MegaForm.Razor
@inherits MfRazorWidgetBase
@attribute [RazorTemplate("CalendarFromSQL", Category = "Calendar", Icon = "fa-calendar-days", WhenToUse = "Show events / bookings / schedules placed on a month grid by a date column.", Description = "Month-grid calendar rendered from SQL rows with a date column.", SupportsSql = true, EmitsValue = false)]
@using System.Linq
@using System.Globalization
@using MegaForm.Core.Interfaces

@code {
    [Parameter, RazorParam(Label = "Date column", Group = "Data mapping", Widget = "sql-column", Required = true, Order = 10, Placeholder = "RoundDate", Hint = "SQL column carrying the date; rows are placed on that day.")]
    public string DateColumn  { get; set; } = "Date";

    [Parameter, RazorParam(Label = "Title column", Group = "Data mapping", Widget = "sql-column", Required = true, Order = 20, Placeholder = "RoundLabel", Hint = "Text shown on the day cell.")]
    public string TitleColumn { get; set; } = "Title";

    [Parameter, RazorParam(Label = "Month anchor (yyyy-MM)", Group = "Display", Widget = "text", Order = 30, Placeholder = "2026-06", Hint = "Empty = use the first row's month.")]
    public string MonthAnchor { get; set; } = "";  // yyyy-MM, empty → first row's month

    private DateTime _anchor;
    private List<(DateTime day, string title)> _events = new();

    protected override void OnParametersSet()
    {
        var rows = SqlRows?.Cast<object>().ToList() ?? new List<object>();
        _events.Clear();
        foreach (var r in rows)
        {
            var raw = Get(r, DateColumn);
            if (raw == null) continue;
            if (!DateTime.TryParse(raw.ToString(), CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var d)) continue;
            _events.Add((d.Date, Convert.ToString(Get(r, TitleColumn)) ?? ""));
        }

        if (!string.IsNullOrWhiteSpace(MonthAnchor) &&
            DateTime.TryParseExact(MonthAnchor.Trim(), "yyyy-MM", CultureInfo.InvariantCulture, DateTimeStyles.None, out var a))
        {
            _anchor = new DateTime(a.Year, a.Month, 1);
        }
        else if (_events.Count > 0)
        {
            var first = _events.Min(e => e.day);
            _anchor = new DateTime(first.Year, first.Month, 1);
        }
        else
        {
            // Without runtime randomness, fall back to a stable anchor
            // (form submissions hitting render shouldn't see "today" shift).
            _anchor = new DateTime(2026, 1, 1);
        }
    }

    private static object Get(object row, string key)
    {
        if (row is IDictionary<string, object> d)
            return d.TryGetValue(key, out var v) ? v : null;
        return row?.GetType().GetProperty(key)?.GetValue(row);
    }
}

<div class="mf-razor-cal">
    <div class="mf-razor-cal-head">
        <strong>@_anchor.ToString("MMMM yyyy", CultureInfo.InvariantCulture)</strong>
        <span class="mf-razor-cal-count">@_events.Count event(s)</span>
    </div>
    @{
        var firstDow = (int)_anchor.DayOfWeek; // Sun=0 … Sat=6
        var daysInMonth = DateTime.DaysInMonth(_anchor.Year, _anchor.Month);
        var totalCells = (int)Math.Ceiling((firstDow + daysInMonth) / 7.0) * 7;
    }
    <table class="mf-razor-cal-table">
        <thead>
            <tr>
                <th>Sun</th><th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < totalCells; i += 7)
            {
                <tr>
                    @for (var dow = 0; dow < 7; dow++)
                    {
                        var dayIdx = i + dow - firstDow + 1;
                        if (dayIdx < 1 || dayIdx > daysInMonth)
                        {
                            <td class="mf-razor-cal-cell mf-razor-cal-blank"></td>
                        }
                        else
                        {
                            var dayDate = new DateTime(_anchor.Year, _anchor.Month, dayIdx);
                            var dayEvents = _events.Where(e => e.day == dayDate).ToList();
                            <td class="mf-razor-cal-cell @(dayEvents.Count > 0 ? "has-events" : "")">
                                <div class="mf-razor-cal-day">@dayIdx</div>
                                @foreach (var e in dayEvents)
                                {
                                    <div class="mf-razor-cal-event" title="@e.title">@e.title</div>
                                }
                            </td>
                        }
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .mf-razor-cal { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; font-size:13px }
    .mf-razor-cal-head { display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;color:#0f172a }
    .mf-razor-cal-count { font-size:11px;color:#7c3aed;background:#ede9fe;padding:2px 8px;border-radius:99px;font-weight:600 }
    .mf-razor-cal-table { width:100%;border-collapse:collapse;background:#fff;table-layout:fixed }
    .mf-razor-cal-table th { background:#f1f5f9;color:#475569;font-weight:600;padding:6px;text-align:center;border:1px solid #e2e8f0;font-size:11px }
    .mf-razor-cal-cell { border:1px solid #e2e8f0;height:64px;vertical-align:top;padding:4px;font-size:11px }
    .mf-razor-cal-blank { background:#f8fafc }
    .mf-razor-cal-cell.has-events { background:#faf5ff }
    .mf-razor-cal-day { font-weight:700;color:#0f172a;margin-bottom:3px }
    .mf-razor-cal-event { background:#7c3aed;color:#fff;border-radius:4px;padding:2px 5px;font-size:10px;margin-bottom:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap }
</style>
