@{
    Layout = null;
    ViewData["Title"] = "MegaForm Setup";
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>MegaForm — Installation Wizard</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --ink:#0d0f12;
  --ink2:#3a3f4a;
  --ink3:#6b717f;
  --border:#e2e5ea;
  --bg:#f7f8fa;
  --surface:#ffffff;
  --accent:#1a56db;
  --accent-h:#1446c0;
  --accent-bg:#eff4ff;
  --green:#0e9f6e;
  --green-bg:#f0fdf4;
  --red:#e02424;
  --red-bg:#fef2f2;
  --yellow:#d97706;
  --yellow-bg:#fffbeb;
  --radius:10px;
  --shadow:0 1px 3px rgba(0,0,0,.06),0 4px 16px rgba(0,0,0,.06);
  --shadow-lg:0 8px 32px rgba(0,0,0,.10);
}

body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--ink);min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding:40px 16px 80px}

/* Layout */
.wizard{width:100%;max-width:720px}
.wizard-brand{display:flex;align-items:center;gap:10px;margin-bottom:32px;justify-content:center}
.wizard-brand svg{width:36px;height:36px}
.wizard-brand-name{font-family:'DM Serif Display',serif;font-size:1.5rem;color:var(--ink)}
.wizard-brand-tag{font-size:.75rem;color:var(--ink3);background:var(--border);padding:2px 8px;border-radius:20px;margin-left:4px}

/* Progress */
.progress-bar{display:flex;align-items:center;margin-bottom:32px;position:relative}
.progress-bar::before{content:'';position:absolute;top:16px;left:16px;right:16px;height:2px;background:var(--border);z-index:0}
.progress-fill{position:absolute;top:16px;left:16px;height:2px;background:var(--accent);z-index:1;transition:width .4s ease}
.step-dot{flex:1;display:flex;flex-direction:column;align-items:center;gap:8px;position:relative;z-index:2;cursor:default}
.step-dot-circle{width:32px;height:32px;border-radius:50%;border:2px solid var(--border);background:var(--surface);display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:600;color:var(--ink3);transition:all .3s}
.step-dot.active .step-dot-circle{border-color:var(--accent);background:var(--accent);color:#fff}
.step-dot.done .step-dot-circle{border-color:var(--green);background:var(--green);color:#fff}
.step-dot-label{font-size:.7rem;color:var(--ink3);font-weight:500;letter-spacing:.02em;text-transform:uppercase;white-space:nowrap}
.step-dot.active .step-dot-label{color:var(--accent)}
.step-dot.done .step-dot-label{color:var(--green)}

/* Card */
.card{background:var(--surface);border-radius:16px;box-shadow:var(--shadow-lg);border:1px solid var(--border);overflow:hidden}
.card-header{padding:28px 32px 0;border-bottom:none}
.step-pane{display:none;padding:32px}
.step-pane.active{display:block}
.step-title{font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--ink);margin-bottom:6px}
.step-subtitle{color:var(--ink3);font-size:.875rem;margin-bottom:24px;line-height:1.5}

/* Form elements */
.field{margin-bottom:18px}
.field label{display:block;font-size:.8rem;font-weight:600;color:var(--ink2);margin-bottom:6px;letter-spacing:.02em}
.field label .req{color:var(--red)}
.field input,.field select,.field textarea{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:var(--radius);font-family:inherit;font-size:.875rem;color:var(--ink);background:var(--surface);transition:border-color .2s,box-shadow .2s;outline:none}
.field input:focus,.field select:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-bg)}
.field .hint{font-size:.75rem;color:var(--ink3);margin-top:5px}
.field .hint a{color:var(--accent);text-decoration:none}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.field-row.three{grid-template-columns:2fr 1fr 1fr}

/* DB provider cards */
.provider-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}
.provider-card{border:2px solid var(--border);border-radius:var(--radius);padding:14px;cursor:pointer;transition:all .2s;text-align:center;background:var(--surface)}
.provider-card:hover{border-color:var(--accent);background:var(--accent-bg)}
.provider-card.selected{border-color:var(--accent);background:var(--accent-bg)}
.provider-card svg{width:32px;height:32px;margin:0 auto 8px;display:block}
.provider-card .pname{font-weight:600;font-size:.85rem;color:var(--ink)}
.provider-card .pdesc{font-size:.72rem;color:var(--ink3);margin-top:2px}
.provider-card .pbadge{font-size:.65rem;background:var(--green-bg);color:var(--green);border-radius:4px;padding:1px 6px;margin-top:4px;display:inline-block;font-weight:600}

/* DB form sections */
.db-section{display:none}
.db-section.visible{display:block}
.db-panel{border:1px solid var(--border);border-radius:14px;background:#fcfcfd;padding:18px}
.mode-switch{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.mode-chip{border:1.5px solid var(--border);background:var(--surface);color:var(--ink2);padding:9px 14px;border-radius:999px;font-size:.8rem;font-weight:600;cursor:pointer;transition:all .2s}
.mode-chip.active{border-color:var(--accent);background:var(--accent-bg);color:var(--accent)}
.mode-chip small{display:block;font-size:.68rem;font-weight:500;color:var(--ink3)}
.conn-pane{display:none}
.conn-pane.visible{display:block}
.section-title{font-size:.8rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--ink3);margin:0 0 14px}
.auth-choice{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
.auth-card{border:1.5px solid var(--border);border-radius:12px;background:var(--surface);padding:14px 16px;display:flex;align-items:flex-start;gap:10px;cursor:pointer;transition:all .2s}
.auth-card:hover{border-color:var(--accent)}
.auth-card.active{border-color:var(--accent);background:var(--accent-bg)}
.auth-card input{margin-top:2px}
.auth-card strong{display:block;font-size:.85rem;color:var(--ink)}
.auth-card span{display:block;font-size:.74rem;color:var(--ink3);margin-top:2px;line-height:1.4}
.advanced-box{margin-top:10px;border:1px solid var(--border);border-radius:12px;background:var(--surface)}
.advanced-toggle{width:100%;border:none;background:transparent;padding:14px 16px;display:flex;align-items:center;justify-content:space-between;font:inherit;font-weight:700;font-size:.82rem;color:var(--ink2);cursor:pointer}
.advanced-toggle svg{transition:transform .2s ease}
.advanced-box.open .advanced-toggle svg{transform:rotate(180deg)}
.advanced-content{display:none;padding:0 16px 16px}
.advanced-box.open .advanced-content{display:block}
.check-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
.check-item{border:1px solid var(--border);border-radius:12px;padding:12px 14px;background:#fbfcfe;display:flex;align-items:flex-start;gap:10px}
.check-item input{margin-top:2px;flex-shrink:0}
.check-item strong{display:block;font-size:.82rem;color:var(--ink)}
.check-item span{display:block;font-size:.73rem;line-height:1.45;color:var(--ink3);margin-top:2px}
.inline-note{font-size:.74rem;color:var(--ink3);margin-top:10px;line-height:1.5}
.field-row.tight{gap:12px}
.field.hidden{display:none}
.full-conn-wrap{display:grid;gap:12px}
.full-conn-note{font-size:.74rem;color:var(--ink3);line-height:1.5;background:#f8fafc;border:1px solid var(--border);padding:12px 14px;border-radius:12px}

/* Test connection */
.conn-test-row{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.btn-test{padding:9px 18px;border:1.5px solid var(--border);border-radius:var(--radius);background:var(--surface);font-family:inherit;font-size:.8rem;font-weight:600;cursor:pointer;color:var(--ink2);display:flex;align-items:center;gap:6px;transition:all .2s;white-space:nowrap}
.btn-test:hover{border-color:var(--accent);color:var(--accent)}
.conn-status{font-size:.8rem;padding:7px 12px;border-radius:7px;display:none;align-items:center;gap:6px}
.conn-status.ok{display:flex;background:var(--green-bg);color:var(--green)}
.conn-status.err{display:flex;background:var(--red-bg);color:var(--red)}

/* Password strength */
.pw-strength{height:3px;border-radius:2px;margin-top:6px;transition:all .3s;background:var(--border)}
.pw-strength[data-level="1"]{background:var(--red);width:25%}
.pw-strength[data-level="2"]{background:var(--yellow);width:50%}
.pw-strength[data-level="3"]{background:var(--yellow);width:75%}
.pw-strength[data-level="4"]{background:var(--green);width:100%}
.pw-strength-label{font-size:.7rem;color:var(--ink3);margin-top:4px}

/* Alert */
.alert{padding:10px 14px;border-radius:var(--radius);font-size:.82rem;margin-bottom:16px;display:none}
.alert.error{display:flex;background:var(--red-bg);color:var(--red);border:1px solid #fca5a5;gap:8px;align-items:flex-start}
.alert.info{display:flex;background:var(--accent-bg);color:var(--accent);border:1px solid #bfdbfe;gap:8px}

/* Footer */
.card-footer{padding:20px 32px;border-top:1px solid var(--border);background:#fafbfc;display:flex;align-items:center;justify-content:space-between}
.btn{padding:10px 24px;border-radius:var(--radius);font-family:inherit;font-size:.875rem;font-weight:600;cursor:pointer;border:none;transition:all .2s;display:inline-flex;align-items:center;gap:8px}
.btn-primary{background:var(--accent);color:#fff}
.btn-primary:hover{background:var(--accent-h);transform:translateY(-1px);box-shadow:0 4px 12px rgba(26,86,219,.3)}
.btn-primary:disabled{opacity:.5;cursor:not-allowed;transform:none;box-shadow:none}
.btn-ghost{background:transparent;color:var(--ink3);border:1.5px solid var(--border)}
.btn-ghost:hover{border-color:var(--ink3);color:var(--ink)}

/* Loading spinner */
.spinner{width:16px;height:16px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite;display:none}
.spinner.visible{display:block}
@@keyframes spin{to{transform:rotate(360deg)}}

/* Success */
.success-pane{text-align:center;padding:48px 32px}
.success-icon{width:72px;height:72px;border-radius:50%;background:var(--green-bg);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;animation:pop .4s cubic-bezier(.34,1.56,.64,1)}
@@keyframes pop{from{transform:scale(0)}to{transform:scale(1)}}
.success-title{font-family:'DM Serif Display',serif;font-size:2rem;color:var(--ink);margin-bottom:8px}
.success-sub{color:var(--ink3);font-size:.9rem;margin-bottom:32px;line-height:1.6}
.success-details{background:var(--bg);border-radius:var(--radius);padding:16px;text-align:left;margin-bottom:28px;font-size:.82rem;color:var(--ink2);line-height:1.8}
.success-details strong{color:var(--ink)}

/* Responsive */
@@media(max-width:540px){
  .field-row,.field-row.three,.auth-choice,.check-grid{grid-template-columns:1fr}
  .provider-grid{grid-template-columns:1fr}
  .card-footer{flex-direction:column;gap:12px}
  .progress-bar{overflow:hidden}
  .db-panel{padding:14px}
}
</style>
</head>
<body>

<div class="wizard">

  <!-- Brand -->
  <div class="wizard-brand">
    <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="36" height="36" rx="8" fill="#1a56db"/>
      <path d="M10 12h16M10 18h10M10 24h13" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/>
      <circle cx="26" cy="24" r="4" fill="#fff" opacity=".9"/>
      <path d="M24.5 24l1 1 2-2" stroke="#1a56db" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span class="wizard-brand-name">MegaForm</span>
    <span class="wizard-brand-tag">Installation Wizard</span>
  </div>

  <!-- Progress -->
  <div class="progress-bar" id="progressBar">
    <div class="progress-fill" id="progressFill" style="width:0%"></div>
    <div class="step-dot active" data-step="1">
      <div class="step-dot-circle">1</div>
      <div class="step-dot-label">Database</div>
    </div>
    <div class="step-dot" data-step="2">
      <div class="step-dot-circle">2</div>
      <div class="step-dot-label">Site Info</div>
    </div>
    <div class="step-dot" data-step="3">
      <div class="step-dot-circle">3</div>
      <div class="step-dot-label">Admin</div>
    </div>
    <div class="step-dot" data-step="4">
      <div class="step-dot-circle">4</div>
      <div class="step-dot-label">Email</div>
    </div>
  </div>

  <!-- Card -->
  <div class="card">

    <!-- STEP 1: DATABASE -->
    <div class="step-pane active" id="pane-1">
      <div class="step-title">Database Setup</div>
      <div class="step-subtitle">Choose your database engine. SQLite is perfect for getting started quickly — no server needed. Use SQL Server, PostgreSQL, or MySQL/MariaDB for production.</div>

      <div class="provider-grid">
        <div class="provider-card selected" data-provider="Sqlite" onclick="selectProvider(this,'Sqlite')">
          <svg viewBox="0 0 32 32"><path d="M16 2C8.27 2 2 8.27 2 16s6.27 14 14 14 14-6.27 14-14S23.73 2 16 2z" fill="#0F80CC"/><path d="M20.5 8.5c-.8-.4-1.7-.5-2.5-.5-3.9 0-7 3.1-7 7 0 2.5 1.3 4.7 3.3 6l.2.1c-.1-.4-.1-.8-.1-1.2 0-2.8 2.2-5 5-5 .5 0 1 .1 1.4.2.5-1 .7-2.1.7-3.1 0-1.3-.4-2.5-1-3.5z" fill="#003B57"/><path d="M21.4 16.1c-2.2 0-4 1.8-4 4s1.8 4 4 4 4-1.8 4-4-1.8-4-4-4z" fill="#fff"/></svg>
          <div class="pname">SQLite</div>
          <div class="pdesc">File-based, zero config</div>
          <div class="pbadge">Recommended</div>
        </div>
        <div class="provider-card" data-provider="SqlServer" onclick="selectProvider(this,'SqlServer')">
          <svg viewBox="0 0 32 32"><rect width="32" height="32" rx="4" fill="#CC2927"/><path d="M8 10h16v12H8z" fill="#fff" opacity=".15"/><text x="16" y="20" text-anchor="middle" fill="#fff" font-size="9" font-weight="700" font-family="sans-serif">SQL</text></svg>
          <div class="pname">SQL Server</div>
          <div class="pdesc">Microsoft MSSQL</div>
        </div>
        <div class="provider-card" data-provider="PostgreSQL" onclick="selectProvider(this,'PostgreSQL')">
          <svg viewBox="0 0 32 32"><circle cx="16" cy="16" r="14" fill="#336791"/><path d="M16 8c-4.4 0-8 3.6-8 8s3.6 8 8 8 8-3.6 8-8-3.6-8-8-8zm0 14c-3.3 0-6-2.7-6-6s2.7-6 6-6 6 2.7 6 6-2.7 6-6 6z" fill="#fff"/></svg>
          <div class="pname">PostgreSQL</div>
          <div class="pdesc">Open-source enterprise</div>
        </div>
        <div class="provider-card" data-provider="MySQL" onclick="selectProvider(this,'MySQL')">
          <svg viewBox="0 0 32 32"><rect width="32" height="32" rx="16" fill="#00758F"/><path d="M10 21c2.2-5.6 7.3-9.4 12-9.2-1.1 1-1.9 2.2-2.4 3.5 1.7.4 3.1 1.5 4.2 3.3-2.2-.7-4.1-.8-5.7-.4-.6 1.2-1 2.6-1.2 4.1H10z" fill="#F29111"/><circle cx="12" cy="11" r="2" fill="#fff"/></svg>
          <div class="pname">MySQL</div>
          <div class="pdesc">MySQL / MariaDB</div>
        </div>
      </div>

      <!-- SQLite options -->
      <div class="db-section visible" id="db-sqlite">
        <div class="field">
          <label>Database File Path <span class="req">*</span></label>
          <input type="text" id="sqlite-file" placeholder="App_Data/MegaForm/megaform.db" value="App_Data/MegaForm/megaform.db"/>
          <div class="hint">Leave as default to store MegaForm in <strong>App_Data/MegaForm/megaform.db</strong>, or specify an absolute path. Missing folders will be created automatically.</div>
        </div>
      </div>

      <!-- SQL Server options -->
      <div class="db-section" id="db-sqlserver">
        <div class="db-panel">
          <div class="mode-switch" role="tablist" aria-label="SQL Server setup mode">
            <button type="button" class="mode-chip active" id="ss-mode-basic-btn" onclick="setSqlServerMode('basic')">
              Basic setup
              <small>Host, auth, and database</small>
            </button>
            <button type="button" class="mode-chip" id="ss-mode-conn-btn" onclick="setSqlServerMode('conn')">
              Full connection string
              <small>Paste an existing string</small>
            </button>
          </div>

          <div class="conn-pane visible" id="ss-pane-basic">
            <div class="section-title">Connection details</div>
            <div class="field-row three tight">
              <div class="field">
                <label>Server Host <span class="req">*</span></label>
                <input type="text" id="ss-host" placeholder="localhost or .\SQLEXPRESS"/>
              </div>
              <div class="field">
                <label>Port</label>
                <input type="text" id="ss-port" placeholder="1433"/>
              </div>
              <div class="field">
                <label>Database Name <span class="req">*</span></label>
                <input type="text" id="ss-db" placeholder="MegaForm" value="MegaForm"/>
              </div>
            </div>

            <div class="section-title" style="margin-top:6px">Authentication</div>
            <div class="auth-choice">
              <label class="auth-card active" id="ss-auth-sql-card">
                <input type="radio" name="ss-auth-mode" value="sql" checked onchange="setSqlServerAuthMode('sql')" />
                <div>
                  <strong>SQL Login</strong>
                  <span>Use SQL Server username and password.</span>
                </div>
              </label>
              <label class="auth-card" id="ss-auth-windows-card">
                <input type="radio" name="ss-auth-mode" value="windows" onchange="setSqlServerAuthMode('windows')" />
                <div>
                  <strong>Windows / Integrated</strong>
                  <span>Use the current Windows account on this machine/server.</span>
                </div>
              </label>
            </div>

            <div class="field-row" id="ss-sql-login-row">
              <div class="field">
                <label>Username</label>
                <input type="text" id="ss-user" placeholder="sa"/>
              </div>
              <div class="field">
                <label>Password</label>
                <input type="password" id="ss-pass" placeholder=""/>
              </div>
            </div>

            <div class="advanced-box" id="ss-advanced-box">
              <button type="button" class="advanced-toggle" onclick="toggleSqlServerAdvanced()">
                <span>Advanced connection options</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="advanced-content">
                <div class="check-grid">
                  <label class="check-item">
                    <input type="checkbox" id="ss-encrypt" checked />
                    <div>
                      <strong>Encrypt connection</strong>
                      <span>Recommended for all environments.</span>
                    </div>
                  </label>
                  <label class="check-item">
                    <input type="checkbox" id="ss-trustcert" checked />
                    <div>
                      <strong>Trust server certificate</strong>
                      <span>Recommended for local/dev or self-signed SQL Server certificates.</span>
                    </div>
                  </label>
                </div>
                <div class="inline-note">For local SQL Server or self-signed certificates, keep <strong>Trust server certificate</strong> enabled to avoid the SSL trust error during setup.</div>
              </div>
            </div>
          </div>

          <div class="conn-pane" id="ss-pane-conn">
            <div class="full-conn-wrap">
              <div class="field" style="margin-bottom:0">
                <label>Full Connection String</label>
                <input type="text" id="ss-connstr" placeholder="Server=.;Database=MegaForm;Trusted_Connection=true;Encrypt=True;TrustServerCertificate=True;"/>
              </div>
              <div class="full-conn-note">Paste an existing SQL Server connection string here. If <strong>Encrypt</strong> or <strong>TrustServerCertificate</strong> is missing, MegaForm will add safe defaults during setup.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- PostgreSQL options -->
      <div class="db-section" id="db-postgresql">
        <div class="field-row three">
          <div class="field">
            <label>Host <span class="req">*</span></label>
            <input type="text" id="pg-host" placeholder="localhost"/>
          </div>
          <div class="field">
            <label>Port</label>
            <input type="text" id="pg-port" placeholder="5432" value="5432"/>
          </div>
          <div class="field">
            <label>Database <span class="req">*</span></label>
            <input type="text" id="pg-db" placeholder="megaform" value="megaform"/>
          </div>
        </div>
        <div class="field-row">
          <div class="field">
            <label>Username <span class="req">*</span></label>
            <input type="text" id="pg-user" placeholder="postgres"/>
          </div>
          <div class="field">
            <label>Password</label>
            <input type="password" id="pg-pass" placeholder=""/>
          </div>
        </div>
      </div>

      <!-- MySQL options -->
      <div class="db-section" id="db-mysql">
        <div class="field-row three">
          <div class="field">
            <label>Host <span class="req">*</span></label>
            <input type="text" id="my-host" placeholder="localhost"/>
          </div>
          <div class="field">
            <label>Port</label>
            <input type="text" id="my-port" placeholder="3306" value="3306"/>
          </div>
          <div class="field">
            <label>Database <span class="req">*</span></label>
            <input type="text" id="my-db" placeholder="megaform" value="megaform"/>
          </div>
        </div>
        <div class="field-row">
          <div class="field">
            <label>Username <span class="req">*</span></label>
            <input type="text" id="my-user" placeholder="root" value="root"/>
          </div>
          <div class="field">
            <label>Password</label>
            <input type="password" id="my-pass" placeholder=""/>
          </div>
        </div>
        <div class="field">
          <div class="hint">Supports MySQL 8+ and MariaDB through the main EF Core provider. Use a dedicated database/schema for MegaForm.</div>
        </div>
      </div>

      <!-- Test connection -->
      <div class="conn-test-row">
        <button class="btn-test" onclick="testConnection()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          Test Connection
        </button>
        <div class="conn-status ok" id="conn-ok">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
          <span id="conn-ok-msg">Connected successfully!</span>
        </div>
        <div class="conn-status err" id="conn-err">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          <span id="conn-err-msg">Connection failed</span>
        </div>
      </div>
    </div>

    <!-- STEP 2: SITE INFO -->
    <div class="step-pane" id="pane-2">
      <div class="step-title">Site Information</div>
      <div class="step-subtitle">Basic details about your MegaForm installation.</div>
      <div class="field">
        <label>Site Name <span class="req">*</span></label>
        <input type="text" id="site-name" placeholder="My Company Forms" value="MegaForm"/>
      </div>
      <div class="field">
        <label>Base URL <span class="req">*</span></label>
        <input type="text" id="site-url" placeholder="https://forms.example.com"/>
        <div class="hint">Used for email links and file uploads. Include https:// without trailing slash.</div>
      </div>
    </div>

    <!-- STEP 3: ADMIN ACCOUNT -->
    <div class="step-pane" id="pane-3">
      <div class="step-title">Create Admin Account</div>
      <div class="step-subtitle">This will be the primary administrator account for MegaForm.</div>
      <div class="field-row">
        <div class="field">
          <label>Username <span class="req">*</span></label>
          <input type="text" id="admin-user" placeholder="admin" value="admin" autocomplete="new-password"/>
        </div>
        <div class="field">
          <label>Email Address <span class="req">*</span></label>
          <input type="email" id="admin-email" placeholder="admin@example.com"/>
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Password <span class="req">*</span></label>
          <input type="password" id="admin-pass" placeholder="Min. 8 characters" oninput="checkPw(this.value)"/>
          <div class="pw-strength" id="pw-strength"></div>
          <div class="pw-strength-label" id="pw-label"></div>
        </div>
        <div class="field">
          <label>Confirm Password <span class="req">*</span></label>
          <input type="password" id="admin-pass2" placeholder="Re-enter password"/>
        </div>
      </div>
    </div>

    <!-- STEP 4: EMAIL (optional) -->
    <div class="step-pane" id="pane-4">
      <div class="step-title">Email Configuration</div>
      <div class="step-subtitle">Optional — configure SMTP to send form notifications and draft resume links. You can skip this and configure later in Settings.</div>
      <div class="alert info" id="email-info" style="display:flex">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:1px"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        <span>Skipping is fine — email can be configured at any time in the admin panel.</span>
      </div>
      <div class="field-row">
        <div class="field">
          <label>SMTP Host</label>
          <input type="text" id="email-host" placeholder="mail.yourdomain.com"/>
        </div>
        <div class="field">
          <label>Port</label>
          <input type="text" id="email-port" placeholder="465"/>
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>From Address</label>
          <input type="email" id="email-from" placeholder="support@example.com"/>
        </div>
        <div class="field">
          <label>Reply-To</label>
          <input type="email" id="email-replyto" placeholder="support@example.com"/>
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>SMTP Username</label>
          <input type="text" id="email-user" placeholder="support@example.com"/>
        </div>
        <div class="field">
          <label>Password / App Password</label>
          <input type="password" id="email-pass" placeholder="SMTP password" autocomplete="new-password"/>
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label>Timeout (ms)</label>
          <input type="text" id="email-timeout" placeholder="20000"/>
        </div>
        <div class="field" style="display:flex;align-items:flex-end">
          <label style="display:flex;align-items:center;gap:8px;margin:0 0 6px 0">
            <input type="checkbox" id="email-ssl" checked />
            <span>Enable SSL/TLS</span>
          </label>
        </div>
      </div>

      <div id="error-alert" class="alert error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:1px"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
        <span id="error-msg"></span>
      </div>
    </div>

    <!-- SUCCESS -->
    <div class="step-pane" id="pane-success">
      <div class="success-pane">
        <div class="success-icon">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#0e9f6e" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
        </div>
        <div class="success-title">MegaForm is ready!</div>
        <div class="success-sub">Your installation is complete. The database has been created and your admin account is ready to use.</div>
        <div class="success-details" id="success-details"></div>
        <button class="btn btn-primary" onclick="goToApp()" style="margin:0 auto;display:flex">
          Go to Dashboard
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>

    <!-- Footer -->
    <div class="card-footer" id="card-footer">
      <button class="btn btn-ghost" id="btn-back" onclick="goBack()" style="visibility:hidden">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back
      </button>
      <div style="display:flex;align-items:center;gap:8px">
        <button class="btn btn-ghost" id="btn-skip" onclick="skipStep()" style="display:none">Skip for now</button>
        <button class="btn btn-primary" id="btn-next" onclick="nextStep()">
          <span id="btn-next-label">Continue</span>
          <div class="spinner" id="btn-spinner"></div>
          <svg id="btn-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </div>

  <p style="text-align:center;margin-top:20px;font-size:.75rem;color:var(--ink3)">
    MegaForm v1.7 · <a href="#" style="color:var(--accent);text-decoration:none">Documentation</a>
  </p>
</div>

<script>
let currentStep = 1;
const totalSteps = 4;
let selectedProvider = 'Sqlite';
let connTested = false;

// Init — auto-detect base URL
document.getElementById('site-url').value = window.location.origin;
setSqlServerMode('basic');
setSqlServerAuthMode('sql');

// Hiện thông báo nếu bị redirect do DB lỗi
const reason = new URLSearchParams(window.location.search).get('reason');
if (reason === 'db_error') {
    const banner = document.createElement('div');
    banner.style.cssText = 'background:#fef2f2;border:1px solid #fca5a5;color:#b91c1c;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:.85rem;display:flex;gap:8px;align-items:flex-start';
    banner.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:1px"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg><span><strong>Previous database configuration failed.</strong> The setup has been reset. Please reconfigure your database connection below.</span>';
    document.querySelector('.wizard').insertBefore(banner, document.querySelector('.progress-bar'));
}

function selectProvider(el, provider) {
  document.querySelectorAll('.provider-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  selectedProvider = provider;
  document.querySelectorAll('.db-section').forEach(s => s.classList.remove('visible'));
  document.getElementById('db-' + provider.toLowerCase()).classList.add('visible');
  document.getElementById('conn-ok').style.display = 'none';
  document.getElementById('conn-err').style.display = 'none';
  connTested = false;
  if (provider === 'SqlServer') setSqlServerMode('basic');
setSqlServerAuthMode('sql');
}

function setSqlServerMode(mode) {
  const basicBtn = document.getElementById('ss-mode-basic-btn');
  const connBtn = document.getElementById('ss-mode-conn-btn');
  const basicPane = document.getElementById('ss-pane-basic');
  const connPane = document.getElementById('ss-pane-conn');
  if (!basicBtn || !connBtn || !basicPane || !connPane) return;
  const isBasic = mode !== 'conn';
  basicBtn.classList.toggle('active', isBasic);
  connBtn.classList.toggle('active', !isBasic);
  basicPane.classList.toggle('visible', isBasic);
  connPane.classList.toggle('visible', !isBasic);
}

function toggleSqlServerAdvanced() {
  const box = document.getElementById('ss-advanced-box');
  if (box) box.classList.toggle('open');
}

function setSqlServerAuthMode(mode) {
  const sqlCard = document.getElementById('ss-auth-sql-card');
  const windowsCard = document.getElementById('ss-auth-windows-card');
  const loginRow = document.getElementById('ss-sql-login-row');
  const user = document.getElementById('ss-user');
  const pass = document.getElementById('ss-pass');
  const integrated = mode === 'windows';
  if (sqlCard) sqlCard.classList.toggle('active', !integrated);
  if (windowsCard) windowsCard.classList.toggle('active', integrated);
  if (loginRow) loginRow.style.display = integrated ? 'none' : 'grid';
  if (user) {
    user.disabled = integrated;
    user.placeholder = integrated ? 'Not required' : 'sa';
  }
  if (pass) {
    pass.disabled = integrated;
    pass.placeholder = integrated ? 'Not required' : '';
  }
}

function toggleSqlServerAuth() {
  const integratedInput = document.querySelector('input[name="ss-auth-mode"][value="windows"]');
  setSqlServerAuthMode(integratedInput && integratedInput.checked ? 'windows' : 'sql');
}

async function testConnection() {
  const btn = document.querySelector('.btn-test');
  btn.disabled = true; btn.textContent = 'Testing...';
  document.getElementById('conn-ok').style.display = 'none';
  document.getElementById('conn-err').style.display = 'none';

  const payload = buildDbPayload();
  try {
    const res = await fetch('/setup/test-connection', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) {
      document.getElementById('conn-ok').style.display = 'flex';
      document.getElementById('conn-ok-msg').textContent = data.message;
      connTested = true;
    } else {
      document.getElementById('conn-err').style.display = 'flex';
      document.getElementById('conn-err-msg').textContent = data.message;
      connTested = false;
    }
  } catch(e) {
    document.getElementById('conn-err').style.display = 'flex';
    document.getElementById('conn-err-msg').textContent = 'Request failed: ' + e.message;
    connTested = false;
  }
  btn.disabled = false; btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg> Test Connection';
}

function buildDbPayload() {
  const p = selectedProvider;
  if (p === 'Sqlite') return { provider: p, sqliteFile: document.getElementById('sqlite-file').value };
  if (p === 'SqlServer') return {
    provider: p,
    host: document.getElementById('ss-host').value,
    port: document.getElementById('ss-port').value,
    database: document.getElementById('ss-db').value,
    username: document.getElementById('ss-user').value,
    password: document.getElementById('ss-pass').value,
    connectionString: document.getElementById('ss-connstr').value,
    encrypt: !!document.getElementById('ss-encrypt').checked,
    trustServerCertificate: !!document.getElementById('ss-trustcert').checked,
    integratedSecurity: (document.querySelector('input[name="ss-auth-mode"]:checked')?.value === 'windows'),
  };
  if (p === 'PostgreSQL') return {
    provider: p,
    host: document.getElementById('pg-host').value,
    port: document.getElementById('pg-port').value,
    database: document.getElementById('pg-db').value,
    username: document.getElementById('pg-user').value,
    password: document.getElementById('pg-pass').value,
  };
  if (p === 'MySQL') return {
    provider: p,
    host: document.getElementById('my-host').value,
    port: document.getElementById('my-port').value,
    database: document.getElementById('my-db').value,
    username: document.getElementById('my-user').value,
    password: document.getElementById('my-pass').value,
  };
}

function checkPw(pw) {
  let score = 0;
  if (pw.length >= 8) score++;
  if (/[A-Z]/.test(pw)) score++;
  if (/[0-9]/.test(pw)) score++;
  if (/[^A-Za-z0-9]/.test(pw)) score++;
  const el = document.getElementById('pw-strength');
  const lbl = document.getElementById('pw-label');
  el.setAttribute('data-level', score);
  el.style.width = ['0%','25%','50%','75%','100%'][score];
  const colors = ['','#e02424','#d97706','#d97706','#0e9f6e'];
  el.style.background = colors[score] || '#e2e5ea';
  const labels = ['','Weak','Fair','Good','Strong'];
  lbl.textContent = pw.length > 0 ? labels[score] : '';
}

function validate() {
  if (currentStep === 1) {
    if (selectedProvider === 'SqlServer') {
      const host = document.getElementById('ss-host').value;
      const connstr = document.getElementById('ss-connstr').value;
      if (!host && !connstr) { showError('Please enter a server host or connection string.'); return false; }
    }
    if (selectedProvider === 'PostgreSQL') {
      if (!document.getElementById('pg-host').value) { showError('Please enter the PostgreSQL host.'); return false; }
      if (!document.getElementById('pg-user').value) { showError('Please enter the username.'); return false; }
    }
    if (selectedProvider === 'MySQL') {
      if (!document.getElementById('my-host').value) { showError('Please enter the MySQL host.'); return false; }
      if (!document.getElementById('my-user').value) { showError('Please enter the username.'); return false; }
    }
    return true;
  }
  if (currentStep === 2) {
    if (!document.getElementById('site-name').value) { showError('Site name is required.'); return false; }
    const url = document.getElementById('site-url').value;
    if (!url || !url.startsWith('http')) { showError('Please enter a valid base URL starting with http:// or https://'); return false; }
    return true;
  }
  if (currentStep === 3) {
    if (!document.getElementById('admin-user').value) { showError('Username is required.'); return false; }
    if (!document.getElementById('admin-email').value.includes('\x40')) { showError('Please enter a valid email address.'); return false; }
    const pw = document.getElementById('admin-pass').value;
    if (pw.length < 8) { showError('Password must be at least 8 characters.'); return false; }
    if (pw !== document.getElementById('admin-pass2').value) { showError('Passwords do not match.'); return false; }
    return true;
  }
  return true;
}

function showError(msg) {
  const el = document.getElementById('error-alert');
  document.getElementById('error-msg').textContent = msg;
  el.style.display = 'flex';
  // Show error in current pane context
  const pane = document.getElementById('pane-' + currentStep);
  if (pane && !pane.contains(el)) {
    // Move to bottom of active pane temporarily
    el.style.marginTop = '8px';
  }
  setTimeout(() => el.style.display = 'none', 5000);
}

function updateProgress() {
  const dots = document.querySelectorAll('.step-dot');
  dots.forEach((d, i) => {
    const s = i + 1;
    d.classList.remove('active','done');
    if (s < currentStep) d.classList.add('done');
    if (s === currentStep) d.classList.add('active');
    const circle = d.querySelector('.step-dot-circle');
    if (s < currentStep) circle.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6L9 17l-5-5"/></svg>';
    else circle.textContent = s;
  });
  const pct = Math.min(((currentStep - 1) / (totalSteps - 1)) * 100, 100);
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('btn-back').style.visibility = currentStep > 1 ? 'visible' : 'hidden';
  document.getElementById('btn-skip').style.display = currentStep === 4 ? 'inline-flex' : 'none';
  document.getElementById('btn-next-label').textContent = currentStep === totalSteps ? 'Install MegaForm' : 'Continue';
}

function showPane(n) {
  document.querySelectorAll('.step-pane').forEach(p => p.classList.remove('active'));
  document.getElementById('pane-' + n).classList.add('active');
}

async function nextStep() {
  document.getElementById('error-alert').style.display = 'none';
  if (!validate()) return;

  if (currentStep === totalSteps) {
    await submitSetup(); return;
  }

  currentStep++;
  showPane(currentStep);
  updateProgress();
  window.scrollTo({top:0, behavior:'smooth'});
}

function goBack() {
  if (currentStep <= 1) return;
  currentStep--;
  showPane(currentStep);
  updateProgress();
}

function skipStep() {
  if (currentStep === 4) { submitSetup(); }
}

async function submitSetup() {
  const btn = document.getElementById('btn-next');
  const spinner = document.getElementById('btn-spinner');
  const arrow = document.getElementById('btn-arrow');
  btn.disabled = true;
  spinner.classList.add('visible');
  arrow.style.display = 'none';
  document.getElementById('btn-next-label').textContent = 'Installing...';

  const payload = {
    database: buildDbPayload(),
    site: {
      siteName: document.getElementById('site-name').value,
      baseUrl:  document.getElementById('site-url').value,
    },
    admin: {
      username: document.getElementById('admin-user').value,
      email:    document.getElementById('admin-email').value,
      password: document.getElementById('admin-pass').value,
    },
    email: {
      host: document.getElementById('email-host').value || null,
      port: document.getElementById('email-port').value || null,
      from: document.getElementById('email-from').value || null,
      username: document.getElementById('email-user').value || null,
      password: document.getElementById('email-pass').value || null,
      enableSsl: document.getElementById('email-ssl').checked,
      replyTo: document.getElementById('email-replyto').value || null,
      timeoutMs: document.getElementById('email-timeout').value || null,
    },
  };

  try {
    const res = await fetch('/setup/complete', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) {
      showSuccess(payload, data.restartPending);
    } else {
      showError(data.error || 'Installation failed.');
      btn.disabled = false;
      spinner.classList.remove('visible');
      arrow.style.display = '';
      document.getElementById('btn-next-label').textContent = 'Install MegaForm';
    }
  } catch(e) {
    showError('Network error: ' + e.message);
    btn.disabled = false;
    spinner.classList.remove('visible');
    arrow.style.display = '';
    document.getElementById('btn-next-label').textContent = 'Install MegaForm';
  }
}

function showSuccess(payload, restartPending) {
  document.querySelectorAll('.step-pane').forEach(p => p.classList.remove('active'));
  document.getElementById('pane-success').classList.add('active');
  document.getElementById('card-footer').style.display = 'none';
  document.getElementById('progressBar').style.display = 'none';

  const db = payload.database;
  const dbSummary = db.provider === 'Sqlite' ? `SQLite · ${db.sqliteFile || 'megaform.db'}` : `${db.provider} · ${db.host || ''}/${db.database || ''}`;
  document.getElementById('success-details').innerHTML = `
    <strong>Site:</strong> ${payload.site.siteName}<br/>
    <strong>URL:</strong> ${payload.site.baseUrl}<br/>
    <strong>Database:</strong> ${dbSummary}<br/>
    <strong>Admin:</strong> ${payload.admin.email}
  `;

  if (restartPending) {
    const sub = document.querySelector('.success-sub');
    sub.innerHTML = 'Installation complete! The application is restarting to apply your database configuration&hellip;';
    const btn = document.querySelector('.success-pane .btn-primary');
    btn.disabled = true;
    btn.innerHTML = '<svg class="spinner visible" style="border-color:rgba(255,255,255,.3);border-top-color:#fff;width:16px;height:16px" viewBox="0 0 16 16"></svg> Restarting&hellip;';

    let attempts = 0;
    const maxAttempts = 120;
    const poll = setInterval(async () => {
      attempts++;
      try {
        const r = await fetch('/setup/runtime-status', { cache: 'no-store' });
        const data = await r.json().catch(() => null);
        if (r.ok && data && data.ready) {
          clearInterval(poll);
          btn.disabled = false;
          sub.innerHTML = data.message || 'Application restarted successfully. Click below to go to your dashboard.';
          btn.innerHTML = 'Go to Dashboard <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';
          return;
        }

        if (data && data.message) {
          sub.textContent = data.message;
        }
      } catch(e) {
        sub.innerHTML = 'Installation complete! Waiting for the application to restart and reconnect to your configured database&hellip;';
      }

      if (attempts >= maxAttempts) {
        clearInterval(poll);
        sub.innerHTML = 'The application is still restarting or reconnecting to the configured database. Keep this page open and refresh when the site is back online.';
      }
    }, 1000);
  }
}

function goToApp() { window.location.href = '/'; }

updateProgress();
</script>
</body>
</html>
