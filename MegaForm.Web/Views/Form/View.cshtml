@model MegaForm.Web.Controllers.FormViewModel
@using Newtonsoft.Json.Linq
@{
    Layout = null; // standalone page — no shared layout
    var apiBase = "/api/MegaForm/";
    var isEmbed = Model.EmbedMode;
    var isPreview = Model.PreviewMode;
    var socialDescription = string.IsNullOrWhiteSpace(Model.Description) ? "Fill out this form" : Model.Description;
    var hasCustomHtml = false;
    try
    {
        var schemaObj = string.IsNullOrWhiteSpace(Model.SchemaJson) ? null : JObject.Parse(Model.SchemaJson);
        var schemaSettings = schemaObj?["settings"] as JObject;
        var schemaCustomHtml = schemaSettings?["customHtml"] ?? schemaSettings?["CustomHtml"];
        if (!string.IsNullOrWhiteSpace(schemaCustomHtml?.ToString()))
        {
            hasCustomHtml = true;
        }
        else
        {
            var settingsObj = string.IsNullOrWhiteSpace(Model.SettingsJson) ? null : JObject.Parse(Model.SettingsJson);
            var customHtmlToken = settingsObj?["customHtml"] ?? settingsObj?["CustomHtml"];
            hasCustomHtml = !string.IsNullOrWhiteSpace(customHtmlToken?.ToString());
        }
    }
    catch
    {
        hasCustomHtml = false;
    }
}
<!DOCTYPE html>
<html lang="@Model.Locale" data-mf-locale="@Model.Locale">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <meta name="robots" content="@(isEmbed || isPreview ? "noindex" : "index,follow")"/>
  <title>@Model.Title</title>
  <meta name="description" content="@socialDescription"/>

  @if (isEmbed || isPreview)
  {
    <!-- No external referencing for embed / preview -->
  }
  else
  {
    <link rel="canonical" href="@Model.CanonicalUrl"/>
    <meta property="og:title" content="@Model.Title"/>
    <meta property="og:description" content="@socialDescription"/>
    <meta property="og:type" content="website"/>
    <meta property="og:url" content="@Model.CanonicalUrl"/>
    <meta property="og:image" content="@Model.SocialImageUrl"/>
    <meta property="og:image:width" content="@Model.SocialImageWidth"/>
    <meta property="og:image:height" content="@Model.SocialImageHeight"/>
    <meta property="og:image:alt" content="@Model.Title"/>
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="@Model.Title"/>
    <meta name="twitter:description" content="@socialDescription"/>
    <meta name="twitter:image" content="@Model.SocialImageUrl"/>
    <meta name="megaform-social-share-badge" content="@Model.SocialShareBadge"/>
  }

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>

  <!-- MegaForm CSS -->
  <link rel="stylesheet" href="/megaform/css/megaform.css"/>
  <link rel="stylesheet" href="/megaform/css/megaform-widgets.css"/>
  <link rel="stylesheet" href="/megaform/css/plugins/megaform-widgets-builtin.css?v=20260404-05"/>
  <meta name="megaform-asset-selection-badge" content="@Model.AssetSelectionBadge"/>
  @foreach (var cssFile in Model.PluginStyles ?? new System.Collections.Generic.List<string>())
  {
    <link rel="stylesheet" href="/megaform/css/plugins/@cssFile?v=20260404-05"/>
  }

  @if (!string.IsNullOrWhiteSpace(Model.InitialInlineCss))
  {
    <style id="mf-inline-preset-@Model.FormId">@Html.Raw(Model.InitialInlineCss)</style>
  }

  <style>
    *, *::before, *::after { box-sizing: border-box; }

    html, body {
      margin: 0; padding: 0;
      font-family: 'DM Sans', sans-serif;
      background: @((isEmbed || hasCustomHtml) ? "transparent" : "#f1f5f9");
      min-height: 100vh;
    }

    /* ── Page wrapper (hosted only) ────────────────── */
    .mf-std-page {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: @((isEmbed || hasCustomHtml) ? "0" : "40px 16px 80px");
    }

    /* ── Content wrapper (renderer owns the visible card) ── */
    .mf-std-content {
      width: 100%;
      max-width: 960px;
    }

    /* ── Body ───────────────────────────────────────── */
    .mf-std-body {
      padding: 0;   /* renderer (mf-form-wrapper) owns its own padding */
    }

    /* ── Footer branding ────────────────────────────── */
    .mf-std-footer {
      text-align: center;
      padding: 14px 0 0;
      font-size: 11px;
      color: #94a3b8;
    }
    .mf-std-footer a {
      color: #6366f1;
      text-decoration: none;
      font-weight: 600;
    }

    .mf-custom-shell-host {
      min-height: 100vh;
      background: transparent;
    }

    /* ── Preview banner ─────────────────────────────── */
    .mfp-preview-banner {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 40px;
      background: #f97316;
      color: #fff;
      font-size: 13px;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      z-index: 9999;
      font-family: 'DM Sans', sans-serif;
    }
    .mfp-preview-banner + .mf-std-page { padding-top: 60px; }

    /* ── Error page ─────────────────────────────────── */
    .mfp-not-published {
      text-align: center;
      padding: 60px 32px;
      color: #64748b;
    }
    .mfp-not-published h2 { color: #1e293b; margin-bottom: 8px; }

    /* ── Responsive ─────────────────────────────────── */
    @@media (max-width: 640px) {
      .mf-std-header, .mf-std-body { padding-left: 20px; padding-right: 20px; }
    }
  </style>
</head>
<body data-mf-locale="@Model.Locale">

@if (isPreview)
{
  <div class="mfp-preview-banner">
    <i class="fas fa-eye"></i>
    Preview Mode — this form is not yet published
    <a href="/admin/builder?formId=@Model.FormId" style="color:#fff;text-decoration:underline;margin-left:12px;">← Back to Builder</a>
  </div>
}

@if (!hasCustomHtml)
{
<div class="mf-std-page">
  <div class="mf-std-content">
    <div class="mf-std-body">
      <!-- MegaFormRenderer mounts here and renders its own title/card -->
      <div id="mf-form-mount"></div>
    </div>
  </div>

  <div class="mf-std-footer">
    Powered by <a href="/">MegaForm</a>
  </div>
</div>
}
else
{
<div class="mf-custom-shell-host">
  <div id="mf-form-mount"></div>
</div>
}

<!-- MegaForm runtime scripts -->
<script src="/megaform/js/megaform-i18n.js?v=20260402-12"></script>
<script src="/megaform/js/megaform-widgets.js"></script>
<script src="/megaform/js/plugins/types.js"></script>
@foreach (var scriptFile in Model.PluginScripts ?? new System.Collections.Generic.List<string>())
{
  <script src="/megaform/js/plugins/@scriptFile?v=20260404-05"></script>
}
<script src="/megaform/js/megaform-rule-engine.js"></script>
<script src="/megaform/js/megaform-renderer.js?v=20260404-04"></script>

<script>
  // ── Server data injected server-side ──────────────────────────────────────
  var _MF_CONFIG = {
    formId:          @Model.FormId,
    title:           @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Title)),
    description:     @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Description)),
    schemaJson:      @Html.Raw(Model.SchemaJson),
    settingsJson:    @Html.Raw(Model.SettingsJson),
    themeJson:       @Html.Raw(string.IsNullOrWhiteSpace(Model.ThemeJson) ? "{}" : Model.ThemeJson),
    rulesJson:       @Html.Raw(Model.RulesJson),
    submitButtonText:@Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.SubmitButtonText)),
    successMessage:  @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.SuccessMessage)),
    enableCaptcha:   @Model.EnableCaptcha.ToString().ToLower(),
    requireAuth:     @Model.RequireAuth.ToString().ToLower(),
    apiBase:         '@apiBase',
    isPreview:       @isPreview.ToString().ToLower(),
    captchaConfig: {
      badgeVersion: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.CaptchaBadgeVersion ?? "")),
      reCaptchaSiteKey: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ReCaptchaSiteKey ?? "")),
      hCaptchaSiteKey: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.HCaptchaSiteKey ?? ""))
    },
    locale: @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Locale ?? "en-US"))
  };
  window.__MegaFormCaptchaConfig = _MF_CONFIG.captchaConfig || {};

  // ── Init renderer ──────────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', async function () {
    var schema;
    try {
      schema = typeof _MF_CONFIG.schemaJson === 'string'
        ? JSON.parse(_MF_CONFIG.schemaJson)
        : _MF_CONFIG.schemaJson;
    } catch (e) {
      schema = { fields: [] };
    }

    if (!schema || !schema.fields || schema.fields.length === 0) {
      document.getElementById('mf-form-mount').innerHTML =
        '<div style="padding:40px;text-align:center;color:#94a3b8;">' +
        '<i class="fas fa-inbox" style="font-size:32px;display:block;margin-bottom:12px;"></i>' +
        'This form has no fields yet.</div>';
      return;
    }

    document.documentElement.setAttribute('data-mf-locale', _MF_CONFIG.locale || 'en-US');
    document.body.setAttribute('data-mf-locale', _MF_CONFIG.locale || 'en-US');
    try {
      if (window.MegaFormI18n && typeof window.MegaFormI18n.initI18n === 'function') {
        await window.MegaFormI18n.initI18n('/api/MegaForm/i18n', _MF_CONFIG.locale || 'en-US');
      }
    } catch (_i18nErr) { }

    // Renderer handles all CSS/theme logic internally via settingsJson + themeJson.
    // No platform-specific merging needed here.
    MegaFormRenderer.init({
      formId:          _MF_CONFIG.formId,
      schema:          schema,
      settingsJson:    _MF_CONFIG.settingsJson,
      themeJson:       _MF_CONFIG.themeJson,
      container:       '#mf-form-mount',
      title:           _MF_CONFIG.title,
      description:     _MF_CONFIG.description,
      submitButtonText: _MF_CONFIG.submitButtonText,
      successMessage:  _MF_CONFIG.successMessage,
      apiBase:         _MF_CONFIG.apiBase,
      isPreview:       _MF_CONFIG.isPreview,
      rules:           _MF_CONFIG.rulesJson || [],
      locale:          _MF_CONFIG.locale || 'en-US'
    });

    // Backup rule pass for public view — renderer also binds internally.
    if (typeof MegaFormRules !== 'undefined' && Array.isArray(_MF_CONFIG.rulesJson) && _MF_CONFIG.rulesJson.length) {
      var formMount = document.getElementById('mf-form-mount');
      var formRoot = document.getElementById('mf-form-wrapper-' + _MF_CONFIG.formId) || formMount;
      var runLegacyRules = function () {
        var data = MegaFormRenderer.collectData ? MegaFormRenderer.collectData() : {};
        var effects = MegaFormRules.evaluateRules(_MF_CONFIG.rulesJson, data);
        if (MegaFormRenderer.applyRuleEffects) MegaFormRenderer.applyRuleEffects(effects, formRoot);
        else MegaFormRules.applyEffects(effects, formRoot);
      };
      formMount.addEventListener('change', runLegacyRules);
      formMount.addEventListener('input', runLegacyRules);
      setTimeout(runLegacyRules, 0);
    }
  });

  // ── postMessage for iframe auto-resize ────────────────────────────────────
  // Parent pages can resize iframe automatically:
  //   window.addEventListener('message', function(e) {
  //     if (e.data && e.data.type === 'mf:resize') iframe.style.height = e.data.height + 'px';
  //   });
  function notifyParentHeight() {
    var h = document.body.scrollHeight;
    if (window.parent && window.parent !== window) {
      window.parent.postMessage({ type: 'mf:resize', height: h, formId: _MF_CONFIG.formId }, '*');
    }
  }
  // Fire on load and on DOM mutations
  window.addEventListener('load', notifyParentHeight);
  if (typeof MutationObserver !== 'undefined') {
    new MutationObserver(notifyParentHeight)
      .observe(document.body, { childList: true, subtree: true, attributes: true });
  }
</script>

</body>
</html>
