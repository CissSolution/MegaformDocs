@{
    Layout = null;
    string apiBase = ViewBag.ApiBaseUrl ?? "/api/MegaForm/";
    string adminLocale = ViewBag.AdminLocale ?? "en-US";
    bool hasDevLock = ViewBag.HasDevLock ?? false;
    bool hasDemoLock = ViewBag.HasDemoLock ?? false;
}
<!DOCTYPE html>
<html lang="en" data-mf-locale="@adminLocale">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>MegaForm — Languages</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/megaform/css/megaform-admin-shell.css?v=20260404-10" />
<style>html,body{height:100%;margin:0;padding:0;}#mf-languages-root{min-height:100vh;}</style>
</head>
<body class="mf-body">
<div id="mf-languages-root"
     data-platform="aspcore"
     data-api-base="@apiBase"
     data-admin-locale="@adminLocale"
     data-dev-lock="@hasDevLock.ToString().ToLower()"
     data-demo-lock="@hasDemoLock.ToString().ToLower()">
  <div class="mf-admin-loading">Loading languages…</div>
</div>
<script src="/megaform/js/megaform-languages.js?v=20260402-17"></script>
<script>
(function(){
  var root = document.getElementById('mf-languages-root');
  if(!root) return;
  function fail(msg){ root.innerHTML = '<div style="padding:2rem;color:#dc2626;">'+msg+'</div>'; }
  function boot(){
    try {
      if(window.MegaForm && window.MegaForm.initLanguages){
        window.MegaForm.initLanguages(root);
      } else { setTimeout(boot, 60); }
    } catch(err){ fail('Languages error: ' + (err && err.message || err)); }
  }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot); else boot();
})();
</script>
</body>
</html>
