@using MegaForm.Web.Services
@{
    Layout = null;
    int formId = ViewBag.FormId ?? 0;
    string apiBase = ViewBag.ApiBaseUrl ?? "/api/MegaForm/";
    bool isNew = (formId == 0);
    bool hasDevLock = ViewBag.HasDevLock ?? false;
    bool hasDemoLock = ViewBag.HasDemoLock ?? false;
    // THEME-FIX: pass themeJson so builder preserves TD customizations on save
    string themeJson = ViewBag.ThemeJson ?? "{}";
    bool workflowEnabled = (ViewBag.Features as IMegaFormFeatureToggles)?.Workflow ?? false;
}
<!DOCTYPE html>
<html lang="en" data-mf-locale="en-US">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>MegaForm — @(isNew ? "New Form" : "Edit Form")</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<!-- MegaForm Builder CSS — v0 redesign -->
<link rel="stylesheet" href="/megaform/css/megaform.css?v=20260422-01" data-mf-builder-preview-css-badge="BuilderPreviewCss v20260422-01"/>
<link rel="stylesheet" href="/megaform/css/megaform-builder-shell.css?v=20260402-08">
<link rel="stylesheet" href="/megaform/css/megaform-builder.css?v=20260404-03"/>
<link rel="stylesheet" href="/megaform/css/megaform-builder-ts.css?v=20260404-03"/>
<link rel="stylesheet" href="/megaform/css/megaform-themes.css"/>
<link rel="stylesheet" href="/megaform/css/megaform-widgets.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widgets-builtin.css?v=20260404-03"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-payment.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-stripe.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-paypal.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-signature.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-rich-text.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-repeater.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-advanced-file.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-calculator.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-rating-suite.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-infinite-list.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-product-line-items.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-draw-on-image.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-phone-pro.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-pdf-form.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-video-embed.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-grid-repeater.css"/>
<link rel="stylesheet" href="/megaform/css/plugins/megaform-widget-data-repeater.css"/>
</head>
<body>
@if (!workflowEnabled)
{
  <style>
    #mf-tab-link-workflow, #mf-tab-workflow { display: none !important; }
  </style>
}

<!--
  All HTML is generated by the Vite builder bundle (dom.ts).
  data-* attributes pass server-side context to the client.
  CSS-only redesign — JS bundle unchanged.
-->
<div id="mf-builder-root"
     data-platform="aspcore"
     data-form-id="@formId"
     data-api-base="@apiBase"
     data-assets-base="/megaform/"
     data-is-new="@isNew.ToString().ToLower()"
     data-dev-lock="@hasDevLock.ToString().ToLower()"
     data-demo-lock="@hasDemoLock.ToString().ToLower()"
     data-theme-json="@Html.Raw(System.Web.HttpUtility.HtmlAttributeEncode(themeJson))"
     data-return-url="/admin">
  <div class="mf-boot"><i class="fas fa-spinner fa-spin" style="margin-right:8px"></i> Loading&#8230;</div>
</div>

<!-- SortableJS 1.15.2 -->
<script src="/megaform/js/Sortable.min.js"></script>

<!-- Widget plugins — must load BEFORE builder bundle -->
<script src="/megaform/js/megaform-widgets.js"></script>
<script src="/megaform/js/plugins/megaform-widget-signature.js"></script>
<script src="/megaform/js/plugins/megaform-widget-rich-text.js"></script>
<script src="/megaform/js/plugins/megaform-widget-repeater.js"></script>
<script src="/megaform/js/plugins/megaform-widget-advanced-file.js"></script>
<script src="/megaform/js/plugins/megaform-widget-calculator.js"></script>
<script src="/megaform/js/plugins/megaform-widget-rating-suite.js?v=20260402-13"></script>
<script src="/megaform/js/plugins/megaform-widget-appointment.js?v=20260404-03"></script>
<script src="/megaform/js/plugins/megaform-widget-geolocation.js"></script>
<script src="/megaform/js/plugins/megaform-widget-image-choice.js"></script>
<script src="/megaform/js/plugins/megaform-widget-payment-unified.js?v=20260404-03"></script>
<script src="/megaform/js/plugins/megaform-widget-stripe.js"></script>
<script src="/megaform/js/plugins/megaform-widget-paypal.js"></script>
<script src="/megaform/js/plugins/megaform-widget-infinite-list.js"></script>
<script src="/megaform/js/plugins/megaform-widget-product-line-items.js"></script>
<script src="/megaform/js/plugins/megaform-widget-draw-on-image.js"></script>
<script src="/megaform/js/plugins/megaform-widget-video-embed.js"></script>
<script src="/megaform/js/plugins/megaform-widget-grid-repeater.js?v=20260402-13"></script>
<script src="/megaform/js/plugins/megaform-widget-captcha.js?v=20260402-08"></script>
<script src="/megaform/js/plugins/megaform-widget-phone-pro.js?v=20260402-13"></script>
<script src="/megaform/js/plugins/megaform-widget-pdf-form.js?v=20260505-01"></script>
<script src="/megaform/js/plugins/megaform-widget-content-slider.js?v=20260414-03"></script>
<script src="/megaform/js/plugins/megaform-widget-qrcode.js?v=20260415-02"></script>
<script src="/megaform/js/plugins/megaform-widget-data-repeater.js?v=20260428-01"></script>

<!-- Renderer + rule engine -->
<script src="/megaform/js/megaform-renderer.js?v=20260402-17"></script>
<script src="/megaform/js/megaform-rule-engine.js"></script>

<!-- VITE BUILDER BUNDLE — UNCHANGED (CSS redesign only) -->
<script src="/megaform/js/bundles/megaform-builder.js?v=20260424-01"></script>
<script src="/megaform/js/megaform-template-gallery-search.js"></script>

@if (workflowEnabled)
{
  <!-- Workflow ReactFlow -->
  <script src="/megaform/js/builder/megaform-workflow-reactflow.js?v=20260423-01"></script>
}

</body>
</html>
