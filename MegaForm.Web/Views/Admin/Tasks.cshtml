@using System
@using System.Collections.Generic
@using MegaForm.Core.Models
@{
    var myTasks = ViewBag.MyTaskShell as List<AdminInboxTaskItem> ?? new List<AdminInboxTaskItem>();
    var roleQueue = ViewBag.RoleQueueShell as List<AdminInboxTaskItem> ?? new List<AdminInboxTaskItem>();
    string message = ViewBag.Message as string ?? string.Empty;
    string error = ViewBag.Error as string ?? string.Empty;
    string currentUrl = Context.Request.Path + Context.Request.QueryString;

    string Fmt(DateTime? value) => value.HasValue ? value.Value.ToString("yyyy-MM-dd HH:mm") : "-";
}
<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>MegaForm - Workflow Inbox</title>
    <style>
        body{font-family:Segoe UI,Arial,sans-serif;background:#f5f6f8;margin:0;color:#16181d}
        .wrap{max-width:1280px;margin:0 auto;padding:24px}
        .top{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:18px}
        .title{font-size:28px;font-weight:700}
        .links a{display:inline-block;margin-left:8px;padding:10px 14px;border-radius:10px;background:#fff;color:#111827;text-decoration:none;border:1px solid #d1d5db}
        .notice{padding:12px 14px;border-radius:12px;margin-bottom:16px}
        .notice.ok{background:#ecfdf3;border:1px solid #86efac;color:#166534}
        .notice.err{background:#fef2f2;border:1px solid #fca5a5;color:#991b1b}
        .grid{display:grid;grid-template-columns:1fr;gap:20px}
        .card{background:#fff;border:1px solid #e5e7eb;border-radius:18px;overflow:hidden;box-shadow:0 10px 30px rgba(15,23,42,.04)}
        .card h2{margin:0;padding:18px 20px;border-bottom:1px solid #eef2f7;font-size:18px}
        .empty{padding:20px;color:#6b7280}
        table{width:100%;border-collapse:collapse}
        th,td{padding:12px 14px;border-bottom:1px solid #eef2f7;vertical-align:top;text-align:left;font-size:14px}
        th{font-size:12px;letter-spacing:.04em;text-transform:uppercase;color:#6b7280;background:#fafafa}
        .meta{color:#6b7280;font-size:12px}
        .subtle{color:#374151;font-size:13px}
        .badge{display:inline-block;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:600}
        .badge.pending{background:#fff7ed;color:#9a3412}
        .badge.claimed{background:#eff6ff;color:#1d4ed8}
        .badge.completed{background:#ecfdf3;color:#166534}
        .badge.document{background:#eef2ff;color:#4338ca}
        .badge.generic{background:#f3f4f6;color:#374151}
        .forms{display:grid;gap:8px;min-width:280px}
        .forms form{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
        .forms input[type=text]{flex:1 1 180px;padding:8px 10px;border:1px solid #d1d5db;border-radius:10px}
        .forms button{padding:8px 12px;border:none;border-radius:10px;background:#111827;color:#fff;cursor:pointer}
        .forms button.alt{background:#374151}
        .forms button.warn{background:#b91c1c}
        .small{font-size:12px;color:#6b7280}
        .stack{display:grid;gap:4px}
        .task-links{display:flex;gap:8px;flex-wrap:wrap}
        .task-links a{color:#1d4ed8;text-decoration:none}
    </style>
</head>
<body>
    <div class="wrap">
        <div class="top">
            <div class="title">Workflow Inbox</div>
            <div class="links">
                <a href="/admin">Dashboard</a>
                <a href="/admin/documents">Documents</a>
                <a href="/admin/submissions">Submissions</a>
                <a href="/admin/builder">Builder</a>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="notice ok">@message</div>
        }
        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="notice err">@error</div>
        }

        <div class="grid">
            <div class="card">
                <h2>My Tasks (@myTasks.Count)</h2>
                @if (myTasks.Count == 0)
                {
                    <div class="empty">No tasks are currently assigned to you.</div>
                }
                else
                {
                    <table>
                        <thead>
                            <tr>
                                <th>Task</th>
                                <th>Record</th>
                                <th>Due</th>
                                <th>State</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var task in myTasks)
                        {
                            <tr>
                                <td>
                                    <div class="stack">
                                        <div><strong>@(string.IsNullOrWhiteSpace(task.Task.NodeLabel) ? task.Task.NodeId : task.Task.NodeLabel)</strong></div>
                                        <div class="meta">TaskId: @task.Task.TaskId</div>
                                        <div class="meta">Case: @(task.WorkflowCase != null ? task.WorkflowCase.CaseId : task.Task.CaseId)</div>
                                        <div><span class="badge @(task.Projection.Profile.EnableDocumentRegistry ? "document" : "generic")">@task.Projection.Profile.DisplayName</span></div>
                                    </div>
                                </td>
                                <td>
                                    <div class="stack">
                                        <div><strong>@task.Projection.Title</strong></div>
                                        <div class="subtle">@(task.Form != null ? task.Form.Title : ("Form #" + task.Task.FormId))</div>
                                        <div class="meta">Submission #@task.Task.SubmissionId</div>
                                        @if (!string.IsNullOrWhiteSpace(task.Projection.Owner))
                                        {
                                            <div class="meta">Owner: @task.Projection.Owner</div>
                                        }
                                        @if (task.AssignmentCount > 0 || task.OpenDirectiveCount > 0)
                                        {
                                            <div class="meta">Assignments: @task.AssignmentCount | Directives: @task.OpenDirectiveCount</div>
                                        }
                                        <div class="task-links">
                                            @if (!string.IsNullOrWhiteSpace(task.RecordUrl))
                                            {
                                                <a href="@task.RecordUrl">Open Detail</a>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(task.PublicUrl))
                                            {
                                                <a href="@task.PublicUrl" target="_blank">Public URL</a>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>@Fmt(task.Task.DueAt ?? task.Projection.DueOnUtc)</td>
                                <td><span class="badge @(task.Task.Status.ToString().ToLowerInvariant())">@task.Task.Status</span></td>
                                <td>
                                    <div class="forms">
                                        <form method="post" action="/admin/tasks/@task.Task.TaskId/claim">
                                            <input type="hidden" name="returnUrl" value="@currentUrl" />
                                            <input type="text" name="comment" placeholder="Claim comment (optional)" />
                                            <button type="submit" class="alt">Claim</button>
                                        </form>
                                        <form method="post" action="/admin/tasks/@task.Task.TaskId/approve">
                                            <input type="hidden" name="returnUrl" value="@currentUrl" />
                                            <input type="text" name="comment" placeholder="Approval note (optional)" />
                                            <button type="submit">Approve</button>
                                        </form>
                                        <form method="post" action="/admin/tasks/@task.Task.TaskId/reject">
                                            <input type="hidden" name="returnUrl" value="@currentUrl" />
                                            <input type="text" name="comment" placeholder="Reject note" />
                                            <button type="submit" class="warn">Reject</button>
                                        </form>
                                        <form method="post" action="/admin/tasks/@task.Task.TaskId/forward">
                                            <input type="hidden" name="returnUrl" value="@currentUrl" />
                                            <input type="text" name="targetUser" placeholder="Target user / email / id" />
                                            <input type="text" name="comment" placeholder="Forward note (optional)" />
                                            <button type="submit" class="alt">Forward</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>

            <div class="card">
                <h2>Role Queue (@roleQueue.Count)</h2>
                @if (roleQueue.Count == 0)
                {
                    <div class="empty">No unclaimed tasks are waiting on your role.</div>
                }
                else
                {
                    <table>
                        <thead>
                            <tr>
                                <th>Task</th>
                                <th>Record</th>
                                <th>Candidates</th>
                                <th>Due</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var task in roleQueue)
                        {
                            <tr>
                                <td>
                                    <div class="stack">
                                        <div><strong>@(string.IsNullOrWhiteSpace(task.Task.NodeLabel) ? task.Task.NodeId : task.Task.NodeLabel)</strong></div>
                                        <div class="meta">TaskId: @task.Task.TaskId</div>
                                        <div><span class="badge @(task.Projection.Profile.EnableDocumentRegistry ? "document" : "generic")">@task.Projection.Profile.DisplayName</span></div>
                                    </div>
                                </td>
                                <td>
                                    <div class="stack">
                                        <div><strong>@task.Projection.Title</strong></div>
                                        <div class="subtle">@(task.Form != null ? task.Form.Title : ("Form #" + task.Task.FormId))</div>
                                        <div class="meta">Submission #@task.Task.SubmissionId</div>
                                        @if (!string.IsNullOrWhiteSpace(task.RecordUrl))
                                        {
                                            <div><a href="@task.RecordUrl">Open Detail</a></div>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <div class="small">Roles: @string.Join(", ", task.Task.CandidateRoles ?? new List<string>())</div>
                                    <div class="small">Users: @string.Join(", ", task.Task.CandidateUsers ?? new List<string>())</div>
                                </td>
                                <td>@Fmt(task.Task.DueAt ?? task.Projection.DueOnUtc)</td>
                                <td>
                                    <form method="post" action="/admin/tasks/@task.Task.TaskId/claim" class="forms">
                                        <input type="hidden" name="returnUrl" value="@currentUrl" />
                                        <input type="text" name="comment" placeholder="Claim comment (optional)" />
                                        <button type="submit">Claim Task</button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</body>
</html>
