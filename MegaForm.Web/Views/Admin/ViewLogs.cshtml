@using System
@using System.Collections.Generic
@using MegaForm.Web.Services
@{
    Layout = null;
    var result = ViewBag.LogQuery as RuntimeLogQueryResult ?? new RuntimeLogQueryResult();
    var entries = result.Items ?? result.Entries ?? new List<RuntimeLogEntry>();
    string category = ViewBag.LogCategory ?? string.Empty;
    string logName = ViewBag.LogName ?? string.Empty;
    string search = ViewBag.LogSearch ?? string.Empty;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>MegaForm — View Logs</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style>
  :root{color-scheme:light;background:#f8fafc;color:#0f172a;font-family:Inter,system-ui,sans-serif}
  *{box-sizing:border-box} body{margin:0;background:#f8fafc;color:#0f172a}
  .vl-shell{max-width:1440px;margin:0 auto;padding:24px}
  .vl-top{display:flex;justify-content:space-between;gap:16px;align-items:flex-start;flex-wrap:wrap;margin-bottom:20px}
  .vl-title h1{margin:0;font-size:28px;line-height:1.1}.vl-title p{margin:8px 0 0;color:#64748b}
  .vl-actions{display:flex;gap:10px;flex-wrap:wrap}.vl-btn{display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border-radius:12px;border:1px solid #cbd5e1;background:#fff;color:#0f172a;text-decoration:none;font-weight:600;cursor:pointer}
  .vl-btn.primary{background:#0f172a;color:#fff;border-color:#0f172a}.vl-btn.danger{background:#fff5f5;color:#b91c1c;border-color:#fecaca}
  .vl-card{background:#fff;border:1px solid #e2e8f0;border-radius:18px;box-shadow:0 16px 40px rgba(15,23,42,.06)}
  .vl-toolbar{padding:18px;border-bottom:1px solid #e2e8f0;display:grid;grid-template-columns:1.2fr 1fr 1fr auto auto;gap:12px}
  .vl-field{display:flex;flex-direction:column;gap:6px}.vl-field label{font-size:12px;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:.04em}
  .vl-field input{height:42px;border-radius:12px;border:1px solid #cbd5e1;padding:0 12px;font:inherit}
  .vl-summary{display:flex;gap:12px;flex-wrap:wrap;padding:16px 18px;border-bottom:1px solid #e2e8f0;color:#475569}
  .vl-chip{display:inline-flex;align-items:center;gap:8px;padding:7px 10px;border-radius:999px;background:#f1f5f9;font-size:12px;font-weight:600}
  .vl-list{padding:18px;display:flex;flex-direction:column;gap:14px}
  .vl-empty{padding:42px 24px;text-align:center;color:#64748b}
  .vl-item{border:1px solid #e2e8f0;border-radius:16px;overflow:hidden;background:#fff}
  .vl-item-hd{padding:14px 16px;background:#f8fafc;border-bottom:1px solid #e2e8f0;display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap}
  .vl-item-title{font-weight:700}.vl-meta{display:flex;gap:10px;flex-wrap:wrap;color:#64748b;font-size:12px}
  .vl-pre{margin:0;padding:16px;background:#0f172a;color:#e2e8f0;overflow:auto;font:12px/1.6 ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;max-height:360px;white-space:pre-wrap;word-break:break-word}
  @@media (max-width: 980px){.vl-toolbar{grid-template-columns:1fr}.vl-actions{width:100%}}
</style>
</head>
<body>
  <div class="vl-shell">
    <div class="vl-top">
      <div class="vl-title">
        <h1>View Logs</h1>
        <p>Inspect runtime logs for email, payment, workflow, and other MegaForm services.</p>
      </div>
      <div class="vl-actions">
        <a class="vl-btn" href="/admin">Dashboard</a>
        <a class="vl-btn" href="/admin/submissions">Submissions</a>
        <a class="vl-btn primary" href="/admin/theme-designer">Theme Designer</a>
      </div>
    </div>

    <div class="vl-card">
      <form class="vl-toolbar" method="get" action="/admin/viewlogs">
        <div class="vl-field">
          <label>Category</label>
          <input type="text" name="category" value="@category" placeholder="runtime, email, payments, workflow" />
        </div>
        <div class="vl-field">
          <label>Log name</label>
          <input type="text" name="logName" value="@logName" placeholder="email-engine, workflow, stripe" />
        </div>
        <div class="vl-field">
          <label>Search</label>
          <input type="text" name="search" value="@search" placeholder="keyword, error code, order id" />
        </div>
        <div class="vl-field">
          <label>Take</label>
          <input type="number" min="1" max="200" name="take" value="@(result.Take > 0 ? result.Take : 50)" />
        </div>
        <div style="display:flex;align-items:flex-end;gap:10px;flex-wrap:wrap;">
          <button class="vl-btn primary" type="submit">Apply</button>
        </div>
      </form>

      <div class="vl-summary">
        <span class="vl-chip">Total files: @result.Total</span>
        <span class="vl-chip">Showing: @entries.Count</span>
        <span class="vl-chip">Category: @(string.IsNullOrWhiteSpace(category) ? "All" : category)</span>
        @if (!string.IsNullOrWhiteSpace(result.Message))
        {
            <span class="vl-chip">@result.Message</span>
        }
        <form method="post" action="/admin/viewlogs/clear" style="margin-left:auto;display:flex;gap:8px;flex-wrap:wrap;">
          @Html.AntiForgeryToken()
          <input type="hidden" name="category" value="@category" />
          <input type="hidden" name="logName" value="@logName" />
          <button class="vl-btn danger" type="submit" onclick="return confirm('Clear matching log files?');">Clear matching logs</button>
        </form>
      </div>

      <div class="vl-list">
        @if (entries.Count == 0)
        {
            <div class="vl-empty">No matching logs found.</div>
        }
        else
        {
            foreach (var item in entries)
            {
                <article class="vl-item">
                  <div class="vl-item-hd">
                    <div>
                      <div class="vl-item-title">@(!string.IsNullOrWhiteSpace(item.DisplayName) ? item.DisplayName : item.LogName)</div>
                      <div class="vl-meta">
                        <span>Category: @(item.Category ?? "runtime")</span>
                        <span>Modified: @(item.LastModifiedUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</span>
                        <span>Size: @item.SizeBytes bytes</span>
                        <span>Lines: @item.LineCount</span>
                      </div>
                    </div>
                    <div class="vl-meta">
                      <span>@(item.RelativePath ?? item.Path)</span>
                    </div>
                  </div>
                  <pre class="vl-pre">@((item.Preview ?? item.Content ?? string.Empty).Trim())</pre>
                </article>
            }
        }
      </div>
    </div>
  </div>
</body>
</html>
