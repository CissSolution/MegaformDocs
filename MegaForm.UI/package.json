{
  "name": "megaform-ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "MegaForm UI — TypeScript SPA for Builder, Config Panel, and Views",
  "scripts": {
    "dev": "set MF_ENTRY=config&& vite build --watch",
    "i18n:check": "node tools/i18n-check.cjs",
    "i18n:refdiff": "node tools/i18n-refdiff.cjs",
    "i18n:litlint": "node tools/i18n-litlint.cjs",
    "prebuild": "npm run i18n:check",
    "build": "npm run build:loader && npm run build:i18n && npm run build:widgets && npm run build:rule-engine && npm run build:renderer && npm run build:builder && npm run build:submissions && npm run build:views && npm run build:settings-popup && npm run build:presets && npm run build:embed && npm run build:admin-live && npm run build:dashboard && npm run build:ai-knowledge && npm run build:languages && npm run build:dnn-host && npm run build:theme-designer && npm run build:theme-inspector",
    "build:ai-knowledge": "node scripts/build-entry.cjs ai-knowledge",
    "build:loader": "node scripts/build-entry.cjs builder-loader",
    "build:config": "node scripts/build-entry.cjs config",
    "build:builder": "node scripts/build-entry.cjs builder",
    "build:rule-engine": "node scripts/build-entry.cjs rule-engine",
    "build:submissions": "node scripts/build-entry.cjs submissions",
    "build:my-inbox": "node scripts/build-entry.cjs my-inbox",
    "build:views": "node scripts/build-entry.cjs views",
    "build:settings-popup": "node scripts/build-entry.cjs settings-popup",
    "build:renderer": "node scripts/build-entry.cjs renderer",
    "build:widgets": "node scripts/build-entry.cjs widgets",
    "build:i18n": "node scripts/build-entry.cjs i18n",
    "build:embed": "node scripts/build-entry.cjs embed",
    "build:presets": "node scripts/build-entry.cjs presets",
    "build:admin-live": "node scripts/build-entry.cjs admin-live",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist ../Assets/js/bundles",
    "copy:workflow-deps": "node scripts/copy-workflow-deps.cjs",
    "build:workflow": "node scripts/copy-workflow-deps.cjs && node scripts/build-entry.cjs workflow",
    "build:dashboard": "node scripts/build-entry.cjs dashboard",
    "build:theme-designer": "node scripts/build-entry.cjs theme-designer",
    "build:theme-inspector": "node scripts/build-entry.cjs theme-inspector",
    "build:dnn-host": "node scripts/build-entry.cjs dnn-host",
    "build:languages": "node scripts/build-entry.cjs languages",
    "build:widget-pdf-form": "node scripts/build-entry.cjs widget-pdf-form"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4",
    "rimraf": "^5.0.0",
    "sortablejs": "^1.15.2",
    "typescript": "^5.4.0",
    "vite": "^5.4.21"
  }
}
