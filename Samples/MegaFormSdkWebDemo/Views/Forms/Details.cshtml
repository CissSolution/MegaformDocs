@model MegaForm.Sdk.FormDto
@{
    ViewData["Title"] = Model.Title;
}

<h1>@Model.Title</h1>
<p class="text-muted">@Model.Description</p>

<div class="mb-3">
    <span class="badge bg-secondary">@Model.Status</span>
    <span class="badge bg-info">Submissions: @Model.SubmissionCount</span>
</div>

<h3>Schema JSON</h3>
<pre class="bg-light p-3 border"><code>@Model.SchemaJson</code></pre>

<div class="mt-3">
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.FormId">Edit Form</a>
    <a class="btn btn-success" asp-controller="Render" asp-action="Form" asp-route-id="@Model.FormId">Open Public Form</a>
    <a class="btn btn-info" asp-controller="Submissions" asp-action="Index" asp-route-formId="@Model.FormId">View Submissions</a>
    <a class="btn btn-outline-secondary" asp-action="Index">Back to List</a>
</div>
