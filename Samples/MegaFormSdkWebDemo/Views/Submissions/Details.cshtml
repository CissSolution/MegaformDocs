@model MegaForm.Sdk.SubmissionDto
@{
    ViewData["Title"] = $"Submission #{Model.SubmissionId}";
    var form = ViewBag.Form as MegaForm.Sdk.FormDto;
    var files = ViewBag.Files as IReadOnlyList<MegaForm.Sdk.FileDto>;
}

<h1>Submission #@Model.SubmissionId</h1>

@if (form != null)
{
    <p class="lead">Form: <a asp-controller="Forms" asp-action="Details" asp-route-id="@form.FormId">@form.Title</a></p>
}

<dl class="row">
    <dt class="col-sm-2">Submitted</dt>
    <dd class="col-sm-10">@Model.SubmittedOnUtc</dd>
    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.Status</dd>
    <dt class="col-sm-2">Spam</dt>
    <dd class="col-sm-10">@(Model.IsSpam ? "Yes" : "No")</dd>
    <dt class="col-sm-2">User</dt>
    <dd class="col-sm-10">@(Model.UserId?.ToString() ?? "anonymous")</dd>
</dl>

<h3>Data</h3>
<pre class="bg-light p-3 border"><code>@Model.DataJson</code></pre>

<h3>Files</h3>
@if (files != null && files.Count > 0)
{
    <ul class="list-group">
        @foreach (var file in files)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                @file.FileName
                <span class="badge bg-primary rounded-pill">@file.SizeBytes bytes</span>
            </li>
        }
    </ul>
}
else
{
    <p class="text-muted">No files attached.</p>
}

<div class="mt-3">
    <a class="btn btn-outline-secondary" asp-action="Index" asp-route-formId="@Model.FormId">Back to List</a>
</div>
