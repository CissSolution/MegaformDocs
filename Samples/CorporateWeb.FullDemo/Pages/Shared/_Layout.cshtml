<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MegaForm Corporate Full Demo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" href="data:," />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    <header class="site-header">
        <div class="container header-inner">
            <a class="brand" href="/">
                <span class="brand-mark">M</span>
                <span class="brand-text">MegaForm Corporate</span>
            </a>
            <nav class="site-nav" aria-label="Main navigation">
                <a class="nav-link" href="/">Home</a>
                <a class="nav-link" href="/Contact">Contact</a>
                <a class="nav-link" href="/Register">Event</a>
                <a class="nav-link" href="/Forms">Forms</a>
                <a class="nav-link" href="/Submissions">Submissions</a>
                <a class="nav-link" href="/Submissions/Card">Card View</a>
                <a class="nav-link" href="/Dashboard">Dashboard</a>
                <a class="nav-link" href="/ApiDemo">API Demo</a>
                <a class="nav-link nav-link-admin" href="/admin" target="_blank">Admin</a>
            </nav>
        </div>
    </header>

    <main class="site-main">
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="site-footer">
        <div class="container">
            <p>&copy; @DateTime.Now.Year MegaForm Corporate Full Demo. Built with the MegaForm ASP.NET Core component.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
