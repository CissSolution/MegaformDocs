@page
@model MegaForm.Samples.CorporateWeb.FullDemo.Pages.RegisterModel
@{
    ViewData["Title"] = "Event Registration";
}

<section class="register-page py-4">
    <div class="container" style="max-width: 960px;">
        @if (Model.FormId > 0)
        {
            <megaform form-id="@Model.FormId" mode="embed" min-height="620" theme="corporate" class="megaform-host"></megaform>
        }
        else
        {
            <div class="alert alert-warning">
                <p>No published event form was found. Make sure the app has finished starting.</p>
                <a class="btn btn-secondary" href="/admin" target="_blank">Open MegaForm admin</a>
            </div>
        }
    </div>
</section>

<style>
    .megaform-host .mf-form-wrapper {
        background: transparent !important;
        padding: 0 !important;
    }
</style>
