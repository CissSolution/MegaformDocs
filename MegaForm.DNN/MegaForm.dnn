<dotnetnuke type="Package" version="5.0">
  <packages>
    <package name="MegaForm" type="Module" version="01.06.32">
      <friendlyName>MegaForm</friendlyName>
      <description>Dynamic Form Builder Module for DNN - drag-and-drop builder, conditional logic, webhooks, anti-spam, email notifications, workflows, Save and Continue, Row/Column layout.</description>
      <iconFile>~/DesktopModules/MegaForm/Images/module-icon.png</iconFile>
      <owner>
        <name>MegaForm</name>
        <organization>MegaForm</organization>
        <url>https://megaform.example.com</url>
        <email>support@megaform.example.com</email>
      </owner>
      <license src="License.txt"/>
      <releaseNotes src="ReleaseNotes.txt"/>
      <azureCompatible>true</azureCompatible>
      <dependencies>
        <dependency type="CoreVersion">09.04.00</dependency>
      </dependencies>
      <components>
        <component type="Module">
          <desktopModule>
            <moduleName>MegaForm</moduleName>
            <foldername>MegaForm</foldername>
            <businessControllerClass>MegaForm.DNN.Components.FeatureController, MegaForm.DNN</businessControllerClass>
            <supportedFeatures>
              <supportedFeature type="Portable"/>
              <supportedFeature type="Upgradeable"/>
            </supportedFeatures>
            <moduleDefinitions>
              <moduleDefinition>
                <friendlyName>MegaForm</friendlyName>
                <defaultCacheTime>0</defaultCacheTime>
                <moduleControls>
                  <moduleControl>
                    <controlKey/>
                    <controlSrc>DesktopModules/MegaForm/Views/FormView.ascx</controlSrc>
                    <supportsPartialRendering>False</supportsPartialRendering>
                    <controlTitle>MegaForm</controlTitle>
                    <controlType>View</controlType>
                    <helpUrl/>
                  </moduleControl>
                  <moduleControl>
                    <controlKey>Edit</controlKey>
                    <controlSrc>DesktopModules/MegaForm/Views/FormEdit.ascx</controlSrc>
                    <supportsPartialRendering>False</supportsPartialRendering>
                    <controlTitle>Form Builder</controlTitle>
                    <controlType>Edit</controlType>
                  </moduleControl>
                  <moduleControl>
                    <controlKey>Submissions</controlKey>
                    <controlSrc>DesktopModules/MegaForm/Views/Submissions.ascx</controlSrc>
                    <supportsPartialRendering>False</supportsPartialRendering>
                    <controlTitle>View Submissions</controlTitle>
                    <controlType>Edit</controlType>
                  </moduleControl>
                  <moduleControl>
                    <controlKey>Tasks</controlKey>
                    <controlSrc>DesktopModules/MegaForm/Views/Tasks.ascx</controlSrc>
                    <supportsPartialRendering>False</supportsPartialRendering>
                    <controlTitle>Workflow Inbox</controlTitle>
                    <controlType>View</controlType>
                  </moduleControl>
                  <moduleControl>
                    <controlKey>ManageModule</controlKey>
                    <controlSrc>DesktopModules/MegaForm/Views/ManageModule.ascx</controlSrc>
                    <supportsPartialRendering>False</supportsPartialRendering>
                    <controlTitle>Manage module</controlTitle>
                    <controlType>Edit</controlType>
                  </moduleControl>
                  <moduleControl>
                    <controlKey>Settings</controlKey>
                    <controlSrc>DesktopModules/MegaForm/Views/Settings.ascx</controlSrc>
                    <supportsPartialRendering>False</supportsPartialRendering>
                    <controlTitle>MegaForm Settings</controlTitle>
                    <controlType>Admin</controlType>
                  </moduleControl>
                  <moduleControl>
                    <controlKey>FormList</controlKey>
                    <controlSrc>DesktopModules/MegaForm/Views/FormList.ascx</controlSrc>
                    <supportsPartialRendering>False</supportsPartialRendering>
                    <controlTitle>My Forms</controlTitle>
                    <controlType>Edit</controlType>
                  </moduleControl>
                </moduleControls>
              </moduleDefinition>
            </moduleDefinitions>
          </desktopModule>
        </component>
