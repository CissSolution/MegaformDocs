        </component>
        <component type="Assembly">
          <assemblies>
            <assembly>
              <name>MegaForm.DNN.dll</name>
              <path>bin</path>
            </assembly>
            <assembly>
              <name>MegaForm.Core.dll</name>
              <path>bin</path>
            </assembly>
            <!-- [2026-06-23] MegaForm.Sdk.dll was missing from the manifest, so every
                 DNN install/upgrade shipped without it. DnnServiceLocator..ctor() loads
                 the SDK, so the FIRST code to touch DnnServiceLocator.Instance (FormsOverview,
                 Reports/Backfill, scheduler tasks like BlogScheduledPublishTask) threw
                 "Could not load file or assembly 'MegaForm.Sdk'". Bundling it here fixes
                 the gap at the source. -->
            <assembly>
              <name>MegaForm.Sdk.dll</name>
              <path>bin</path>
            </assembly>
          </assemblies>
        </component>
        <component type="ResourceFile">
          <resourceFiles>
            <basePath>DesktopModules/MegaForm</basePath>
            <resourceFile>
