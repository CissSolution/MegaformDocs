-- ── MERGE seed entries into MF_AI_Knowledge ──────────────────────────
MERGE {databaseOwner}{objectQualifier}MF_AI_Knowledge AS target
USING (SELECT Slug, Kind, Title, Summary, Body, Tags, Examples FROM @kb) AS source
   ON target.Slug = source.Slug AND target.PortalId IS NULL
WHEN NOT MATCHED BY TARGET THEN
  INSERT (Slug, Kind, Title, Summary, Body, Tags, Examples, PortalId, Source, Version, CreatedOnDate)
  VALUES (source.Slug, source.Kind, source.Title, source.Summary, source.Body, source.Tags, source.Examples, NULL, 'megaform-builtin', 1, SYSUTCDATETIME())
WHEN MATCHED AND target.Source = 'megaform-builtin' THEN
  UPDATE SET
    Kind        = source.Kind,
    Title       = source.Title,
    Summary     = source.Summary,
    Body        = source.Body,
    Tags        = source.Tags,
    Examples    = source.Examples,
    Version     = target.Version + 1,
    UpdatedOnDate = SYSUTCDATETIME();
-- Note: rows with Source IN ('customer','customer-overridden') are NOT updated.

GO

