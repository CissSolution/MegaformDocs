-- MegaForm 01.06.27 — AI Knowledge Base (2026-05-28)
--
-- Adds the AI knowledge base used by the MegaForm AI Form Assistant:
--   MF_AI_Knowledge         — current knowledge entries
--   MF_AI_Knowledge_History — audit log of every edit (for rollback)
--
-- Each entry has Kind = widget | sql_sample | row_template | pager_template
--                       | form_pattern | designer | cascade_pattern | system_arch
-- and a Source = 'megaform-builtin' | 'customer' | 'customer-overridden'.
-- Future upgrades MERGE on Slug but only update Source='megaform-builtin' rows,
-- so customer-edited entries survive MegaForm updates.

IF OBJECT_ID('{databaseOwner}{objectQualifier}MF_AI_Knowledge', 'U') IS NULL
BEGIN
    CREATE TABLE {databaseOwner}{objectQualifier}MF_AI_Knowledge (
        Id              INT IDENTITY(1,1) PRIMARY KEY,
        Slug            NVARCHAR(160) NOT NULL,
        Kind            NVARCHAR(40)  NOT NULL,
        Title           NVARCHAR(200) NOT NULL,
        Summary         NVARCHAR(500) NULL,
        Body            NVARCHAR(MAX) NULL,
        Tags            NVARCHAR(500) NULL,
        Examples        NVARCHAR(MAX) NULL,
        PortalId        INT NULL,                   -- NULL = global
        Source          NVARCHAR(40)  NOT NULL CONSTRAINT DF_MF_AI_Knowledge_Source DEFAULT 'customer',
        Version         INT NOT NULL CONSTRAINT DF_MF_AI_Knowledge_Version DEFAULT 1,
        CreatedByUserId INT NULL,
        CreatedOnDate   DATETIME2 NOT NULL CONSTRAINT DF_MF_AI_Knowledge_CreatedOn DEFAULT SYSUTCDATETIME(),
        UpdatedByUserId INT NULL,
        UpdatedOnDate   DATETIME2 NULL,
        CONSTRAINT UQ_MF_AI_Knowledge_Slug UNIQUE (Slug, PortalId)
    );
    CREATE INDEX IX_MF_AI_Knowledge_Kind   ON {databaseOwner}{objectQualifier}MF_AI_Knowledge (Kind);
    CREATE INDEX IX_MF_AI_Knowledge_Source ON {databaseOwner}{objectQualifier}MF_AI_Knowledge (Source);
END;
GO

IF OBJECT_ID('{databaseOwner}{objectQualifier}MF_AI_Knowledge_History', 'U') IS NULL
BEGIN
    CREATE TABLE {databaseOwner}{objectQualifier}MF_AI_Knowledge_History (
        HistoryId       INT IDENTITY(1,1) PRIMARY KEY,
        KnowledgeId     INT NOT NULL,
        Slug            NVARCHAR(160) NOT NULL,
        Kind            NVARCHAR(40)  NOT NULL,
        Title           NVARCHAR(200) NOT NULL,
        Summary         NVARCHAR(500) NULL,
        Body            NVARCHAR(MAX) NULL,
        Tags            NVARCHAR(500) NULL,
        Examples        NVARCHAR(MAX) NULL,
        Source          NVARCHAR(40)  NOT NULL,
        Version         INT NOT NULL,
        ChangedByUserId INT NULL,
        ChangedOnDate   DATETIME2 NOT NULL CONSTRAINT DF_MF_AI_Knowledge_Hist_When DEFAULT SYSUTCDATETIME(),
        ChangeAction    NVARCHAR(16)  NOT NULL  -- 'create' | 'update' | 'delete'
    );
    CREATE INDEX IX_MF_AI_Knowledge_Hist_KnowledgeId ON {databaseOwner}{objectQualifier}MF_AI_Knowledge_History (KnowledgeId);
END;
GO

