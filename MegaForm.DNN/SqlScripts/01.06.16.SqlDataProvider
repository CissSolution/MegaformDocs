IF OBJECT_ID('dbo.spMegaForm_Sample_GetEventsByYear', 'P') IS NOT NULL
    DROP PROCEDURE dbo.spMegaForm_Sample_GetEventsByYear;
GO

CREATE PROCEDURE dbo.spMegaForm_Sample_GetEventsByYear
    @year NVARCHAR(20) = NULL
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @yearInt INT = NULL;
    IF (@year IS NOT NULL AND LEN(@year) > 0 AND ISNUMERIC(@year) = 1)
        SET @yearInt = CONVERT(INT, @year);

    SELECT
        CAST(EventId AS NVARCHAR(20))                                          AS [Value],
        EventName + COALESCE(' (' + City + N')', '') + COALESCE(' — ' + CONVERT(NVARCHAR(10), EventDate, 23), '') AS [Label]
    FROM dbo.MegaForm_Sample_Events
    WHERE (@yearInt IS NULL OR EventYear = @yearInt)
    ORDER BY EventDate, SortOrder, EventName;
END
GO
