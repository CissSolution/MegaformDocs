-- ============================================================
-- MegaForm 01.06.16 — Cascading SQL dropdown sample data
-- ============================================================
-- Adds sample tables + stored procedure to demonstrate the new
-- cascading dropdown feature (parent field value -> child options
-- filtered server-side via :token or stored proc parameter).
--
-- Objects created (safe to re-run):
--   dbo.MegaForm_Sample_Events     — table of demo events with EventYear
--   dbo.spMegaForm_Sample_GetEventsByYear  — stored proc returning
--       (EventId, EventLabel) for a given @year
--
-- Usage in MegaForm builder (Select / Dropdown field):
--   Source        = SQL
--   Query type    = SQL query (SELECT)
--   Connection    = SiteSqlServer
--   Database type = SqlServer
--   SQL query     = SELECT EventId, EventName + ' (' + City + ')'
--                   FROM MegaForm_Sample_Events
--                   WHERE EventYear = :year
--                   ORDER BY EventDate
--   Depends on    = year
--
-- OR using the stored procedure (recommended for production):
--   Query type    = Stored procedure
--   SQL query     = spMegaForm_Sample_GetEventsByYear
--   Depends on    = year
-- ============================================================

IF NOT EXISTS (SELECT 1 FROM sys.tables WHERE name = 'MegaForm_Sample_Events')
BEGIN
    CREATE TABLE dbo.MegaForm_Sample_Events
    (
        EventId    INT IDENTITY(1,1) NOT NULL PRIMARY KEY,
        EventYear  INT             NOT NULL,
        EventName  NVARCHAR(200)   NOT NULL,
        EventDate  DATE            NULL,
        City       NVARCHAR(120)   NULL,
        SortOrder  INT             NOT NULL CONSTRAINT DF_MegaForm_Sample_Events_SortOrder DEFAULT(0)
    );

    CREATE INDEX IX_MegaForm_Sample_Events_Year ON dbo.MegaForm_Sample_Events(EventYear);
END
GO

