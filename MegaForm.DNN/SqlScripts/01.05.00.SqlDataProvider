CREATE PROCEDURE dbo.usp_MF_Form_List
    @PortalId INT,
    @Status   NVARCHAR(20) = NULL,
    @Search   NVARCHAR(200) = NULL,
    @PageIndex INT = 0,
    @PageSize  INT = 20
AS
BEGIN
    SET NOCOUNT ON;
    SELECT f.*, 
           (SELECT COUNT(*) FROM dbo.MF_Submissions s WHERE s.FormId = f.FormId AND s.IsSpam = 0) AS SubmissionCount
    FROM dbo.MF_Forms f
    WHERE f.PortalId = @PortalId
      AND (@Status IS NULL OR f.[Status] = @Status)
      AND (@Search IS NULL OR f.Title LIKE '%' + @Search + '%')
    ORDER BY f.CreatedOnUtc DESC
    OFFSET @PageIndex * @PageSize ROWS FETCH NEXT @PageSize ROWS ONLY;
END
GO

