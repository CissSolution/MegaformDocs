CREATE PROCEDURE dbo.MF_IncrementUniqueId
    @FormId     INT,
    @FieldKey   NVARCHAR(100),
    @StartValue BIGINT = 1
AS
BEGIN
    SET NOCOUNT ON;
    IF NOT EXISTS (SELECT 1 FROM MF_UniqueIdCounters WHERE FormId = @FormId AND FieldKey = @FieldKey)
    BEGIN
        INSERT INTO MF_UniqueIdCounters (FormId, FieldKey, CurrentValue)
        VALUES (@FormId, @FieldKey, @StartValue - 1);
    END
    UPDATE MF_UniqueIdCounters
    SET CurrentValue = CurrentValue + 1
    OUTPUT inserted.CurrentValue
    WHERE FormId = @FormId AND FieldKey = @FieldKey;
END
GO

