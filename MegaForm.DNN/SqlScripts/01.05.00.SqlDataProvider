IF OBJECT_ID('dbo.MF_GetSubmissions_Filtered','P') IS NOT NULL DROP PROCEDURE dbo.MF_GetSubmissions_Filtered;
GO
CREATE PROCEDURE [dbo].[MF_GetSubmissions_Filtered]
    @FormId     INT,
    @UserId     INT,
    @UserRoles  NVARCHAR(MAX) = NULL,
    @Status     NVARCHAR(20)  = NULL,
    @Search     NVARCHAR(200) = NULL,
    @SortBy     NVARCHAR(50)  = 'SubmittedOnUtc',
    @SortDir    NVARCHAR(4)   = 'DESC',
    @Page       INT = 1,
    @PageSize   INT = 20
AS
BEGIN
    SET NOCOUNT ON;
    SELECT s.SubmissionId, s.FormId, s.DataJson, s.[Status],
           s.IpAddress, s.UserId, s.IsSpam, s.SpamScore,
           s.SubmittedOnUtc, s.ReadOnUtc
    FROM MF_Submissions s
    WHERE s.FormId = @FormId
      AND s.[Status] <> 'Deleted'
      AND (@Status IS NULL OR s.[Status] = @Status)
      AND (@Search IS NULL OR s.DataJson LIKE '%' + @Search + '%')
    ORDER BY
        CASE WHEN @SortBy='SubmittedOnUtc' AND @SortDir='DESC' THEN s.SubmittedOnUtc END DESC,
        CASE WHEN @SortBy='SubmittedOnUtc' AND @SortDir='ASC'  THEN s.SubmittedOnUtc END ASC,
        CASE WHEN @SortBy='Status'         AND @SortDir='DESC' THEN s.[Status] END DESC,
        CASE WHEN @SortBy='Status'         AND @SortDir='ASC'  THEN s.[Status] END ASC
    OFFSET (@Page - 1) * @PageSize ROWS
    FETCH NEXT @PageSize ROWS ONLY;

    SELECT COUNT(*) AS TotalCount
    FROM MF_Submissions s
    WHERE s.FormId = @FormId
      AND s.[Status] <> 'Deleted'
      AND (@Status IS NULL OR s.[Status] = @Status)
      AND (@Search IS NULL OR s.DataJson LIKE '%' + @Search + '%');
END
GO

