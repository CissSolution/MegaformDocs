-- usp_MF_Form_Upsert
IF OBJECT_ID('dbo.usp_MF_Form_Upsert','P') IS NOT NULL DROP PROCEDURE dbo.usp_MF_Form_Upsert;
GO
CREATE PROCEDURE dbo.usp_MF_Form_Upsert
    @FormId          INT OUTPUT,
    @ModuleId        INT,
    @PortalId        INT,
    @Title           NVARCHAR(500),
    @Description     NVARCHAR(MAX),
    @SchemaJson      NVARCHAR(MAX),
    @SettingsJson    NVARCHAR(MAX),
    @ThemeJson       NVARCHAR(MAX),
    @Status          NVARCHAR(20),
    @SubmitButtonText NVARCHAR(200),
    @SuccessMessage  NVARCHAR(MAX),
    @RedirectUrl     NVARCHAR(1000),
    @MaxSubmissions  INT,
    @ExpiresOnUtc    DATETIME2,
    @RequireAuth     BIT,
    @EnableCaptcha   BIT,
    @EnableSaveResume BIT,
    @WebhookUrl      NVARCHAR(1000),
    @WebhookSecret   NVARCHAR(500),
    @WebhookHeaders  NVARCHAR(MAX),
    @NotifyEmails    NVARCHAR(MAX),
    @NotifyTemplate  NVARCHAR(MAX),
    @AutoresponderEnabled BIT,
    @AutoresponderEmailField NVARCHAR(200),
    @AutoresponderSubject NVARCHAR(500),
    @AutoresponderBody NVARCHAR(MAX),
    @AppScope        NVARCHAR(50) = NULL,
    @UserId          INT
AS
BEGIN
    SET NOCOUNT ON;
    IF @FormId > 0 AND EXISTS (SELECT 1 FROM dbo.MF_Forms WHERE FormId = @FormId)
    BEGIN
        UPDATE dbo.MF_Forms SET
            Title = @Title, [Description] = @Description, SchemaJson = @SchemaJson,
            SettingsJson = @SettingsJson, ThemeJson = @ThemeJson, [Status] = @Status,
            SubmitButtonText = @SubmitButtonText, SuccessMessage = @SuccessMessage,
            RedirectUrl = @RedirectUrl, MaxSubmissions = @MaxSubmissions,
            ExpiresOnUtc = @ExpiresOnUtc, RequireAuth = @RequireAuth,
            EnableCaptcha = @EnableCaptcha, EnableSaveResume = @EnableSaveResume,
            WebhookUrl = @WebhookUrl, WebhookSecret = @WebhookSecret,
            WebhookHeaders = @WebhookHeaders, NotifyEmails = @NotifyEmails,
            NotifyTemplate = @NotifyTemplate,
            AutoresponderEnabled = @AutoresponderEnabled,
            AutoresponderEmailField = @AutoresponderEmailField,
            AutoresponderSubject = @AutoresponderSubject,
            AutoresponderBody = @AutoresponderBody,
            AppScope = @AppScope,
            UpdatedByUserId = @UserId, UpdatedOnUtc = SYSUTCDATETIME()
        WHERE FormId = @FormId;
    END
    ELSE
    BEGIN
        INSERT INTO dbo.MF_Forms (
            ModuleId, PortalId, Title, [Description], SchemaJson, SettingsJson, ThemeJson,
            [Status], SubmitButtonText, SuccessMessage, RedirectUrl, MaxSubmissions,
            ExpiresOnUtc, RequireAuth, EnableCaptcha, EnableSaveResume,
            WebhookUrl, WebhookSecret, WebhookHeaders, NotifyEmails, NotifyTemplate,
            AutoresponderEnabled, AutoresponderEmailField, AutoresponderSubject,
            AutoresponderBody, AppScope, CreatedByUserId
        ) VALUES (
            @ModuleId, @PortalId, @Title, @Description, @SchemaJson, @SettingsJson, @ThemeJson,
            @Status, @SubmitButtonText, @SuccessMessage, @RedirectUrl, @MaxSubmissions,
            @ExpiresOnUtc, @RequireAuth, @EnableCaptcha, @EnableSaveResume,
            @WebhookUrl, @WebhookSecret, @WebhookHeaders, @NotifyEmails, @NotifyTemplate,
            @AutoresponderEnabled, @AutoresponderEmailField, @AutoresponderSubject,
            @AutoresponderBody, @AppScope, @UserId
        );
        SET @FormId = SCOPE_IDENTITY();
    END
END
GO

