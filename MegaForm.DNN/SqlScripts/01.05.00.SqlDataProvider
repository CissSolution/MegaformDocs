IF OBJECT_ID('dbo.usp_MF_Form_Stats','P') IS NOT NULL DROP PROCEDURE dbo.usp_MF_Form_Stats;
GO
CREATE PROCEDURE dbo.usp_MF_Form_Stats
    @FormId INT
AS
BEGIN
    SET NOCOUNT ON;
    SELECT 
        ISNULL(COUNT(*), 0) AS TotalSubmissions,
        ISNULL(SUM(CASE WHEN IsSpam = 0 THEN 1 ELSE 0 END), 0) AS ValidSubmissions,
        ISNULL(SUM(CASE WHEN IsSpam = 1 THEN 1 ELSE 0 END), 0) AS SpamSubmissions,
        ISNULL(SUM(CASE WHEN [Status] = 'Read' THEN 1 ELSE 0 END), 0) AS ReadSubmissions,
        MIN(SubmittedOnUtc) AS FirstSubmission,
        MAX(SubmittedOnUtc) AS LastSubmission
    FROM dbo.MF_Submissions
    WHERE FormId = @FormId;
END
GO

