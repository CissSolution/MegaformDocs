IF OBJECT_ID('dbo.usp_MF_RateLimit_Check','P') IS NOT NULL DROP PROCEDURE dbo.usp_MF_RateLimit_Check;
GO
CREATE PROCEDURE dbo.usp_MF_RateLimit_Check
    @FormId     INT,
    @IpAddress  NVARCHAR(45),
    @WindowMinutes INT = 5,
    @MaxPerWindow  INT = 3,
    @IsAllowed  BIT OUTPUT
AS
BEGIN
    SET NOCOUNT ON;
    DECLARE @Count INT;
    SELECT @Count = COUNT(*)
    FROM dbo.MF_RateLimitLog
    WHERE FormId = @FormId
      AND IpAddress = @IpAddress
      AND SubmittedOnUtc >= DATEADD(MINUTE, -@WindowMinutes, SYSUTCDATETIME());

    IF @Count >= @MaxPerWindow
        SET @IsAllowed = 0;
    ELSE
    BEGIN
        SET @IsAllowed = 1;
        INSERT INTO dbo.MF_RateLimitLog (FormId, IpAddress) VALUES (@FormId, @IpAddress);
    END
END
GO

