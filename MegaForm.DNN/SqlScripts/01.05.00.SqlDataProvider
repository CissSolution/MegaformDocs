-- usp_MF_Submission_List
IF OBJECT_ID('dbo.usp_MF_Submission_List','P') IS NOT NULL DROP PROCEDURE dbo.usp_MF_Submission_List;
GO
CREATE PROCEDURE dbo.usp_MF_Submission_List
    @FormId    INT,
    @Status    NVARCHAR(20) = NULL,
    @Search    NVARCHAR(500) = NULL,
    @DateFrom  DATETIME2 = NULL,
    @DateTo    DATETIME2 = NULL,
    @PageIndex INT = 0,
    @PageSize  INT = 50
AS
BEGIN
    SET NOCOUNT ON;
    SELECT s.*
    FROM dbo.MF_Submissions s
    WHERE s.FormId = @FormId
      AND (@Status IS NULL OR s.[Status] = @Status)
      AND (@DateFrom IS NULL OR s.SubmittedOnUtc >= @DateFrom)
      AND (@DateTo IS NULL OR s.SubmittedOnUtc <= @DateTo)
      AND (@Search IS NULL OR EXISTS (
            SELECT 1 FROM dbo.MF_SubmissionValues v 
            WHERE v.SubmissionId = s.SubmissionId AND v.FieldValue LIKE '%' + @Search + '%'
      ))
    ORDER BY s.SubmittedOnUtc DESC
    OFFSET @PageIndex * @PageSize ROWS FETCH NEXT @PageSize ROWS ONLY;

    -- Total count for paging
    SELECT COUNT(*) AS TotalCount
    FROM dbo.MF_Submissions s
    WHERE s.FormId = @FormId
      AND (@Status IS NULL OR s.[Status] = @Status)
      AND (@DateFrom IS NULL OR s.SubmittedOnUtc >= @DateFrom)
      AND (@DateTo IS NULL OR s.SubmittedOnUtc <= @DateTo)
      AND (@Search IS NULL OR EXISTS (
            SELECT 1 FROM dbo.MF_SubmissionValues v 
            WHERE v.SubmissionId = s.SubmissionId AND v.FieldValue LIKE '%' + @Search + '%'
      ));
END
GO

