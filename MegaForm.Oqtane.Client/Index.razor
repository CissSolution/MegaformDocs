private string BuildCurrentModuleUrl(string key, string value)
{
    var baseUrl = GetCurrentPageRendererHostUrl();
    var parts = new List<string>();
    var editValue = GetQueryValue(NavigationManager?.Uri ?? string.Empty, "edit");
    if (!string.IsNullOrWhiteSpace(editValue))
    {
        parts.Add("edit=" + Uri.EscapeDataString(editValue));
    }
    if (!string.IsNullOrWhiteSpace(key) && value != null)
    {
        parts.Add(key + "=" + Uri.EscapeDataString(value));
    }
    return parts.Count == 0 ? baseUrl : baseUrl + "?" + string.Join("&", parts);
}

private string BuildStarterBoardUrl()
{
    if (!string.IsNullOrWhiteSpace(_activeViewKey))
    {
        return BuildCurrentModuleUrl("vk", _activeViewKey);
