        else if (!IsStaticRender && _fastEmbed && !SsrMode && _formId > 0 && _isPublished && !IsPopupMode && !_embedMode)
        {
            @* [FastEmbed v20260620-B209] Render the form via an <iframe> to the server-rendered
               fast page (/api/MegaForm/render/{id}). The form HTML is in the iframe's INITIAL
               response — no per-module Schema fetch, no waiting for the JS renderer. The iframe
               auto-resizes from the page's postMessage height broadcast (listener wired in
               BuildFastEmbedBootScript). Opt in with MegaForm:FastEmbed=true or ?mffast=1. *@
            @* [FastEmbed recreate fix v20260621-B217] The <iframe> is NO LONGER in Blazor's render
               tree. We render only an EMPTY, constant host <div>; BuildFastEmbedBootScript creates
               the <iframe> via JS once (idempotent) and appends it here. Reason: when the iframe
               lived in the Razor tree, Oqtane's interactive hydration / any later re-render made
               Blazor DIFF and RECREATE the <iframe> element (@key + deterministic markup did NOT
               stop it) → src reloaded a 2nd time (double-load of render/{id} + Schema + images).
               A constant empty <div> is a no-op for Blazor's diff, so it is never recreated, and a
               JS-injected child outside the virtual tree is never touched. The iframe is a separate
               document, so the in-frame JS renderer never mutates Blazor-managed DOM (no circuit
               batch conflict — the failure mode that killed the prerender SSR-in-place attempt). *@
            @* [B218 experiment, REVERTED 2026-06-21] We TRIED adding @key="mf-fast-host-{_formId}"
               here to also kill the admin-only host/edit-view 2nd fetch (anon was already single-load).
               It did NOT help: render/{id} still fetched 2× on the anon→edit transition (QA
               qa-hosthome-urls → {"744":2}, unchanged) because that transition does NOT diff this
               element — Oqtane REPLACES the whole module subtree when edit mode turns on, so a @key on
               a child div can't preserve it. @key was removed (no-op here). Anon stays perfect (every
               public visitor = 1 load); the host/edit 2nd fetch is admin-only, one-time, end-state
               correct (exactly 1 iframe, 0 batch errors). Do not re-add @key expecting a fix. *@
            <div id="@($"mf-fast-host-{FormMountId}")"
                 class="mf-fast-embed-host"
                 data-mf-fast-form="@_formId"
                 style="display:block;width:100%;min-height:460px;"></div>
        }
        else
        {
            @* [2026-06-18 SchemaPreload] Embed resolved schema into the initial HTML so the
               JS renderer can paint the form immediately after MegaFormRenderer loads,
               without waiting for the interactive Blazor circuit to trigger a second
               /api/MegaForm/Schema/{id} fetch. This removes the ~1.2s dead zone caused
               by SignalR connect + component lifecycle. *@
            @if (_formId > 0 && _isPublished && !IsPopupMode && _preloadedForm != null)
            {
                <script type="application/json" id="mf-preload-schema-@FormMountId">
                    @((MarkupString)BuildPreloadSchemaJson())
                </script>
            }
            <div id="@FormMountId"
                 data-form-id="@_formId"
                 data-module-id="@(ModuleState?.ModuleId ?? 0)">@if (SsrMode && !string.IsNullOrEmpty(_ssrFieldsHtml))
                {
                    @* [2026-06-13 SSR] Server-rendered form body for SEO + fast first paint.
                       Crawlers (no JS) see the real field labels/inputs/text here; the JS
                       renderer hydrates this DOM (or rebuilds identically when hydration off). *@
                    @* [C v20260621] data-mf-has-custom-html is the marker megaform.css uses to strip the
                       default form padding/card so a custom-HTML shell goes full-width. The JS renderer
                       sets it on rebuild (renderer/index.ts:1165); the prerender MUST set it too, else the
                       SSR card renders narrower (default padding) and visibly snaps wider when JS runs. *@
                    <div id="mf-form-wrapper-@_formId" class="@_ssrWrapperClass" data-mf-has-custom-html="@(_ssrHasCustom ? "1" : null)" data-mf-ssr="1">
                        <form id="mf-form-@_formId" class="mf-form" novalidate>
                            <div id="mf-fields-container-@_formId">@((MarkupString)_ssrFieldsHtml)</div>
                        </form>
                    </div>
                }
                else if (!IsPopupMode)
                {
