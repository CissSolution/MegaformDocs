@* [EditMode admin dock 2026-06-13] Shared admin dock rendered both in normal
   form view and when the module is pinned to a surface, so long as ShouldShowAdminDock. *@
@{
    RenderFragment RenderAdminDock = @<text>
    <div class="mf-oq-admin-dock">
        <a class="mf-oq-btn" href="@BuildSettingsUrl()" data-mf-settings-link="1" onclick="@BuildSettingsInlineOpenScript()"><i class="fas fa-cog"></i> Settings</a>
        <a class="mf-oq-linkbtn" href="@BuildPanelUrl("builder")"><i class="fas fa-pen-ruler"></i> Form Builder</a>
        <a class="mf-oq-linkbtn" href="@BuildPanelUrl("dashboard")" data-mf-shared-dashboard-badge="OQDashboardLink v20260429-01"><i class="fas fa-table-columns"></i> Form Dashboard</a>
        @if (!IsFormMode && _formId > 0)
        {
            <a class="mf-oq-linkbtn" href="@BuildPanelUrl("builder")"><i class="fas fa-paintbrush"></i> Design Template</a>
        }
    </div>
    <div id="@SettingsInlineHostId" class="mf-oq-settings-inline-host" data-mf-settings-inline-host="1"></div>
    <script data-mf-settings-dock-boot="1">
        @((MarkupString)BuildSettingsDockBootScript())
    </script>
    </text>;
}

@* [FastPaint v20260620] Form-shaped loading skeleton, reused in BOTH the _loading window
   AND the form-mount div. Rendering it during _loading (keyed off the synchronously-known
   _formId) makes the form FRAME appear at the SAME instant as the admin dock — the module
   does not prerender, so the dock + this skeleton both land on the first post-circuit render,
   eliminating the ~2s blank gap before the JS renderer paints the real form. The renderer's
   buildSkeleton() overwrites the mount innerHTML on init (it only no-ops when
   #mf-fields-container-{id} exists, which this skeleton avoids), so it is cleanly replaced. *@
@{
    RenderFragment RenderFormSkeleton = @<div class="mf-skeleton" data-mf-skeleton="FastPaint v20260620" role="status" aria-label="Loading form">
        <div class="mf-skeleton-card" aria-hidden="true">
            <div class="mf-skel-bar mf-skel-title"></div>
            <div class="mf-skel-bar mf-skel-subtitle"></div>
            <div class="mf-skel-field"><span class="mf-skel-bar mf-skel-label"></span><span class="mf-skel-bar mf-skel-input"></span></div>
            <div class="mf-skel-field"><span class="mf-skel-bar mf-skel-label"></span><span class="mf-skel-bar mf-skel-input"></span></div>
            <div class="mf-skel-field"><span class="mf-skel-bar mf-skel-label"></span><span class="mf-skel-bar mf-skel-input"></span></div>
            <div class="mf-skel-actions"><span class="mf-skel-btn"></span></div>
        </div>
    </div>;
}

@* [EditMode settings panel 2026-06-13] Shared settings panel rendered both in normal
   form view and above a pinned surface so the Settings button opens the panel in a
   predictable location (above the surface, not below it). *@
@{
    RenderFragment RenderSettingsPanel = @<text>
        @if (_showSettingsPanel)
        {
            <div class="mf-oq-panel">
                <h3><i class="fas fa-cog"></i> Module Settings</h3>
                <p class="mf-oq-help">Configure the form, display mode, and theme for this module instance.</p>

                <div class="mf-oq-acc">

                    @* â”€â”€ 1. Surface Role (always shown) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ *@
                    <div class="mf-oq-acc-item @(_settingsOpenSection == "role" ? "is-open" : null)">
                        <button type="button" class="mf-oq-acc-hd" @onclick='() => ToggleSettingsSection("role")'>
                            <span class="mf-oq-acc-ic"><i class="fas fa-thumbtack"></i></span>
                            Surface Role
                            <span class="mf-oq-acc-sub">@(string.IsNullOrEmpty(_moduleRole) ? "Form / View" : char.ToUpper(_moduleRole[0]) + _moduleRole.Substring(1))</span>
                            <span class="mf-oq-acc-chev"><i class="fas fa-chevron-right"></i></span>
                        </button>
                        @if (_settingsOpenSection == "role")
                        {
                            <div class="mf-oq-acc-bd">
                                <p class="mf-oq-help" style="margin:0 0 10px;">Pin this module to a fixed surface. When a role is set, this module <strong>is</strong> that surface (opened as a full-screen panel) and the form/display options below are hidden.</p>
                                <div class="mf-oq-formgrid">
                                    <label>Module Role</label>
                                    <select @bind="_moduleRole">
                                        <option value="">Form / View (default)</option>
                                        <option value="dashboard">Dashboard</option>
                                        <option value="myinbox">My Inbox</option>
                                        <option value="submissions">Submissions</option>
                                        <option value="portal">Portal</option>
                                        <option value="builder">Form Builder</option>
                                        <option value="languages">Languages (admin)</option>
                                    </select>
                                </div>
                                @if (!string.IsNullOrEmpty(_moduleRole))
                                {
                                    <div class="mf-oq-note" style="margin-top:12px;">
                                        <span class="mf-oq-rolebadge"><i class="fas fa-thumbtack"></i> @_moduleRole</span>
                                        This page opens the <strong>@_moduleRole</strong> surface as a full-screen panel. Add <code>?mfconfig=1</code> to the URL to reach these settings again.
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @* The form / display / appearance groups only apply when NOT role-pinned *@
                    @if (string.IsNullOrEmpty(_moduleRole))
                    {
                        @* â”€â”€ 2. Form Binding â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ *@
                        <div class="mf-oq-acc-item @(_settingsOpenSection == "binding" ? "is-open" : null)">
                            <button type="button" class="mf-oq-acc-hd" @onclick='() => ToggleSettingsSection("binding")'>
                                <span class="mf-oq-acc-ic"><i class="fas fa-link"></i></span>
                                Form Binding
                                <span class="mf-oq-acc-sub">@(_formId > 0 ? $"Form #{_formId}" : "No form")</span>
                                <span class="mf-oq-acc-chev"><i class="fas fa-chevron-right"></i></span>
                            </button>
                            @if (_settingsOpenSection == "binding")
                            {
                                <div class="mf-oq-acc-bd">
                                    <div class="mf-oq-formgrid">
                                        <label>Bound Form</label>
                                        <select @bind="_formId">
                                            <option value="0">â€” Select a form â€”</option>
                                            @foreach (var f in _forms)
                                            {
                                                <option value="@f.FormId">@(f.Title ?? $"Form {f.FormId}") (ID @f.FormId)</option>
                                            }
                                        </select>
                                        @* [FormOnly 2026-06-17] View Mode selector removed — this module always renders the form view. *@
                                    </div>
                                </div>
                            }
                        </div>

                        @* â”€â”€ 3. Display & Popup â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ *@
                        <div class="mf-oq-acc-item @(_settingsOpenSection == "display" ? "is-open" : null)">
                            <button type="button" class="mf-oq-acc-hd" @onclick='() => ToggleSettingsSection("display")'>
                                <span class="mf-oq-acc-ic"><i class="fas fa-window-restore"></i></span>
                                Display &amp; Popup
                                <span class="mf-oq-acc-sub">@_displayMode</span>
                                <span class="mf-oq-acc-chev"><i class="fas fa-chevron-right"></i></span>
                            </button>
                            @if (_settingsOpenSection == "display")
                            {
                                <div class="mf-oq-acc-bd">
                                    <div class="mf-oq-formgrid">
                                        <label>Display Mode</label>
                                        <select @bind="_displayMode">
                                            <option value="fixed">Fixed (inline)</option>
                                            <option value="popup">Popup</option>
                                        </select>
                                    </div>
                                    @if (_displayMode == "popup")
                                    {
                                        <div class="mf-oq-formgrid" style="margin-top:12px;">
                                            <label>Popup Size</label>
                                            <select @bind="_popupSize">
                                                <option value="small">Small (360px)</option>
                                                <option value="medium">Medium (560px)</option>
                                                <option value="large">Large (820px)</option>
                                                <option value="fullscreen">Fullscreen</option>
                                            </select>
                                            <label>Trigger Type</label>
                                            <select @bind="_triggerType">
                                                <option value="time_delay">Time Delay</option>
                                                <option value="scroll_depth">Scroll Percentage</option>
                                                <option value="click_trigger">Click Selector</option>
                                            </select>
                                            @if (_triggerType == "time_delay")
                                            {
                                                <label>Delay (seconds)</label>
                                                <input type="number" min="0" @bind="_delaySeconds" />
                                            }
                                            @if (_triggerType == "scroll_depth")
                                            {
                                                <label>Scroll %</label>
                                                <input type="number" min="0" max="100" @bind="_scrollPercent" />
                                            }
                                            @if (_triggerType == "click_trigger")
                                            {
                                                <label>Click Selector</label>
                                                <input type="text" @bind="_clickSelector" placeholder=".btn-open-form" />
                                            }
                                        </div>

                                        @* Sample HTML triggers the user can drop onto the page *@
                                        <div class="mf-oq-snip">
                                            <h5><i class="fas fa-code"></i> Sample HTML triggers</h5>
                                            <p>Paste one of these into any HTML module / page to open this form. <code>data-mf-open-form</code> points at the bound form id.</p>

                                            <h5>Button</h5>
                                            <pre>@SampleButtonHtml</pre>

                                            <h5>Sticky tab â€” left edge</h5>
                                            <pre>@SampleStickyLeftHtml</pre>

                                            <h5>Sticky tab â€” right edge</h5>
                                            <pre>@SampleStickyRightHtml</pre>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        @* [FormOnly 2026-06-17] Appearance / Theme Preset section removed — it was not persisted by inline save and is unused. *@
                    }
                </div>

                <div class="mf-oq-actions">
                    <button type="button" class="mf-oq-btn is-primary" disabled="@_settingsBusy" @onclick="SaveInlineSettingsAsync">
                        @if (_settingsBusy)
                        {
                            <span><i class="fas fa-spinner fa-spin"></i> Savingâ€¦</span>
                        }
                        else
                        {
                            <span><i class="fas fa-save"></i> Save Settings</span>
                        }
                    </button>
                    <button type="button" class="mf-oq-btn" @onclick="ClosePanels"><i class="fas fa-times"></i> Close</button>
                </div>

                @if (!IsFormMode && _formId > 0)
                {
                    <div class="mf-oq-note" style="margin-top:14px;">
                        <strong>Sample Data</strong><br />
                        This view mode needs submission data to display.
                        <button type="button" class="mf-oq-btn" style="margin-top:8px;" disabled="@_seedBusy" @onclick="GenerateSampleDataAsync">
                            @if (_seedBusy)
                            {
                                <span><i class="fas fa-spinner fa-spin"></i> Generatingâ€¦</span>
                            }
                            else
                            {
                                <span><i class="fas fa-wand-magic-sparkles"></i> Generate Sample Data</span>
                            }
                        </button>
                    </div>
                }
            </div>
        }
    </text>;
}



@* [EditMode action-menu fix — updated 2026-06-18] In Oqtane edit mode the admin needs the
   NATIVE module action menu (the ▼ dropdown: Manage Settings / Unpublish / Delete / Move…)
   next to each MegaForm module. THREE things broke it on themes with a pinned header
   (reproduced live on the `acme-mock-oqtane` theme @ :5070, which has a Bootstrap
   `navbar fixed-top`):

   (1) [B182] `.app-moduleactions` had no z-index of its own, so a MegaForm surface/card/
       admin-dock in the same pane could visually COVER it → admin sees an empty spot.
   (2) The theme pins its header with `position:fixed` (Bootstrap `.fixed-top`), which removes
       it from layout flow. Oqtane renders each module's action menu at the TOP of the module,
       so with no flow space reserved the ▼ rendered UNDERNEATH the fixed header — landing on
       the logo, and once scrolled it vanished completely behind the header ("không thấy docking
       button"). FIX: in edit mode convert any top-pinned header to `sticky` so it RESERVES flow
       space (content — and every action menu — drops below it) while staying pinned, and keep
       the action menu just BELOW the header's z-index (Bootstrap navbar = 1030) so on scroll it
       tucks BEHIND the header instead of floating over the logo. (1000 < 1030 < offcanvas 1045,
       so the Oqtane control-panel slide-out is unaffected.)
   (3) MegaForm's global typography / Bootstrap-var styling bled into the native dropdown (Geist
       font + dark menu surface) — the "CSS bị ảnh hưởng bởi MegaForm" report. Re-assert a clean,
       native, readable LIGHT menu so the edit chrome looks like stock Oqtane, not MegaForm.

   All gated on IsEditMode → ZERO effect on the live public form (the header stays `fixed-top`
   for visitors); it only ever makes Oqtane's own edit chrome MORE visible/usable. *@
@if (IsEditMode)
{
    <style>
        /* (2) Pinned theme header → sticky in edit mode, so module action menus clear it both at
           the top of the page AND on scroll (header reserves flow space + stays pinned). */
        .fixed-top { position: sticky !important; top: 0 !important; }

        /* (2b) [TopGapFix 2026-06-23] The theme reserves `body{padding-top:Nrem}` to clear its
           FIXED header. Once (2) makes that header `sticky` it re-enters the flow and provides
           its OWN space, so the reserved body padding now doubles up as an empty band at the very
           top of the page. Drop it — scoped to `:has(.fixed-top)` so it ONLY fires on the exact
           pinned-header theme that hits this, and only in edit mode (whole block is gated). */
        body:has(.fixed-top) { padding-top: 0 !important; }

        /* (1) Make the native action menu visible above MegaForm content, but keep it BELOW the
           header (z 1030) so it tucks behind the header on scroll rather than over the logo. */
        .app-moduleactions { position: relative; z-index: 1000; display: inline-block !important;
            visibility: visible !important; opacity: 1 !important; }
        .app-moduleactions .dropdown-toggle { display: inline-flex !important; align-items: center;
            justify-content: center; min-width: 30px; min-height: 30px; padding: 4px 8px;
            border: 1px solid #cbd5e1; border-radius: 8px; background: #ffffff; color: #334155 !important;
            box-shadow: 0 1px 2px rgba(15, 23, 42, .06); }
        .app-moduleactions .dropdown-toggle::after { display: inline-block !important; opacity: .85; margin-left: 2px; }

        /* (3) De-contaminate the native dropdown from MegaForm/theme bleed: clean light surface,
           readable dark text + icons, system font — matching stock Oqtane edit chrome. */
        .app-moduleactions .dropdown-menu { z-index: 1300; background-color: #ffffff !important;
            color: #212529 !important; border: 1px solid rgba(0, 0, 0, .15) !important;
            box-shadow: 0 .5rem 1rem rgba(0, 0, 0, .175) !important;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif !important; }
        .app-moduleactions .dropdown-menu .dropdown-item,
        .app-moduleactions .dropdown-menu .dropdown-item i,
        .app-moduleactions .dropdown-menu .dropdown-item svg,
        .app-moduleactions .dropdown-menu a { color: #212529 !important; }
        .app-moduleactions .dropdown-menu .dropdown-item:hover,
        .app-moduleactions .dropdown-menu .dropdown-item:focus { background-color: #e9ecef !important; color: #1e2125 !important; }
        .app-moduleactions .dropdown-divider { border-top-color: rgba(0, 0, 0, .15) !important; }
    </style>
}

@if (_panelMode != MfPanelMode.None)
{
    @* [Inline surface 2026-06-11] is-fs = full-screen overlay (admin ?mfpanel= nav);
       is-inline = renders in the module pane so the Oqtane page keeps a normal CMS
       layout (other modules above/below). For inline, the inner full-page apps are
       sized to a viewport-relative height instead of 100vh. *@
    <style>
        .mf-oq-surface { background: #f8fafc; }
        .mf-oq-surface.is-fs { position: fixed; inset: 0; z-index: 10000; overflow: auto; }
        /* [Inline default 2026-06-12] Fullscreen toggle button â€” ALWAYS floats at the surface's
           top-right corner (consistent on every surface, per user request). */
        .mf-fs-toggle { display: inline-flex; align-items: center; gap: 6px; border: 1px solid #cbd5e1;
            background: #fff; color: #334155; padding: 7px 11px; border-radius: 9px; font-family: inherit;
            font-size: 13px; font-weight: 600; cursor: pointer; transition: .15s; white-space: nowrap; }
        .mf-fs-toggle:hover { background: #0f172a; color: #fff; border-color: #0f172a; }
        .mf-fs-toggle svg { width: 14px; height: 14px; flex-shrink: 0; }
        /* [2026-06-13] Mode toast — VIEWPORT-fixed (mounted on the page body, not inside the surface) so
           the windowed⇄fullscreen control is ALWAYS visible, even when the surface is far down the
           page or scrolled. (Was position:absolute inside the surface → scrolled away + was painted
           over by the host fixed-top navbar because the surface is an isolation stacking context.) */
        .mf-fs-toggle.mf-fs-floating { position: fixed; right: 16px; bottom: 16px; top: auto;
            z-index: 2147483600; box-shadow: 0 6px 20px rgba(15, 23, 42, .28); }
        [dir="rtl"] .mf-fs-toggle.mf-fs-floating { right: auto; left: 16px; }
        /* In Oqtane page EDIT mode the admin is arranging modules — make the mode toast pop so it's
           obviously the control to switch working mode. */
        html.mf-host-editmode .mf-fs-toggle.mf-fs-floating { border-color: #6366f1; color: #4338ca;
            box-shadow: 0 8px 24px rgba(99, 102, 241, .45); }
        html.mf-host-editmode .mf-fs-toggle.mf-fs-floating:hover { background: #6366f1; color: #fff; border-color: #6366f1; }
        /* [Inline-isolation 2026-06-12] When embedded in a host pane, re-assert MegaForm's
           own typography so the host theme's font-family/size/line-height/color stop
           cascading in (the latent theme-conflict), establish an isolated stacking context,
           and guarantee a minimum height so a host flex/grid pane can't collapse the surface.
           This is the lightweight precursor to the cascade-layer isolation in the handoff. */
        .mf-oq-surface.is-inline { position: relative; width: 100%; overflow-x: auto;
            font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
            font-size: 14px; line-height: 1.5; color: #0f172a;
            /* [2026-06-12] `contain: layout` REMOVED â€” it establishes a containing block for
               position:fixed descendants, so popups mounted inside the builder shell (Token
               Designer, image gallery, etc.) rendered in-flow at the bottom of the page instead
               of as a centered viewport overlay. isolation:isolate (stacking) + the scoped
               typography reset already give host-theme immunity without trapping fixed. */
            isolation: isolate; min-height: 60vh; }
        /* [2026-06-12] NOTE: the full Token/Image/Map designer modal CSS (backdrop dim+blur,
           centered shell, head gradient, tabs, token rows) lives in megaform-builder.css
           (~line 1063, ".mf-token-designer-*"). The popup looked unstyled + dropped to the
           bottom of the page because the DEPLOYED megaform-builder.css was stale and missing
           those rules â€” the real fix is redeploying that CSS, not re-declaring it here. The
           modal is mounted on document.body (token-designer.ts getMountTarget) so its
           position:fixed backdrop escapes the builder shell's stacking context. */
        /* Re-assert on common inner roots too (defensive against host element-level rules). */
        .mf-oq-surface.is-inline .mf-sidebar, .mf-oq-surface.is-inline .mf-hd,
        .mf-oq-surface.is-inline .mf-main, .mf-oq-surface.is-inline #mf-dashboard-root,
        .mf-oq-surface.is-inline .mf-subs-shell, .mf-oq-surface.is-inline .mf-mi3-shell {
            font-family: inherit; line-height: inherit; color: inherit; }
        /* Broaden the inherited-property reset so a host theme's text styling can't bleed
           into the embedded surface (text-align:start keeps RTL working). */
        .mf-oq-surface.is-inline { letter-spacing: normal; text-transform: none;
            text-align: start; text-decoration: none; font-weight: 400; font-style: normal;
            white-space: normal; text-shadow: none; }
        .mf-oq-surface.is-inline :where(input, textarea, select, button, a) { letter-spacing: inherit; }
        .mf-oq-surface.is-inline :where(input, textarea, select, button) { font: inherit; }
        /* Responsive: when the host module pane is narrower than the inner app, let the
           header bar + KPI strip + submissions toolbar WRAP/scroll instead of clipping
           (the one real visual break seen inline; full-screen is unaffected). */
        .mf-oq-surface.is-inline .mf-hd { flex-wrap: wrap; height: auto; row-gap: 6px; }
        .mf-oq-surface.is-inline .mf-stats-pillbar,
        .mf-oq-surface.is-inline .mf-subs-toolbar { overflow-x: auto; }
        .mf-oq-surface.is-inline .mf-subs-card-hd { flex-wrap: wrap; }
        /* My Inbox 3-pane needs an explicit height to lay out its columns inline */
        .mf-oq-surface.is-inline .mf-mi3-shell { height: auto; }
        .mf-oq-surface.is-inline .mf-mi3-panes { height: 78vh !important; min-height: 520px; border-radius: 12px; border: 1px solid #e2e8f0; }
        /* Languages admin: drop its full-viewport min-height when inline */
        .mf-oq-surface.is-inline .mf-loc-shell { min-height: 0 !important; }
        /* Dashboard / Submissions roots: let content drive height, bounded + scroll */
        .mf-oq-surface.is-inline #mf-dash-root,
        .mf-oq-surface.is-inline .mf-subs-shell { min-height: 0 !important; }
        /* Form Builder + Theme Designer inline: the loader skips its full-screen takeover
           (data-fullscreen-host="false") so #mf-builder-root renders IN the module pane. Its
           internal panes are sized calc(100vh - topbar), so let the shell take its natural
           height in flow (page scrolls below the host header); the Fullscreen toggle zooms it to
           a true full-screen overlay. Neutralise any residual fixed positioning. */
        .mf-oq-surface.is-inline #mf-builder-root {
            position: relative !important; inset: auto !important; z-index: auto !important;
            width: 100% !important; max-height: none !important;
            border-radius: 12px; border: 1px solid #e2e8f0; overflow: hidden; }
        .mf-oq-surface.is-inline > iframe { height: 78vh !important; min-height: 520px; border-radius: 12px; border: 1px solid #e2e8f0; }
    </style>
    @* [EditMode fix 2026-06-12] Hide the Oqtane module title chrome for a clean MegaForm look
       â€” but NOT in edit mode, where the admin needs the module ACTION MENU to move/configure
       the module (e.g. drop it into a full-width pane). Hiding it unconditionally removed the
       action menu in edit mode so the module could not be re-paned. *@
    @if (!(PageState?.EditMode ?? false))
    {
        <style>.app-moduletitle, .app-module-title, .module-title { display: none !important; }</style>
    }
    @* [admin dock 2026-06-13; removed-from-panels 2026-06-22] The admin dock is intentionally
       NOT rendered above panel surfaces. Every ?mfpanel= surface already ships its own full
       navigation — Dashboard/Submissions/My Inbox/Languages render the MegaForm sidebar (which
       lists Form Builder / Form Management / Submissions / Settings / Languages), and the Builder
       has its own return-to-dashboard toolbar. The dock here was therefore a redundant strip of
       "Settings / Form Builder / Form Dashboard" buttons floating above the panel — the bug the
       user flagged on Form Dashboard. (Note: it is NOT gated on IsEditMode because the host's
       edit-mode preference persists across sessions, so an edit-mode gate would not reliably hide
       it.) The dock still renders for the normal form/module view (panelMode==None) below, and
       edit-mode module configuration stays available via the Oqtane action menu — kept visible in
       edit mode above — plus each surface's own navigation. *@
    @* Settings panel host kept (renders only when _showSettingsPanel is set, which now happens
       solely from the form-view dock); harmless/empty on panel surfaces. *@
    @RenderSettingsPanel
}


@if (ShouldShowAdminDock)
{
    <style>
        .mf-oq-admin-dock{position:relative;z-index:1020;display:flex;gap:8px;align-items:center;justify-content:flex-end;margin:0 0 12px;flex-wrap:wrap;font-family:'Inter',system-ui,sans-serif;}
        .mf-oq-settings-inline-host{position:relative;z-index:1019;}
        .mf-oq-settings-inline-host:not(:empty){margin:0 0 14px;font-family:'Inter',system-ui,sans-serif;}
        .mf-oq-pill,.mf-oq-btn,.mf-oq-linkbtn{border:1px solid #dbe4f0;background:#fff;color:#0f172a;border-radius:999px;padding:8px 14px;font-size:13px;font-weight:600;line-height:1;text-decoration:none;display:inline-flex;align-items:center;gap:8px;box-shadow:0 8px 20px rgba(15,23,42,.06);cursor:pointer;}
        .mf-oq-pill{background:linear-gradient(180deg,#eff6ff 0%,#ffffff 100%);color:#2563eb;border-color:#bfdbfe;}
        .mf-oq-btn.is-primary,.mf-oq-linkbtn.is-primary{background:#0f172a;color:#fff;border-color:#0f172a;}
        .mf-oq-panel{margin:0 0 14px;padding:18px;border:1px solid #dbe4f0;border-radius:20px;background:#fff;box-shadow:0 14px 40px rgba(15,23,42,.05);font-family:'Inter',system-ui,sans-serif;}
        .mf-oq-panel h3{margin:0 0 8px;font-size:16px;font-weight:700;color:#0f172a;display:flex;align-items:center;gap:10px;}
        .mf-oq-panel .mf-oq-help{color:#475569;font-size:13px;line-height:1.6;margin:0 0 14px;}
        .mf-oq-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;}
        .mf-oq-card{border:1px solid #dbe4f0;border-radius:18px;background:#f8fafc;padding:16px;}
        .mf-oq-card-title{font-size:12px;color:#64748b;text-transform:uppercase;letter-spacing:.04em;margin:0 0 6px;}
        .mf-oq-card-value{font-size:18px;font-weight:700;color:#0f172a;margin:0 0 4px;}
        .mf-oq-card-meta{font-size:13px;color:#475569;line-height:1.5;}
        .mf-oq-formgrid{display:grid;grid-template-columns:220px minmax(0,1fr);gap:12px 16px;align-items:center;margin-top:12px;}
        .mf-oq-formgrid label{font-size:13px;font-weight:600;color:#0f172a;}
        .mf-oq-formgrid select,.mf-oq-formgrid input[type='text'],.mf-oq-formgrid input[type='number']{width:100%;border:1px solid #cbd5e1;border-radius:12px;padding:10px 12px;font-size:14px;background:#fff;}
        .mf-oq-inline-check{display:flex;align-items:center;gap:10px;font-size:14px;color:#0f172a;}
        .mf-oq-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px;}
        .mf-oq-acc{display:flex;flex-direction:column;gap:10px;margin-top:8px;}
        .mf-oq-acc-item{border:1px solid #e2e8f0;border-radius:14px;background:#fff;overflow:hidden;}
        .mf-oq-acc-hd{display:flex;align-items:center;gap:10px;width:100%;border:0;background:#f8fafc;padding:13px 16px;font-size:14px;font-weight:700;color:#0f172a;cursor:pointer;text-align:left;}
        .mf-oq-acc-hd:hover{background:#f1f5f9;}
        .mf-oq-acc-hd .mf-oq-acc-ic{width:26px;height:26px;border-radius:8px;display:inline-flex;align-items:center;justify-content:center;background:#e0e7ff;color:#4f46e5;font-size:12px;}
        .mf-oq-acc-hd .mf-oq-acc-chev{margin-left:auto;color:#94a3b8;transition:transform .15s ease;}
        .mf-oq-acc-item.is-open .mf-oq-acc-chev{transform:rotate(90deg);}
        .mf-oq-acc-sub{font-weight:500;color:#94a3b8;font-size:12px;}
        .mf-oq-acc-bd{padding:14px 16px;border-top:1px solid #eef2f7;}
        .mf-oq-rolebadge{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:999px;font-size:12px;font-weight:700;background:#ecfeff;color:#0e7490;border:1px solid #a5f3fc;text-transform:capitalize;}
        .mf-oq-snip{margin:12px 0 0;}
        .mf-oq-snip h5{margin:0 0 4px;font-size:12.5px;font-weight:700;color:#0f172a;}
        .mf-oq-snip p{margin:0 0 6px;font-size:12px;color:#64748b;line-height:1.5;}
        .mf-oq-snip pre{margin:0 0 12px;padding:11px 13px;border-radius:10px;background:#0f172a;color:#e2e8f0;font-size:12px;line-height:1.55;overflow:auto;white-space:pre-wrap;word-break:break-word;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;}
        .mf-oq-note{margin-top:16px;padding:12px 14px;border-radius:14px;background:#eef6ff;color:#1d4ed8;font-size:13px;line-height:1.6;}
        .mf-oq-list{margin:14px 0 0;padding:0;list-style:none;display:grid;gap:10px;}
        .mf-oq-list li{display:flex;justify-content:space-between;gap:12px;align-items:center;padding:12px 14px;border:1px solid #e2e8f0;border-radius:14px;background:#fff;}
        .mf-oq-list-main{min-width:0;}
        .mf-oq-list-title{font-size:14px;font-weight:600;color:#0f172a;margin:0 0 2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
        .mf-oq-list-meta{font-size:12px;color:#64748b;}
        .mf-oq-status{display:inline-flex;align-items:center;border-radius:999px;padding:4px 10px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;}
        .mf-oq-status.is-published{background:#dcfce7;color:#166534;}
        .mf-oq-status.is-draft{background:#fef3c7;color:#92400e;}
        .mf-oq-saved{margin:0 0 12px;padding:10px 12px;border-radius:12px;background:#ecfdf5;color:#166534;font-size:13px;font-weight:600;}
        @@media (max-width: 900px){.mf-oq-grid{grid-template-columns:1fr;}.mf-oq-formgrid{grid-template-columns:1fr;}}
    </style>
}


@if (_panelMode == MfPanelMode.Dashboard)
{
    <style>
        html.mf-oq-dashboard-active, body.mf-oq-dashboard-active { overflow: hidden !important; }
    </style>
    <div class="mf-oq-surface @(IsPanelInline ? "is-inline" : "is-fs")">
        <DashboardView ModuleId="@(ModuleState?.ModuleId ?? 0)" PageId="@(PageState?.Page?.PageId ?? 0)" SiteId="@(SiteState?.Alias?.SiteId ?? 0)" AuthToken="@(SiteState?.AuthorizationToken ?? string.Empty)" IsAdmin="_isAdmin" Inline="IsPanelInline" RoleDriven="_panelRoleDriven" />
    </div>
}
else if (_panelMode == MfPanelMode.Builder)
{
    <div class="mf-oq-surface @(IsPanelInline ? "is-inline" : "is-fs")">
        <BuilderView ModuleId="@(ModuleState?.ModuleId ?? 0)" PageId="@(PageState?.Page?.PageId ?? 0)" SiteId="@(SiteState?.Alias?.SiteId ?? 0)" AuthToken="@(SiteState?.AuthorizationToken ?? string.Empty)" IsAdmin="_isAdmin" ConfiguredFormId="_formId" Inline="IsPanelInline" />
    </div>
}
else if (_panelMode == MfPanelMode.Submissions)
{
    <div class="mf-oq-surface @(IsPanelInline ? "is-inline" : "is-fs")">
        <SubmissionsView ModuleId="@(ModuleState?.ModuleId ?? 0)" SiteId="@(SiteState?.Alias?.SiteId ?? 0)" />
    </div>
}
else if (_panelMode == MfPanelMode.Portal)
{
    @* [B86] End-user Portal surface â€” "My Records". Renders the standalone
       portal.html (same-origin, so the auth cookie flows); the server applies
       row-level security so each signed-in user sees only their own records. *@
    <div class="mf-oq-surface @(IsPanelInline ? "is-inline" : "is-fs")">
        <iframe src="@($"/Modules/MegaForm/portal.html?formId={_formId}")"
                style="width:100%;height:100%;border:0;display:block;" title="My Records"></iframe>
    </div>
}
else if (_panelMode == MfPanelMode.MyInbox)
{
    @* [MyInbox v20260610-B120] Personal project-manager workboard. The
       megaform-my-inbox.js bundle self-mounts #mf-myinbox-root and reads the
       MegaForm API base from data-api-base, then calls GET /Workflow/MyInbox. *@
    <div class="mf-oq-surface @(IsPanelInline ? "is-inline" : "is-fs")">
        <div id="mf-myinbox-root"
             data-platform="oqtane"
             data-api-base="/api/MegaForm/"
             data-submissions-api-base="/api/MegaForm/"
             data-mf-locale="@_culture"
             data-module-id="@(ModuleState?.ModuleId ?? 0)"></div>
    </div>
}
else if (_panelMode == MfPanelMode.Languages)
{
    @* [Languages v20260610-01] Language pack admin. The megaform-languages.js
       bundle self-mounts #mf-languages-root and reads the MegaForm API base
       from data-api-base.
       [Admin-gate 2026-06-11] ?mfpanel=languages edits site-wide translation
       packs â†’ restrict to module-edit (Admin/Host) users only. Non-admins get a
       Forbidden card instead of the editor. *@
    @if (_isAdmin)
    {
        <div class="mf-oq-surface @(IsPanelInline ? "is-inline" : "is-fs")">
            <div id="mf-languages-root"
                 data-platform="oqtane"
                 data-api-base="/api/MegaForm/"
                 data-mf-locale="@_culture"
                 data-admin-locale="en-US"></div>
        </div>
    }
    else
    {
        <div style="position:fixed;inset:0;z-index:10000;background:#f8fafc;overflow:auto;display:flex;align-items:center;justify-content:center;font-family:'Inter',system-ui,sans-serif;">
            <div style="max-width:460px;text-align:center;padding:32px;border:1px solid #e2e8f0;border-radius:20px;background:#fff;box-shadow:0 12px 30px rgba(15,23,42,.06);">
                <div style="font-size:34px;margin-bottom:10px;">ðŸ”’</div>
                <h2 style="margin:0 0 8px;font-size:20px;font-weight:800;color:#0f172a;">Administrators only</h2>
                <p style="margin:0 0 18px;color:#475569;font-size:14px;line-height:1.6;">The Language Manager edits site-wide translation packs and is restricted to administrators and the host.</p>
                <a href="/" style="display:inline-flex;align-items:center;gap:6px;border:1px solid #cbd5e1;background:#0f172a;color:#fff;padding:9px 16px;border-radius:10px;font-size:13px;font-weight:700;text-decoration:none;">â† Back to site</a>
            </div>
        </div>
    }
}
else if (_panelMode == MfPanelMode.SdkDemo)
{
    @* [SDK demo v20260616] ?mfpanel=sdkdemo — read-only consumer surface proving any
       module can read MegaForm data (forms, submissions, files) through ONLY the public
       IMegaFormClient facade. Download links hit /api/MegaForm/SdkDemo/Download which
       streams via the SDK Files API. Reads private submissions → admin/host only. *@
    @if (_isAdmin)
    {
        <div class="mf-oq-surface @(IsPanelInline ? "is-inline" : "is-fs")">
            <SdkDemoView PortalId="@(SiteState?.Alias?.SiteId ?? 0)" />
        </div>
    }
    else
    {
        <div style="position:fixed;inset:0;z-index:10000;background:#f8fafc;overflow:auto;display:flex;align-items:center;justify-content:center;font-family:'Inter',system-ui,sans-serif;">
            <div style="max-width:460px;text-align:center;padding:32px;border:1px solid #e2e8f0;border-radius:20px;background:#fff;box-shadow:0 12px 30px rgba(15,23,42,.06);">
                <div style="font-size:34px;margin-bottom:10px;">🔒</div>
                <h2 style="margin:0 0 8px;font-size:20px;font-weight:800;color:#0f172a;">Administrators only</h2>
                <p style="margin:0 0 18px;color:#475569;font-size:14px;line-height:1.6;">The SDK demo reads submission data and is restricted to administrators and the host.</p>
                <a href="/" style="display:inline-flex;align-items:center;gap:6px;border:1px solid #cbd5e1;background:#0f172a;color:#fff;padding:9px 16px;border-radius:10px;font-size:13px;font-weight:700;text-decoration:none;">← Back to site</a>
            </div>
        </div>
    }
}
else
{
    @if (ShouldShowAdminDock)
    {
        @RenderAdminDock
    }
    @RenderSettingsPanel

    @if (!string.IsNullOrWhiteSpace(_saveMessage))
    {
        <div class="mf-oq-saved">@_saveMessage</div>
    }

}

@if (IsStaticRender && _panelMode != MfPanelMode.None)
{
    <script data-mf-static-surface-boot="@_panelMode">
        @((MarkupString)BuildSurfaceBootScript())
    </script>
}


