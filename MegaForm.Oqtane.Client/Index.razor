        };
    }

private static string BuildWorkflowNodeNote(WorkflowNode node, List<string> roles, List<string> users)
{
    if (node == null)
    {
        return string.Empty;
        }

    if (node.Type == WorkflowNodeType.Approval)
    {
        return roles.Count == 0 && users.Count == 0
            ? "This BPMN user task has no candidate role or user yet."
            : "This BPMN user task can be claimed by the listed roles or directly assigned users.";
    }

    return node.Type switch
    {
        WorkflowNodeType.End => "BPMN end event for this business process.",
        WorkflowNodeType.Condition or WorkflowNodeType.Switch or WorkflowNodeType.Fork or WorkflowNodeType.Join => "Gateway routing is controlled by the outgoing sequence flows from this node.",
        WorkflowNodeType.SendEmail or WorkflowNodeType.Webhook or WorkflowNodeType.Database or WorkflowNodeType.GoogleSheets or WorkflowNodeType.SetVariable or WorkflowNodeType.AddRole or WorkflowNodeType.AddUser or WorkflowNodeType.AddUserToRole or WorkflowNodeType.Calculate => "Automated service task executed by the platform runtime.",
        WorkflowNodeType.Delay => "Timer event that pauses the process until its configured duration completes.",
        _ => string.Empty
    };
}

private static string ResolveWorkflowLaneLabel(WorkflowNode node, List<string> roles, List<string> users, string startNodeId)
{
    if (node == null)
    {
        return "System Automation";
    }

    if (!string.IsNullOrWhiteSpace(startNodeId) &&
        string.Equals(node.Id, startNodeId, StringComparison.OrdinalIgnoreCase))
    {
        return "Submitter";
    }

    if (node.Type == WorkflowNodeType.FormField)
    {
        return "Submitter";
    }

    if (users != null && users.Count > 0)
    {
        return "User: " + users[0];
    }

    if (roles != null && roles.Count > 0)
    {
        return "Role: " + roles[0];
    }

    return node.Type switch
    {
        WorkflowNodeType.End => "End Events",
        WorkflowNodeType.Condition or WorkflowNodeType.Switch or WorkflowNodeType.Fork or WorkflowNodeType.Join => "Decision Gateways",
        WorkflowNodeType.Approval => "Approvals",
        _ => "System Automation"
    };
}

