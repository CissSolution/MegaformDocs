    private string BuildSettingsInlineOpenScript()
    {
        var payload = JsonSerializer.Serialize(new
        {
            moduleId = ModuleState?.ModuleId ?? 0,
            siteId = GetCurrentSiteId(),
            currentPageId = PageState?.Page?.PageId ?? 0,
            currentPageUrl = GetCurrentPageRendererHostUrl(),
            inline = true,
            inlineHostId = SettingsInlineHostId
        });
        var version = (OqtaneCoreAssetVersion ?? string.Empty).Replace("'", "\\'");
        return "(function(opts){"
            + "function prep(){var host=opts.inlineHostId?document.getElementById(opts.inlineHostId):null;if(!host)return null;"
            + "var surface=null;try{surface=(host.parentElement&&host.parentElement.querySelector('.mf-oq-surface.is-fs'))||document.querySelector('.mf-oq-surface.is-fs');}catch(e){}"
