    var profile = GetStarterQaProfile();
    var recommendedBoard = profile?.SurfaceLinks?.FirstOrDefault(link => link.IsRecommended)?.Url;
    if (!string.IsNullOrWhiteSpace(recommendedBoard))
    {
        return recommendedBoard;
    }

    if (IsListViewMode)
    {
        return BuildCurrentModuleUrl("view", "listview");
    }

    if (IsListMode)
    {
        return BuildCurrentModuleUrl("view", "list");
    }

    if (IsCardMode)
    {
        return BuildCurrentModuleUrl("view", "card");
    }

    return BuildCurrentModuleUrl("view", "form");
}

    // [2026-06-13 SSR] Deserialize the resolved schema and render the static form body
    // server-side (FormHtmlRenderer, shared Core). Runs during Blazor prerender so the
    // markup is in the initial HTTP response = crawlable. Non-fatal on any error.
    private void TryBuildSsrFormHtml(string schemaJson)
    {
        _ssrFieldsHtml = string.Empty;
        _ssrCustomCss = string.Empty;
        _ssrWrapperRuntimeClasses = string.Empty;
        _ssrWrapperClass = "mf-form-wrapper";
        try
        {
            if (string.IsNullOrWhiteSpace(schemaJson)) return;
            var schema = Newtonsoft.Json.JsonConvert.DeserializeObject<FormSchema>(schemaJson);
            if (schema == null) return;
            // [C v20260621] Render the SSR body for ALL published forms incl custom-HTML, multi-page
            // and hydration-widget forms (RenderFieldsBody → RenderCustomHtml token-substitutes the
            // author layout; the iframe render-page used this for every form). This is the INSTANT
            // first paint; the JS renderer then rebuilds from schema in one tick (the hasCustom path)
            // — so an SSR body that the renderer would rebuild anyway is still correct. Was gated to
            // IsSsrEligible only (standard hydrate); the gate is removed now that we render in-place.
            _ssrHasCustom = !string.IsNullOrWhiteSpace(schema.Settings?.CustomHtml);
            // [SingleSource v20260624-B260] Compose the form's FULL CSS into ONE block via the
            // shared ModuleCssComposer: [preset (_initialInlineCss), scoped theme vars, authored
            // customCss, custom-shell compat] in the SAME source order the two old blocks had
            // (mf-inline-preset then mf-custom-css), so cascade resolution is unchanged. This folds
            // the former separate mf-inline-preset block into mf-custom-css and WIDENS the
            // custom-shell predicate (customHtml || .mfp-in-customCss) so premium forms keep their
            // var bridge when the public renderer is neutralised (it early-returns on data-mf-ssr=1).
            var authoredCustomCss = schema.Settings?.CustomCss ?? string.Empty;
            try
            {
                var schemaObj = Newtonsoft.Json.Linq.JObject.Parse(schemaJson);
                var settingsObj = schemaObj["settings"] as Newtonsoft.Json.Linq.JObject
                                  ?? schemaObj["Settings"] as Newtonsoft.Json.Linq.JObject;
                // [ModuleStyle v20260624-B262] If THIS module owns a CSS for the current form
                // (MegaForm:ModuleStyleJson + matching MegaForm:ModuleStyleFormId), overlay its
                // style fields onto the form's — "module setting wins". Additive: no module style
                // (or bound to a different form) → form settings used unchanged.
                if (settingsObj != null) OverlayModuleStyle(settingsObj, _formId);
                _ssrWrapperRuntimeClasses = settingsObj != null
                    ? MegaForm.Core.Services.ThemeFirstPaintCssService.BuildWrapperRuntimeClasses(settingsObj)
                    : string.Empty;
                _ssrCustomCss = MegaForm.Core.Services.ModuleCssComposer.Compose(_formId, settingsObj, _initialInlineCss, null);
            }
            catch
            {
                // non-fatal: first paint falls back to authored customCss (+ compat for custom-HTML).
                _ssrCustomCss = _ssrHasCustom
                    ? CustomShellCompatibilityCssService.AppendTo(authoredCustomCss, "#mf-form-wrapper-" + _formId)
                    : authoredCustomCss;
            }

            var baseWrapperClass = "mf-form-wrapper" + (_ssrHasCustom ? " mf-custom-shell-mode" : string.Empty);
            _ssrWrapperClass = string.IsNullOrEmpty(_ssrWrapperRuntimeClasses)
                ? baseWrapperClass
                : baseWrapperClass + " " + _ssrWrapperRuntimeClasses;

            _ssrFieldsHtml = MegaForm.Core.Services.FormHtmlRenderer.RenderFieldsBody(schema, _formId, null);
        }
        catch { _ssrFieldsHtml = string.Empty; }
    }

    // [ModuleStyle v20260624-B262] Overlay the module's owned CSS for the current form onto the
    // form's settings (module-setting-wins). Reads MegaForm:ModuleStyleJson + the
    // MegaForm:ModuleStyleFormId guard from ModuleState.Settings (available at SSR). No-op when
    // this module has not seeded a style, or its seeded style is for a DIFFERENT form (so binding
    // a new form to the module falls back to the new form's CSS until reseeded).
    private void OverlayModuleStyle(Newtonsoft.Json.Linq.JObject settingsObj, int formId)
    {
        try
        {
            if (ModuleState?.Settings == null || formId <= 0) return;
            if (!ModuleState.Settings.TryGetValue("MegaForm:ModuleStyleFormId", out var msFid)
                || !int.TryParse(msFid, out var msFidInt) || msFidInt != formId) return;
            if (!ModuleState.Settings.TryGetValue("MegaForm:ModuleStyleJson", out var msJson)
                || string.IsNullOrWhiteSpace(msJson)) return;
            var ms = Newtonsoft.Json.Linq.JObject.Parse(msJson);
            foreach (var key in new[] { "theme", "themeCssOverrides", "customCss", "cssOverrides" })
            {
                var tok = ms[key] ?? ms[char.ToUpperInvariant(key[0]) + key.Substring(1)];
                if (tok != null) settingsObj[key] = tok;
            }
        }
        catch { /* non-fatal: fall back to the form's settings */ }
    }

    // [2026-06-18 SchemaPreload] Build a SchemaResponse-shaped JSON blob from the form DTO
    // we already fetched in OnParametersSetAsync. Embedded as <script type="application/json">
    // so the browser has the schema before the Blazor interactive circuit finishes connecting.
    private string BuildPreloadSchemaJson()
    {
        if (_preloadedForm == null || _preloadedForm.FormId <= 0) return "{}";
        try
        {
            var schemaJson = !string.IsNullOrWhiteSpace(_preloadedForm.ResolvedSchemaJson)
                ? _preloadedForm.ResolvedSchemaJson
                : _preloadedForm.SchemaJson;
            var settingsJson = !string.IsNullOrWhiteSpace(_preloadedForm.ResolvedSettingsJson)
                ? _preloadedForm.ResolvedSettingsJson
                : _preloadedForm.SettingsJson;

            var response = new SchemaResponse
            {
                FormId = _preloadedForm.FormId,
                Title = _preloadedForm.Title,
                Description = _preloadedForm.Description,
                Schema = schemaJson,
                SubmitButtonText = _preloadedForm.SubmitButtonText,
                EnableCaptcha = _preloadedForm.EnableCaptcha,
                EnableSaveResume = _preloadedForm.EnableSaveResume,
                ThemeJson = _preloadedForm.ThemeJson,
                SettingsJson = settingsJson,
                InitialInlineCss = _preloadedForm.InitialInlineCss,
                RequireAuth = _preloadedForm.RequireAuth,
                AssetSelectionBadge = _preloadedForm.AssetSelectionBadge,
                PluginScripts = _preloadedForm.PluginScripts ?? new System.Collections.Generic.List<string>(),
                PluginStyles = _preloadedForm.PluginStyles ?? new System.Collections.Generic.List<string>()
            };
            return System.Text.Json.JsonSerializer.Serialize(response);
        }
        catch
        {
            return "{}";
        }
    }

    private void LoadWorkflowPreview(string workflowJson)
    {
        _workflowPreview = WorkflowPreviewModel.Empty();
        if (string.IsNullOrWhiteSpace(workflowJson))
        {
            return;
        }

        try
        {
            var envelope = WorkflowEnvelope.ParseOrMigrate(workflowJson);
            var definition = envelope?.AppliedWorkflow ?? envelope?.DraftWorkflow;
            if (definition == null || definition.Nodes == null || definition.Nodes.Count == 0)
            {
                return;
            }

        var previewNodes = new List<WorkflowPreviewNode>();
        var laneSequence = new List<string>();
        var maxRight = 0d;
        var maxBottom = 0d;

        for (var i = 0; i < definition.Nodes.Count; i++)
        {
            var node = definition.Nodes[i];
            var left = (node?.Position?.X ?? 0d) + 64d;
            if (left <= 64d)
            {
                left = 84d + (i * 250d);
            }

            var roles = GetWorkflowConfigValues(node?.Config, "candidateRoles", "CandidateRoles");
            var users = GetWorkflowConfigValues(node?.Config, "candidateUsers", "CandidateUsers");
            var laneLabel = ResolveWorkflowLaneLabel(node, roles, users, definition.StartNodeId);
            var laneIndex = laneSequence.FindIndex(l => string.Equals(l, laneLabel, StringComparison.OrdinalIgnoreCase));
            if (laneIndex < 0)
            {
                laneSequence.Add(laneLabel);
                laneIndex = laneSequence.Count - 1;
            }

            var laneTop = 40d + (laneIndex * 224d);
            var top = laneTop + 54d;

            maxRight = Math.Max(maxRight, left + 260d);
            maxBottom = Math.Max(maxBottom, top + 200d);

            var statuses = new List<string>();
            AddWorkflowConfigStatus(statuses, node?.Config, "pendingSubmissionStatus", "PendingSubmissionStatus");
            AddWorkflowConfigStatus(statuses, node?.Config, "approvedSubmissionStatus", "ApprovedSubmissionStatus");
            AddWorkflowConfigStatus(statuses, node?.Config, "rejectedSubmissionStatus", "RejectedSubmissionStatus");

                previewNodes.Add(new WorkflowPreviewNode
                {
                Id = node?.Id ?? ("node-" + i),
                Label = string.IsNullOrWhiteSpace(node?.Label) ? ("Step " + (i + 1)) : node.Label,
                TypeLabel = GetWorkflowNodeTypeLabel(node?.Type ?? WorkflowNodeType.FormField),
                ZoneLabel = laneLabel,
                CssClass = GetWorkflowNodeCssClass(node?.Type ?? WorkflowNodeType.FormField),
                Left = left,
                Top = top,
                    CenterX = left + 110d,
                    CenterY = top + 90d,
                    MetaText = string.IsNullOrWhiteSpace(node?.Id) ? "Runtime step" : ("Node: " + node.Id),
                    RoleAssignments = roles,
                    UserAssignments = users,
                    StatusHints = statuses,
                    Note = BuildWorkflowNodeNote(node, roles, users)
                });
            }

            var nodeLookup = previewNodes.ToDictionary(n => n.Id, n => n, StringComparer.OrdinalIgnoreCase);
            var previewEdges = new List<WorkflowPreviewEdge>();
            foreach (var edge in definition.Edges ?? Enumerable.Empty<WorkflowEdge>())
            {
                if (edge == null ||
                    string.IsNullOrWhiteSpace(edge.SourceNodeId) ||
                    string.IsNullOrWhiteSpace(edge.TargetNodeId) ||
                    !nodeLookup.TryGetValue(edge.SourceNodeId, out var sourceNode) ||
                    !nodeLookup.TryGetValue(edge.TargetNodeId, out var targetNode))
                {
                    continue;
                }

                var x1 = sourceNode.CenterX + 104d;
                var y1 = sourceNode.CenterY;
                var x2 = targetNode.CenterX - 104d;
                var y2 = targetNode.CenterY;
                previewEdges.Add(new WorkflowPreviewEdge
                {
                    SourceId = sourceNode.Id,
                    TargetId = targetNode.Id,
                    Label = edge.Label ?? string.Empty,
                    X1 = x1,
                    Y1 = y1,
                    X2 = x2,
                    Y2 = y2,
                    LabelX = (x1 + x2) / 2d,
                    LabelY = (y1 + y2) / 2d,
                    Color = string.Equals(edge.SourceHandle, "rejected", StringComparison.OrdinalIgnoreCase) ? "#f97316" : "#94a3b8"
                });
            }

        var lanes = new List<WorkflowPreviewLane>();
        for (var laneIndex = 0; laneIndex < laneSequence.Count; laneIndex++)
        {
            var laneLabel = laneSequence[laneIndex];
            lanes.Add(new WorkflowPreviewLane
            {
                Label = laneLabel,
                Top = 40d + (laneIndex * 224d),
                Height = 188d
            });
        }

        if (lanes.Count == 0)
        {
            lanes.Add(new WorkflowPreviewLane { Label = "BPMN 2.0 Process", Top = 40d, Height = Math.Max(320d, maxBottom) });
        }

            var startNode = previewNodes.FirstOrDefault(n => string.Equals(n.Id, definition.StartNodeId, StringComparison.OrdinalIgnoreCase))
                ?? previewNodes.FirstOrDefault();

            _workflowPreview = new WorkflowPreviewModel
            {
                Title = string.IsNullOrWhiteSpace(definition.Name) ? (GetSelectedFormTitle() + " Workflow") : definition.Name,
                VersionText = !string.IsNullOrWhiteSpace(envelope?.AppliedVersion) ? ("Applied " + envelope.AppliedVersion) : (!string.IsNullOrWhiteSpace(definition.Version) ? ("Version " + definition.Version) : string.Empty),
                Nodes = previewNodes,
                Edges = previewEdges,
                Lanes = lanes,
                CanvasWidth = Math.Max(1080d, maxRight + 120d),
                CanvasHeight = Math.Max(540d, Math.Max(maxBottom + 80d, lanes.Max(l => l.Top + l.Height) + 24d)),
                StartNodeLabel = startNode?.Label ?? "Unknown",
                TotalAssignments = previewNodes.Sum(n => n.RoleAssignments.Count + n.UserAssignments.Count)
            };
        }
        catch
        {
            _workflowPreview = WorkflowPreviewModel.Empty();
        }
    }

    private static List<string> GetWorkflowConfigValues(Dictionary<string, object> config, params string[] keys)
    {
        var values = new List<string>();
        if (config == null || keys == null || keys.Length == 0)
        {
            return values;
        }

        foreach (var key in keys)
        {
            var actualKey = config.Keys.FirstOrDefault(k => string.Equals(k, key, StringComparison.OrdinalIgnoreCase));
            if (string.IsNullOrWhiteSpace(actualKey) || !config.TryGetValue(actualKey, out var raw) || raw == null)
            {
                continue;
            }

            if (raw is string text)
            {
                foreach (var item in text.Split(new[] { ',', ';', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
                {
                    var trimmed = item.Trim();
                    if (!string.IsNullOrWhiteSpace(trimmed) && !values.Any(v => string.Equals(v, trimmed, StringComparison.OrdinalIgnoreCase)))
                    {
                        values.Add(trimmed);
                    }
                }
                continue;
            }

            if (raw is System.Collections.IEnumerable seq)
            {
                foreach (var item in seq)
                {
                    var textValue = Convert.ToString(item)?.Trim();
                    if (!string.IsNullOrWhiteSpace(textValue) && !values.Any(v => string.Equals(v, textValue, StringComparison.OrdinalIgnoreCase)))
                    {
                        values.Add(textValue);
                    }
                }
            }
        }

        return values;
    }

    private static void AddWorkflowConfigStatus(List<string> target, Dictionary<string, object> config, params string[] keys)
    {
        if (target == null || config == null)
        {
            return;
        }

        foreach (var key in keys ?? Array.Empty<string>())
        {
            var actualKey = config.Keys.FirstOrDefault(k => string.Equals(k, key, StringComparison.OrdinalIgnoreCase));
            if (string.IsNullOrWhiteSpace(actualKey) || !config.TryGetValue(actualKey, out var raw) || raw == null)
            {
                continue;
            }

            var value = Convert.ToString(raw)?.Trim();
            if (!string.IsNullOrWhiteSpace(value) && !target.Any(v => string.Equals(v, value, StringComparison.OrdinalIgnoreCase)))
            {
                target.Add(value);
            }
        }
    }

