    private string BuildPanelUrl(string panel)
    {
        var baseUrl = NavigationManager.Uri.Split('?')[0].Split('#')[0];
        var parts = new List<string>();
        var editValue = GetQueryValue(NavigationManager.Uri, "edit");
        if (!string.IsNullOrWhiteSpace(editValue))
            parts.Add("edit=" + Uri.EscapeDataString(editValue));
        parts.Add("mfpanel=" + Uri.EscapeDataString(panel));
        // [FormBuilderLoadsViewedForm 20260617] Carry the currently-viewed form id into
        // the builder / submissions panel so it opens THIS form instead of defaulting to
        // whatever the bundle last had. Only the form-scoped panels need it; the dashboard
        // is a form-list and languages is global.
        if (_formId > 0 && (panel == "builder" || panel == "submissions"))
            parts.Add("formId=" + _formId);
        return parts.Count == 0 ? baseUrl : baseUrl + "?" + string.Join("&", parts);
    }

    private string BuildSettingsUrl()
    {
        var uri = NavigationManager?.Uri ?? "/";
        var baseUrl = uri.Split('?')[0].Split('#')[0];
        var parts = new List<string>();
        var qIdx = uri.IndexOf('?');
        if (qIdx >= 0)
        {
            var query = uri.Substring(qIdx + 1).Split('#')[0];
            foreach (var part in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
            {
                var key = part.Split('=', 2)[0];
                if (key.Equals("mfconfig", StringComparison.OrdinalIgnoreCase)) continue;
                parts.Add(part);
            }
        }

        parts.Add("mfconfig=1");
        return parts.Count == 0 ? baseUrl : baseUrl + "?" + string.Join("&", parts);
    }

