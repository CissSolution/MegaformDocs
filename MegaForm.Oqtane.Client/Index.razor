    private async Task OpenViewDesigner()
    {
        if (_formId <= 0) return;
        var kind = IsListMode ? "list" : IsCardMode ? "card" : IsListViewMode ? "listview" : null;
        if (kind == null) return;

        // Ensure designer bundle is loaded, then open it
        try
        {
            await Js.InvokeVoidAsync("eval", $@"
(function(){{
  var moduleId = {ModuleState?.ModuleId ?? 0};
  var formId = {_formId};
  var kind = '{kind}';
  var baseUrl = '/Modules/MegaForm/js/';
  function loadScript(src){{
    return new Promise(function(resolve,reject){{
      if(document.querySelector('script[src=""' + src + '""]')){{ resolve(); return; }}
      var s = document.createElement('script');
      s.src = src; s.async = true;
      s.onload = resolve; s.onerror = function(){{ reject(new Error('Failed to load ' + src)); }};
      document.head.appendChild(s);
    }});
  }}
  function openDesigner(){{
    if(kind === 'listview'){{
      if(window.MFListView && window.MFListView.openDesigner){{
        window.MFListView.openDesigner({{ apiBase: '/api/MegaForm/', moduleId: moduleId, formId: formId, initial: {{ formId: formId }}, onSave: function(s){{ console.log('ListView saved', s); }} }});
      }} else {{ alert('ListView designer not available.'); }}
    }} else if(kind === 'list'){{
      if(window.MFListDesigner){{
        window.MFListDesigner.open({{ moduleId: moduleId, formId: formId, fields: [], current: {{}}, onSaved: function(){{ location.reload(); }} }});
      }} else {{ alert('List designer not available.'); }}
    }} else if(kind === 'card'){{
      if(window.MFCardDesigner){{
        window.MFCardDesigner.open({{ moduleId: moduleId, formId: formId, fields: [], current: {{}}, onSaved: function(){{ location.reload(); }} }});
      }} else {{ alert('Card designer not available.'); }}
    }}
  }}
  if(kind === 'listview'){{
    openDesigner();
  }} else {{
    var file = kind === 'list' ? 'megaform-view-designer-list.js' : 'megaform-view-designer-card.js';
    loadScript(baseUrl + file).then(openDesigner).catch(function(e){{ alert(e.message); }});
  }}
}})();
");
        }
        catch (Exception ex)
        {
            _saveMessage = "Designer failed to open: " + ex.Message;
            StateHasChanged();
        }
    }

