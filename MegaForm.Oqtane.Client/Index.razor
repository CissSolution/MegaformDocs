        _liveRenderMode = false;
        _embedMode = false;
        _fastEmbed = false;  // [No-iframe v20260620-B216] DEFAULT OFF (per user 2026-06-20): render the form IN-PLACE (light DOM), NOT via an <iframe>. The FastEmbed iframe caused an intermittent DOUBLE render: Oqtane Interactive recreates the @key'd <iframe> on the hydration pass → /api/MegaForm/render/{id} is fetched TWICE on warm loads (confirmed via Network: 2 requests ↔ 2 "rendering N fields" logs). In-place renders exactly ONCE (verified: render/{id}=0, Schema/{id}=1, 1 render log, form paints in host DOM, visually correct). Re-enable the iframe per-module with MegaForm:FastEmbed=true or per-request with ?mffast=1.
        _moduleConfigured = false;
        _rendererHostUrl = string.Empty;
        _rendererHostPageId = 0;
        _rendererHostModuleId = 0;
        _moduleViewConfigJson = "{}";
        _saveMessage = string.Empty;
        _activeViewKey = string.Empty;
        _workflowPreview = WorkflowPreviewModel.Empty();

        var currentUri = NavigationManager.Uri ?? string.Empty;
        var requested = GetQueryValue(currentUri, "formid") ?? GetQueryValue(currentUri, "FormId");
        if (!string.IsNullOrWhiteSpace(requested))
        {
            var raw = requested;
            if (!int.TryParse(raw, out _formId))
            {
                var digits = new string(raw.Where(char.IsDigit).ToArray());
                int.TryParse(digits, out _formId);
            }
            _liveRenderMode = _formId > 0;
        }

        var embedRaw = GetQueryValue(currentUri, "embed");
        if (!string.IsNullOrWhiteSpace(embedRaw))
        {
            _embedMode = embedRaw == "1" || string.Equals(embedRaw, "true", StringComparison.OrdinalIgnoreCase) || string.Equals(embedRaw, "yes", StringComparison.OrdinalIgnoreCase);
        }

        // [FastEmbed v20260620-B210] ?mffast=0/1 is an explicit per-request override (wins over the
        // per-module setting). Default is ON; the per-module setting (read below) can also disable it.
        // [B217] Reset to the default (ON) at the start of each parse so the choice is deterministic:
        // a one-off ?mffast=0 must not stay "sticky" on a later re-render that has no query/setting.
        // The recreate double-load that made B216 turn this OFF is fixed (iframe is now JS-injected,
        // outside Blazor's render tree — see BuildFastEmbedBootScript), so the iframe is the default
        // again: instant server-rendered first paint, separate document = no Blazor circuit conflict.
        _fastEmbed = true;
        var fastRaw = GetQueryValue(currentUri, "mffast");
        var fastQueryExplicit = !string.IsNullOrWhiteSpace(fastRaw);
        if (fastQueryExplicit)
        {
            _fastEmbed = fastRaw == "1" || string.Equals(fastRaw, "true", StringComparison.OrdinalIgnoreCase) || string.Equals(fastRaw, "yes", StringComparison.OrdinalIgnoreCase);
        }

        var panelRaw = GetQueryValue(currentUri, "mfpanel");
        _panelMode = (panelRaw ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "dashboard" => MfPanelMode.Dashboard,
            "builder" => MfPanelMode.Builder,
            "submissions" => MfPanelMode.Submissions,
            "portal" => MfPanelMode.Portal,
            "myinbox" => MfPanelMode.MyInbox,
            "languages" => MfPanelMode.Languages,
            "sdkdemo" => MfPanelMode.SdkDemo,
            _ => MfPanelMode.None
        };
        // [Inline default 2026-06-12] Per user request, MegaForm panel surfaces render INLINE
        // (embedded in the module pane, theme-isolated via the .is-inline reset) by default,
        // with a client-side Fullscreen toggle button (platform-host installFullscreenToggle)
        // to zoom any surface to a full-screen overlay on demand. ?mfinline=0 forces
        // full-screen (QA / per-surface fallback).
        _panelInline = !string.Equals(GetQueryValue(currentUri, "mfinline"), "0", StringComparison.OrdinalIgnoreCase);
        // [CloseTrap fix 2026-06-11] Track whether the panel is driven by a pinned ModuleRole
        // (vs an explicit ?mfpanel= admin nav). On a role-pinned page the surface IS the page,
        // so the surface's "Close" must escape to the Oqtane home (/) instead of reloading the
        // same page (which would re-pin the surface â†’ user trapped).
        _panelRoleDriven = false;

        if (ModuleState?.Settings != null)
        {
            if (_formId <= 0)
            {
                var legacyFormIdValue = ReadModuleSetting("FormId");
                var prefixedFormIdValue = ReadModuleSetting("MegaForm:FormId");
                var rawFormId = !string.IsNullOrWhiteSpace(prefixedFormIdValue) ? prefixedFormIdValue : legacyFormIdValue;
                if (int.TryParse(rawFormId, out var configuredId))
                {
                    _formId = configuredId;
                }
            }

            _cssClass = ReadModuleSetting("MegaForm:CssClass") ?? ReadModuleSetting("CssClass") ?? string.Empty;
            _moduleViewConfigJson = ReadModuleSetting("MegaForm:ViewConfig") ?? ReadModuleSetting("ViewConfig") ?? "{}";
            _selectedPresetThemeKey = ReadModuleSetting("MegaForm:SelectedThemePresetKey") ?? ReadModuleSetting("SelectedThemePresetKey") ?? string.Empty;
            _moduleConfigured = ReadModuleBool("MegaForm:ModuleConfigured") || ReadModuleBool("ModuleConfigured") || _formId > 0;
            // [FastEmbed v20260620-B210] per-module setting can explicitly enable/disable (default ON),
            // unless the ?mffast= query override was given (which wins).
            if (!fastQueryExplicit)
            {
                if (ModuleState.Settings.ContainsKey("MegaForm:FastEmbed")) _fastEmbed = ReadModuleBool("MegaForm:FastEmbed");
                else if (ModuleState.Settings.ContainsKey("FastEmbed")) _fastEmbed = ReadModuleBool("FastEmbed");
            }

            // [ModuleRole 2026-06-11] Read the pinned-surface role. When set (and no
            // explicit ?mfpanel= override is present), the module *is* that surface â€”
            // so an Oqtane page hosting it renders e.g. the Dashboard or My Inbox
            // directly. Honours admin gating downstream (e.g. Languages = admin only).
            _moduleRole = (ReadModuleSetting("MegaForm:ModuleRole") ?? ReadModuleSetting("ModuleRole") ?? string.Empty).Trim().ToLowerInvariant();
            // Admin escape: ?mfconfig=1 forces the normal module dock + Settings even
            // when a role is pinned, so admins can always reach / change the role.
            var configEscape = string.Equals(GetQueryValue(currentUri, "mfconfig"), "1", StringComparison.OrdinalIgnoreCase);
            if (_panelMode == MfPanelMode.None && !configEscape && !string.IsNullOrEmpty(_moduleRole))
            {
                _panelMode = _moduleRole switch
                {
                    "dashboard" => MfPanelMode.Dashboard,
                    "builder" => MfPanelMode.Builder,
                    "submissions" => MfPanelMode.Submissions,
                    "portal" => MfPanelMode.Portal,
                    "myinbox" => MfPanelMode.MyInbox,
                    "inbox" => MfPanelMode.MyInbox,
                    "languages" => MfPanelMode.Languages,
                    "sdkdemo" => MfPanelMode.SdkDemo,
                    _ => MfPanelMode.None
                };
                // [Inline default 2026-06-12] Role-pinned surfaces also render inline (embedded
                // in the page) by default, with the Fullscreen toggle available. ?mfinline=0 escapes.
                _panelInline = !string.Equals(GetQueryValue(currentUri, "mfinline"), "0", StringComparison.OrdinalIgnoreCase);
                _panelRoleDriven = _panelMode != MfPanelMode.None;
            }

            // [ViewDesigner v20260503-06] Parse viewMode + list/card config out of
            // ModuleState.Settings so anonymous visitors AND admins both render the
            // right mount. Previously these fields were only populated inside
            // LoadAdminConfigAsync â€” meaning anonymous users always saw the form
            // even when the module was set to List/Card view, and even admins
            // would silently fall back to the form if the GetModuleConfigAsync
            // call threw before reaching the viewMode block.
            ApplyViewConfigFromJson(_moduleViewConfigJson);
        }

        AddPlatformHeadContent();

        if (_isAdmin)
        {
            await LoadAdminConfigAsync();
            await BuildDashboardAsync();
            AddPlatformHeadContent();
        }
        else if (!_liveRenderMode)
        {
            // [OqtaneCanonicalModuleBinding v20260511-06] Non-admin visitors were
            // still reading stale ModuleState.Settings, while admins refreshed the
            // true module binding from ModuleConfig. Result: named views could point
            // at the new form, but generic ?view=form still rendered the previous
            // schema for regular users. Reuse the same canonical ModuleConfig read
            // for authenticated/public visitors and quietly fall back if the host
            // blocks the API.
            try
            {
                await LoadAdminConfigAsync();
                AddPlatformHeadContent();
            }
            catch
            {
                // Keep the stale ModuleState fallback rather than breaking render.
            }
        }

        if (_formId > 0)
        {
            try
            {
                // Keep workflow preview reads under the same ViewModule auth context
                // as the rest of the Oqtane module; otherwise the API may 403 and
                // the BPMN map silently falls back to an empty preview.
                var form = await MegaFormService.GetFormAsync(_formId, ModuleState?.ModuleId ?? 0, GetCurrentSiteId());
                _preloadedForm = form;
                _isPublished = form != null; // [B267] draft/published gate REMOVED — every existing form is viewable; only the orthogonal "locked" concept gates management
                _initialInlineCss = form?.InitialInlineCss ?? string.Empty;
                LoadWorkflowPreview(form?.WorkflowJson);
                // Static render has no Blazor circuit for this module, so field-level SSR is safe
                // and gives public visitors real form markup in the first HTML response.
                if (SsrMode)
                    TryBuildSsrFormHtml(!string.IsNullOrWhiteSpace(form?.ResolvedSchemaJson) ? form.ResolvedSchemaJson : form?.SchemaJson);
            }
            catch
            {
                _isPublished = false;
                _initialInlineCss = string.Empty;
                _workflowPreview = WorkflowPreviewModel.Empty();
            }

            // [OQ-difix20260418-12] Bug F: same Oqtane ServiceBase JSON quirk that
            // emptied response.Forms (Bug D) sometimes leaves FormDto.Status as the
            // C# default "Draft" even when the JSON payload says "status":"Published".
            // Result: orange "This form is not published yet" warning shows for an
            // already-published form.
            //
            // Defense-in-depth:
            //   1. If _forms (loaded by reliable Form/List endpoint via v11-D
            //      fallback) confirms the form exists and is Published â†’ trust it.
            //   2. Otherwise â€” for non-admin live render â€” re-query Form/List
            //      directly here (since LoadAdminConfigAsync only ran for admins)
            //      and read the status from there.
            if (!_isPublished)
            {
                FormListItem match = null;
                if (_forms != null && _forms.Count > 0)
                {
                    match = _forms.FirstOrDefault(f => f.FormId == _formId);
                }
                if (match == null)
                {
                    try
                    {
                        var allForms = await MegaFormService.ListFormsAsync(ModuleState.ModuleId, GetCurrentSiteId());
                        if (allForms != null)
                        {
                            var hit = allForms.FirstOrDefault(f => f.FormId == _formId);
                            if (hit != null)
                            {
                                match = new FormListItem { FormId = hit.FormId, Title = hit.Title, Status = hit.Status };
                            }
                        }
                    }
                    catch { /* non-fatal */ }
                }
                if (match != null) // [B267] any existing form is viewable (draft/published gate removed)
                {
                    _isPublished = true;
                }
            }
        }

        // [OQ-difix20260420-09] Stash, don't inject. OnAfterRenderAsync will eval
        // via IJSRuntime so the boot script is guaranteed to run even when it's
        // built after async awaits have already ended the current resource pass.
        // [ListViewBootSkip v20260508-04] ONLY run the form-renderer boot when
        // the module is actually in form mode. In list/card/listview mode the
        // page emits a different mount div (data-mf-view="list", data-mf-listview)
        // and the form-renderer boot would wait 10s for `mf-form-{module}-{form}`
        // â€” which never exists â€” then log "MegaForm core wait timed out".
        // [PanelBootSkip 2026-06-11] Also skip the form-renderer boot when an admin
        // PANEL is active (?mfpanel=languages/dashboard/submissions/...). In panel mode
        // the module renders the panel, NOT the form, so the `mf-form-{module}-{form}`
        // mount never exists â†’ waitForCore polled 10s â†’ "MegaForm core wait timed out"
        // (seen on Languages â†’ Import JSON, which re-renders and re-triggers the boot).
        if (_formId > 0 && _isPublished && !_embedMode && IsFormMode && _panelMode == MfPanelMode.None)
        {
            // [FastEmbed v20260620-B209] In fast-embed (non-popup) mode the form is an <iframe>
            // to the server-rendered page, so the heavy JS renderer boot is replaced by a tiny
            // script that only wires the iframe auto-resize listener.
            // [SSR hydrate B213] But when SsrMode is active the form is rendered in-place (not an
            // iframe) and needs the full renderer boot (which hydrates the SSR DOM via init()).
            _pendingRendererBoot = (_fastEmbed && !SsrMode && !IsPopupMode) ? BuildFastEmbedBootScript() : BuildRendererBootScript();
            _rendererBootExecuted = false;
        }
        else
        {
            _pendingRendererBoot = string.Empty;
        }

        // [2026-06-13] Ensure a role-pinned / panel surface gets its (gated) admin bundle.
        _pendingSurfaceBoot = BuildSurfaceBootScript();
        _surfaceBootExecuted = false;

        if (_panelMode != MfPanelMode.None)
        {
            _loading = false;
            return;
        }

        EnsureStarterRoleSelection();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Oqtane ModuleBase injects ResourceType.Script entries here on first render.
        // If we short-circuit and skip base.OnAfterRenderAsync, the live renderer core
        // files declared in Resources never reach the page, leaving MegaFormRenderer undefined.
        await base.OnAfterRenderAsync(firstRender);

        // [OQ-difix20260420-09] Run the stashed renderer boot once the mount div is
        // guaranteed in the DOM. Eval gives us the same "inline <script>" semantics
        // UpsertModuleInlineScript was supposed to produce, minus the timing hazard.
        if (!_rendererBootExecuted && !string.IsNullOrEmpty(_pendingRendererBoot))
        {
            _rendererBootExecuted = true;
            try
            {
                await Js.InvokeVoidAsync("eval", _pendingRendererBoot);
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"MegaForm: renderer boot eval failed: {ex.Message}");
            }
        }

        if (!_surfaceBootExecuted && !string.IsNullOrEmpty(_pendingSurfaceBoot))
        {
            _surfaceBootExecuted = true;
            try { await Js.InvokeVoidAsync("eval", _pendingSurfaceBoot); }
            catch (Exception ex) { Console.Error.WriteLine($"MegaForm: surface boot eval failed: {ex.Message}"); }
        }

        // [BrowseViewAutoMount v20260509-06] Oqtane/Blazor can render the
        // browse-mode mount divs after the JS bundles have already passed their
        // DOMContentLoaded auto-bind. Nudge all browse renderers after every
        // render so list/card/listview surfaces re-mount even if the host swaps
        // or re-creates their nodes late.
        try
        {
            await Js.InvokeVoidAsync("eval", @"
(function(){
  try { if (window.MFListViewRebind) window.MFListViewRebind(); } catch {}
  try { if (window.MFSubmissionListRebind) window.MFSubmissionListRebind(); } catch {}
  try { if (window.MFSubmissionCardRebind) window.MFSubmissionCardRebind(); } catch {}
  try {
    var root = document.getElementById('mf-dnn-tasks-root');
    if (root && window.MegaForm && window.MegaForm.initWorkflowInbox) {
      window.MegaForm.initWorkflowInbox(root);
    }
  } catch {}
})();
");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"MegaForm: browse rebind eval failed: {ex.Message}");
        }

        // [NoPopupAdmin v20260605-01] Workflow editor no longer auto-opens as a popup.
        // Admins navigate to the Builder with ?rightTab=workflow instead.

        // [NoPopupAdmin v20260605-04] Panels now render inside .mf-oq-panel-fullscreen
        // which uses position:fixed to escape the Oqtane admin modal boundaries.

        if (_panelMode != MfPanelMode.None && firstRender)
        {
            try
            {
                await Js.InvokeVoidAsync("eval", @"
(function(){
    var KEY = '__mfModalFixed';
    function fix() {
        var am = document.querySelector('.app-admin-modal');
        if (!am || am.dataset[KEY]) return;
        am.dataset[KEY] = '1';
        var m = am.querySelector('.modal');
        var d = m ? m.querySelector('.modal-dialog') : null;
        var c = m ? m.querySelector('.modal-content') : null;
        var h = m ? m.querySelector('.modal-header') : null;
        var b = m ? m.querySelector('.modal-body') : null;
        var f = m ? m.querySelector('.modal-footer') : null;
        if (c) {
            c.style.setProperty('margin','0','important');
            c.style.setProperty('width','100%','important');
            c.style.setProperty('max-width','100%','important');
            c.style.setProperty('height','100vh','important');
            c.style.setProperty('border-radius','0','important');
            c.style.setProperty('border','none','important');
            c.style.setProperty('box-shadow','none','important');
            c.style.setProperty('padding','0','important');
        }
        if (d) {
            d.style.setProperty('margin','0','important');
            d.style.setProperty('max-width','100%','important');
            d.style.setProperty('width','100%','important');
            d.style.setProperty('height','100vh','important');
        }
        if (h) h.style.setProperty('display','none','important');
        if (f) f.style.setProperty('display','none','important');
        if (b) b.style.setProperty('padding','0','important');
        if (m) {
            m.style.setProperty('background','#f8fafc','important');
            m.style.setProperty('padding','0','important');
        }
        am.style.setProperty('position','fixed','important');
        am.style.setProperty('inset','0','important');
        am.style.setProperty('z-index','9999','important');
    }
    fix();
    var obs = new MutationObserver(function(){ fix(); });
    obs.observe(document.body, {childList:true, subtree:true});
    setTimeout(function(){ obs.disconnect(); }, 8000);
})();
");
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"MegaForm: modal expand failed: {ex.Message}");
            }
        }
    }

    private async Task LoadAdminConfigAsync()
    {
        try
        {
            var response = await MegaFormService.GetModuleConfigAsync(ModuleState.ModuleId, GetCurrentSiteId());
            _forms = response?.Forms ?? new List<FormListItem>();

            // [OQ-difix20260418-11] Bug D fix: response.Forms occasionally arrives
            // empty even when the API returned forms (deserialization quirk in
            // Oqtane's ServiceBase). Fall back to ListFormsAsync â€” the dedicated
            // Form/List endpoint that we know returns the full list reliably.
            // Result: the "Module form" dropdown is always populated when the DB
            // has forms.
            if (_forms.Count == 0)
            {
                try
                {
                    var allForms = await MegaFormService.ListFormsAsync(ModuleState.ModuleId, GetCurrentSiteId());
                    if (allForms != null && allForms.Count > 0)
                    {
                        _forms = allForms.Select(f => new FormListItem
                        {
                            FormId = f.FormId,
                            Title  = string.IsNullOrWhiteSpace(f.Title) ? $"Form #{f.FormId}" : f.Title,
                            Status = string.IsNullOrWhiteSpace(f.Status) ? "Draft" : f.Status,
                        }).ToList();
                    }
                }
                catch
                {
                    // Non-fatal â€” dropdown stays with the "-- Select a Form --" placeholder.
                }
            }

            // [OQ-fixedrender v20260420-01] In page render mode, trust the
            // ModuleConfig API as the canonical module binding source instead of the
            // potentially stale ModuleState.Settings snapshot. This keeps the current
            // page's fixed form in sync immediately after Save Module Settings.
            if (!_liveRenderMode && response?.Config != null)
            {
                _formId = response.Config.FormId > 0 ? response.Config.FormId : 0;
            }
            else if (_formId <= 0 && response?.Config != null && response.Config.FormId > 0)
            {
                _formId = response.Config.FormId;
            }

            if (response?.Config != null)
            {
                _moduleViewConfigJson = string.IsNullOrWhiteSpace(response.Config.ViewConfig) ? _moduleViewConfigJson : response.Config.ViewConfig;
                _cssClass = string.IsNullOrWhiteSpace(response.Config.CssClass) ? _cssClass : response.Config.CssClass;
                _moduleConfigured = response.Config.ModuleConfigured || response.Config.FormId > 0 || _moduleConfigured;
                _displayMode = string.Equals(response.Config.DisplayMode, "popup", StringComparison.OrdinalIgnoreCase) ? "popup" : "fixed";
                _triggerType = NormalizeTriggerType(response.Config.TriggerType);
                _delaySeconds = response.Config.DelaySeconds > 0 ? response.Config.DelaySeconds : 5;
                _scrollPercent = response.Config.ScrollPercent > 0 ? response.Config.ScrollPercent : 50;
                _clickSelector = response.Config.ClickSelector ?? string.Empty;
                _showOncePerSession = response.Config.ShowOncePerSession;
                _closeOnOverlay = response.Config.CloseOnOverlay;
                _startAt = response.Config.StartAt ?? string.Empty;
                _endAt = response.Config.EndAt ?? string.Empty;
                // [SubmissionViews v20260503-01] + [ListViewRouting v20260507-23]
                var vm = (response.Config.ViewMode ?? string.Empty).Trim().ToLowerInvariant();
                _viewMode = (vm == "list" || vm == "card" || vm == "listview") ? vm : "form";
                _listFields = response.Config.ListFields ?? string.Empty;
                _listTemplate = response.Config.ListTemplate ?? string.Empty;
                _cardFields = response.Config.CardFields ?? string.Empty;
                _cardTemplate = response.Config.CardTemplate ?? string.Empty;
                ApplyViewConfigFromJson(_moduleViewConfigJson);
            }

            _rendererHostUrl = response?.RendererHostUrl ?? string.Empty;
            _rendererHostPageId = response?.RendererHostPageId ?? 0;
            _rendererHostModuleId = response?.RendererHostModuleId ?? 0;
            _useThisPageAsRendererHost = IsCurrentPageRendererHost();
        }
        catch
        {
            _forms = new List<FormListItem>();
        }
    }

    private async Task SaveManagePanelAsync()
    {
        var config = new ModuleConfigDto
        {
            ModuleId = ModuleState.ModuleId,
            FormId = _formId,
            ViewType = "submit",
            CssClass = _cssClass ?? string.Empty,
            ModuleConfigured = true,
            DisplayMode = IsPopupMode ? "popup" : "fixed",
            TriggerType = NormalizeTriggerType(_triggerType),
            DelaySeconds = Math.Clamp(_delaySeconds <= 0 ? 5 : _delaySeconds, 0, 600),
            ScrollPercent = Math.Clamp(_scrollPercent <= 0 ? 50 : _scrollPercent, 5, 95),
            ClickSelector = (_clickSelector ?? string.Empty).Trim(),
            ShowOncePerSession = _showOncePerSession,
            CloseOnOverlay = _closeOnOverlay,
            StartAt = _startAt ?? string.Empty,
            EndAt = _endAt ?? string.Empty,
            UseCurrentPageAsRendererHost = _useThisPageAsRendererHost,
            CurrentPageUrl = GetCurrentPageRendererHostUrl(),
            CurrentPageId = PageState?.Page?.PageId ?? 0
        };

        await MegaFormService.SaveModuleConfigAsync(config, GetCurrentSiteId());
        _moduleConfigured = true;
        _saveMessage = "Module settings saved.";
        NavigationManager.NavigateTo(NavigationManager.Uri, true);
    }


