    // [FastEmbed recreate fix v20260621-B217] Create the form <iframe> in JS (once) and wire its
    // auto-resize listener. The iframe is built HERE rather than in the Razor tree so Blazor's diff
    // never sees it and can never recreate it on a re-render (the old double-load cause). Idempotent:
    // if the host already holds the iframe (OnAfterRender can run many times, or a re-render may
    // re-emit this boot), we leave it untouched — src loads exactly once. The fast page
    // (/api/MegaForm/render/{id}) postMessages its content height; we size the iframe to match
    // (no inner scrollbar / clipping). Same-origin only. Runs via eval in OnAfterRenderAsync (an
    // inline <script> emitted by Blazor would NOT execute).
    private string BuildFastEmbedBootScript()
    {
        var payload = JsonSerializer.Serialize(new
        {
            hostId = "mf-fast-host-" + FormMountId,
            frameId = "mf-fast-" + FormMountId,
            formId = _formId,
            src = "/api/MegaForm/render/" + _formId
        });
        return "(function(opts){"
            + "var host=document.getElementById(opts.hostId);"
            + "if(!host)return;"
            + "var f=document.getElementById(opts.frameId);"
            + "if(!f){"                                          // create the iframe exactly once
            + "if(host.querySelector('iframe.mf-fast-embed-frame'))return;"  // belt-and-braces guard
            + "f=document.createElement('iframe');"
            + "f.id=opts.frameId;f.className='mf-fast-embed-frame';"
            + "f.setAttribute('title','MegaForm');f.setAttribute('scrolling','no');f.setAttribute('loading','eager');"
            + "f.src=opts.src;"
            + "f.style.cssText='display:block;width:100%;border:0;min-height:460px;background:transparent;';"
            + "host.appendChild(f);"
            + "}"
            + "if(f.__mfFastWired)return;f.__mfFastWired=true;"   // wire resize once
            + "window.addEventListener('message',function(e){"
            + "if(e.origin!==location.origin)return;"
            + "var d=e.data;"
            + "if(d&&d.type==='mf-resize'&&d.formId===opts.formId&&d.height>0){f.style.height=d.height+'px';}"
            + "});"
            + "})(" + payload + ");";
    }

    private string ReadModuleSetting(string key)
    {
        if (ModuleState?.Settings != null && ModuleState.Settings.TryGetValue(key, out var value))
        {
            return value ?? string.Empty;
        }
        return string.Empty;
    }

    private bool ReadModuleBool(string key)
    {
        var raw = ReadModuleSetting(key);
        return bool.TryParse(raw, out var parsed) && parsed;
    }

    private string GetSelectedFormTitle()
    {
        if (_formId <= 0)
        {
            return "No form selected";
        }

        var item = _forms.FirstOrDefault(f => f.FormId == _formId);
        if (item != null && !string.IsNullOrWhiteSpace(item.Title))
        {
            return item.Title;
        }

        return $"Form #{_formId}";
    }

    private string GetSelectedFormStatus()
    {
        var item = _forms.FirstOrDefault(f => f.FormId == _formId);
        if (item != null && !string.IsNullOrWhiteSpace(item.Status))
        {
            return item.Status;
        }
        return _isPublished ? "Published" : "Draft / Unknown";
    }

    private string GetRendererHostStatus()
    {
        var isCurrentPage = IsCurrentPageRendererHost();

        if (_useThisPageAsRendererHost && !isCurrentPage)
        {
            return "After you save these module settings, this page will become the public Renderer Host for View and embedded links.";
        }

        if (!_useThisPageAsRendererHost && isCurrentPage)
        {
            return "This page is currently the public Renderer Host for View and embedded links. Clear the checkbox and save to move or unset it.";
        }

        if (isCurrentPage)
        {
            return "This page is currently the public Renderer Host for View and embedded links.";
        }
        if (!string.IsNullOrWhiteSpace(_rendererHostUrl))
        {
            return "Renderer Host is another page: " + _rendererHostUrl;
        }
        return "Renderer Host is not set yet.";
    }

    private bool IsCurrentPageRendererHost()
    {
        var currentUrl = GetCurrentPageRendererHostUrl();
        if (!string.IsNullOrWhiteSpace(_rendererHostUrl) && string.Equals(_rendererHostUrl, currentUrl, StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }
        return _rendererHostPageId > 0 && _rendererHostPageId == (PageState?.Page?.PageId ?? 0);
    }

    private string GetCurrentPageRendererHostUrl()
    {
        try
        {
            var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
            return uri.GetLeftPart(UriPartial.Path).TrimEnd('/');
        }
        catch
        {
            return NavigationManager.Uri?.TrimEnd('/') ?? string.Empty;
        }
    }

    private string BuildTemplateContextJson()
    {
        var effectiveFormId = IsListViewMode && _listViewFormId > 0 ? _listViewFormId : _formId;
        var payload = new
        {
            form = new
            {
                id = effectiveFormId,
                title = GetSelectedFormTitle(),
                status = _isPublished ? "Published" : "Draft"
            },
            module = new
            {
                id = ModuleState?.ModuleId ?? 0,
                siteId = GetCurrentSiteId(),
                pageId = PageState?.Page?.PageId ?? 0,
                platform = "oqtane",
                viewMode = _viewMode,
                queryKey = _activeQueryKey ?? string.Empty,
                rendererHostUrl = _rendererHostUrl ?? string.Empty
            },
            user = new
            {
                isAdmin = _isAdmin,
                isAuthenticated = PageState?.User != null
            }
        };
        return JsonSerializer.Serialize(payload);
    }

    private static string NormalizeTriggerType(string value)
    {
        var trigger = (value ?? string.Empty).Trim().ToLowerInvariant();
        return trigger == "scroll_depth" || trigger == "click_trigger" ? trigger : "time_delay";
    }

    // [ViewDesigner v20260503-06] Pull viewMode + list/card config out of the
    // raw MegaForm:ViewConfig JSON in ModuleState.Settings. Applies to ALL
    // visitors (not just admins) so the page renders the right mount on the
    // very first request, before â€” and independently of â€” LoadAdminConfigAsync.
    private void ApplyViewConfigFromJson(string json)
    {
        if (string.IsNullOrWhiteSpace(json) || json == "{}") return;
        try
        {
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;
            if (root.ValueKind != JsonValueKind.Object) return;

            string ReadStr(string camel, string pascal = null)
            {
                if (root.TryGetProperty(camel, out var v) && v.ValueKind == JsonValueKind.String) return v.GetString();
                if (pascal != null && root.TryGetProperty(pascal, out var v2) && v2.ValueKind == JsonValueKind.String) return v2.GetString();
                return null;
            }

            string ReadItemStr(JsonElement source, string camel, string pascal = null)
            {
                if (source.TryGetProperty(camel, out var v) && v.ValueKind == JsonValueKind.String) return v.GetString();
                if (pascal != null && source.TryGetProperty(pascal, out var v2) && v2.ValueKind == JsonValueKind.String) return v2.GetString();
                return null;
            }

            void ApplyGenericRootConfig(string mode)
            {
                var normalized = string.Equals(mode, "list", StringComparison.OrdinalIgnoreCase)
                    || string.Equals(mode, "card", StringComparison.OrdinalIgnoreCase)
                    || string.Equals(mode, "listview", StringComparison.OrdinalIgnoreCase)
                    ? mode.ToLowerInvariant()
                    : "form";

                _viewMode = normalized;
                _activeViewKey = string.Empty;
                _activeQueryKey = string.Empty;
                _listFields = ReadStr("listFields", "ListFields") ?? _listFields ?? string.Empty;
                _listTemplate = ReadStr("listTemplate", "ListTemplate") ?? _listTemplate ?? string.Empty;
                _cardFields = ReadStr("cardFields", "CardFields") ?? _cardFields ?? string.Empty;
                _cardTemplate = ReadStr("cardTemplate", "CardTemplate") ?? _cardTemplate ?? string.Empty;
                _listViewSettingsJson = ReadStr("listViewSettingsJson", "ListViewSettingsJson") ?? _listViewSettingsJson ?? "{}";
                if (_viewMode == "listview" && (_listViewSettingsJson == "{}" || string.IsNullOrWhiteSpace(_listViewSettingsJson)))
                {
                    _listViewSettingsJson = json;
                }

                ParseListViewSettings(_listViewSettingsJson);
            }

            void ApplyNamedView(FormViewInfo item)
            {
                var mode = FormViewSelector.MapViewTypeToViewMode(item?.ViewType);
                if (string.IsNullOrWhiteSpace(mode))
                {
                    mode = "form";
                }

                _activeViewKey = item?.ViewKey ?? string.Empty;
                _activeQueryKey = item?.QueryKey ?? string.Empty;

                if (!string.IsNullOrWhiteSpace(item.ConfigJson) && item.ConfigJson != "{}")
                {
                    try
                    {
                        using var itemDoc = JsonDocument.Parse(item.ConfigJson);
                        var itemRoot = itemDoc.RootElement;
                        if (itemRoot.ValueKind == JsonValueKind.Object)
                        {
                            _listFields = ReadItemStr(itemRoot, "listFields", "ListFields") ?? _listFields ?? string.Empty;
                            _listTemplate = ReadItemStr(itemRoot, "listTemplate", "ListTemplate") ?? _listTemplate ?? string.Empty;
                            _cardFields = ReadItemStr(itemRoot, "cardFields", "CardFields") ?? _cardFields ?? string.Empty;
                            _cardTemplate = ReadItemStr(itemRoot, "cardTemplate", "CardTemplate") ?? _cardTemplate ?? string.Empty;
                            _listViewSettingsJson = ReadItemStr(itemRoot, "listViewSettingsJson", "ListViewSettingsJson") ?? item.ConfigJson;
                        }
                    }
                    catch
                    {
                        _listViewSettingsJson = item.ConfigJson;
                    }
                }

                _viewMode = mode;
                if (mode == "list" && !string.IsNullOrWhiteSpace(item.CustomHtml))
                {
                    _listTemplate = item.CustomHtml;
                }
                else if (mode == "card" && !string.IsNullOrWhiteSpace(item.CustomHtml))
                {
                    _cardTemplate = item.CustomHtml;
                }
                else if (mode == "listview" && (string.IsNullOrWhiteSpace(_listViewSettingsJson) || _listViewSettingsJson == "{}"))
                {
                    _listViewSettingsJson = item.ConfigJson;
                }

                ParseListViewSettings(_listViewSettingsJson);

                // [ViewCustomHtmlListview v20260516-11] Honor MF_Views.CustomHtml on the
                // new ListView mode too. CustomHtml is treated as the WRAPPER template
                // (it is expected to contain a {{rows}} placeholder where per-row HTML
                // is injected, or it can be self-rendering chrome that shows static data).
                // Runs AFTER ParseListViewSettings so it overrides whatever ConfigJson set.
                if (mode == "listview" && !string.IsNullOrWhiteSpace(item.CustomHtml))
                {
                    _listViewWrapperTemplate = item.CustomHtml;
                }
            }

            var currentUri = NavigationManager?.Uri ?? string.Empty;
            var requestedView = (GetQueryValue(currentUri, "view") ?? string.Empty).Trim();
            var requestedViewKey = (GetQueryValue(currentUri, "vk") ?? string.Empty).Trim();
            var selectedViewKey = FormViewSelector.ReadSelectedViewKey(json);
            var catalogItems = FormViewSelector.ReadViewCatalog(json)
                .Select(item => new FormViewInfo
                {
                    ViewKey = item.ViewKey,
                    QueryKey = item.QueryKey,
                    ViewType = item.ViewType,
                    ViewName = item.ViewName,
                    IsDefault = item.IsDefault,
                    ConfigJson = item.ConfigJson,
                    CustomHtml = item.CustomHtml
                })
                .ToList();
            var moduleViewType = ReadStr("viewMode", "ViewMode")
                ?? ReadStr("viewType", "ViewType")
                ?? _viewMode
                ?? "form";
            var selection = FormViewSelector.Resolve(
                catalogItems,
                requestedView,
                requestedViewKey,
                selectedViewKey,
                moduleViewType);
            if (selection.UsedNamedView && selection.MatchedView != null)
            {
                ApplyNamedView(selection.MatchedView);
                return;
            }

            ApplyGenericRootConfig(FormViewSelector.MapViewTypeToViewMode(selection.ActiveViewType));
        }
        catch
        {
            // Malformed JSON â€” leave _viewMode at its current value ("form" by default).
        }
    }

    // [ListViewRouting v20260507-23] Decode the saved ListView settings JSON
    // into the typed backing fields the Razor markup binds to.
    private void ParseListViewSettings(string json)
    {
        // Reset to defaults first so re-parses don't keep stale values.
        _listViewFormId          = 0;
        _listViewFieldsJson      = "[]";
        _listViewRowTemplate     = string.Empty;
        _listViewDetailTemplate  = string.Empty;
        _listViewWrapperTemplate = string.Empty;
        _listViewPageSize        = 25;
        _listViewEnableSearch    = true;
        _listViewEnableSort      = true;
        _listViewTitle           = string.Empty;
        _listViewEmptyMessage    = "No submissions yet.";
        _listViewShowAddButton   = true;
        _listViewShowRowActions  = true;
        if (string.IsNullOrWhiteSpace(json) || json == "{}") return;
        try
        {
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;
            if (root.ValueKind != JsonValueKind.Object) return;

            string ReadStr(string camel, string pascal = null)
            {
                if (root.TryGetProperty(camel, out var v) && v.ValueKind == JsonValueKind.String) return v.GetString();
                if (pascal != null && root.TryGetProperty(pascal, out var v2) && v2.ValueKind == JsonValueKind.String) return v2.GetString();
                return null;
            }
            int ReadInt(string camel, string pascal, int def)
            {
                if (root.TryGetProperty(camel, out var v) && v.ValueKind == JsonValueKind.Number && v.TryGetInt32(out var n)) return n;
                if (root.TryGetProperty(pascal, out var v2) && v2.ValueKind == JsonValueKind.Number && v2.TryGetInt32(out var n2)) return n2;
                return def;
            }
            bool ReadBool(string camel, string pascal, bool def)
            {
                if (root.TryGetProperty(camel, out var v) && (v.ValueKind == JsonValueKind.True || v.ValueKind == JsonValueKind.False)) return v.GetBoolean();
                if (root.TryGetProperty(pascal, out var v2) && (v2.ValueKind == JsonValueKind.True || v2.ValueKind == JsonValueKind.False)) return v2.GetBoolean();
                return def;
            }

            _listViewFormId          = ReadInt("formId", "FormId", _listViewFormId);
            if (_listViewFormId <= 0)
            {
                _listViewFormId = _formId;
            }
            _listViewRowTemplate     = ReadStr("rowTemplate",     "RowTemplate")     ?? _listViewRowTemplate;
            _listViewDetailTemplate  = ReadStr("detailTemplate",  "DetailTemplate")  ?? _listViewDetailTemplate;
            _listViewWrapperTemplate = ReadStr("wrapperTemplate", "WrapperTemplate") ?? _listViewWrapperTemplate;
            _listViewPageSize        = ReadInt("pageSize", "PageSize", _listViewPageSize);
            _listViewEnableSearch    = ReadBool("enableSearch", "EnableSearch", _listViewEnableSearch);
            _listViewEnableSort      = ReadBool("enableSort",   "EnableSort",   _listViewEnableSort);
            _listViewShowAddButton   = ReadBool("showAddButton",  "ShowAddButton",  _listViewShowAddButton);
            _listViewShowRowActions  = ReadBool("showRowActions", "ShowRowActions", _listViewShowRowActions);
            _listViewTitle           = ReadStr("title",        "Title")        ?? _listViewTitle;
            _listViewEmptyMessage    = ReadStr("emptyMessage", "EmptyMessage") ?? _listViewEmptyMessage;

            if (root.TryGetProperty("fields", out var f) && f.ValueKind == JsonValueKind.Array)
                _listViewFieldsJson = f.GetRawText();
            else if (root.TryGetProperty("Fields", out var f2) && f2.ValueKind == JsonValueKind.Array)
                _listViewFieldsJson = f2.GetRawText();
        }
        catch
        {
            // Bad JSON â€” leave defaults; runtime will show the empty-state.
        }
    }

    private static string GetQueryValue(string uri, string key)
    {
        if (string.IsNullOrWhiteSpace(uri) || string.IsNullOrWhiteSpace(key))
        {
            return null;
        }

        var question = uri.IndexOf('?');
        if (question < 0 || question >= uri.Length - 1)
        {
            return null;
        }

        var query = uri.Substring(question + 1);
        var hash = query.IndexOf('#');
        if (hash >= 0)
        {
            query = query.Substring(0, hash);
        }

        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        foreach (var part in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2, StringSplitOptions.None);
            if (kv.Length == 0)
            {
                continue;
            }

            var candidateKey = Uri.UnescapeDataString((kv[0] ?? string.Empty).Replace('+', ' '));
            if (!string.Equals(candidateKey, key, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            var value = kv.Length > 1 ? kv[1] ?? string.Empty : string.Empty;
            return Uri.UnescapeDataString(value.Replace('+', ' '));
        }

        return null;
    }

