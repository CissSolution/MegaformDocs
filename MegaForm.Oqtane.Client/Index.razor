@if (IsWorkflowMapMode && _workflowPreview != null && _workflowPreview.Nodes.Count > 0)
{
    <style>
        .mf-flow-shell{display:grid;gap:18px;font-family:'Inter',system-ui,sans-serif;}
        .mf-flow-hero{display:grid;gap:14px;padding:22px 24px;border:1px solid #bfdbfe;border-radius:24px;background:linear-gradient(135deg,#eff6ff 0%,#ffffff 55%,#f8fafc 100%);box-shadow:0 18px 42px rgba(15,23,42,.08);}
        .mf-flow-hero-main{display:flex;justify-content:space-between;gap:18px;align-items:flex-start;flex-wrap:wrap;}
        .mf-flow-eyebrow{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:#2563eb;font-weight:800;}
        .mf-flow-title{margin:6px 0 0;font-size:30px;line-height:1.12;color:#0f172a;}
        .mf-flow-sub{margin:10px 0 0;font-size:14px;line-height:1.7;color:#475569;max-width:900px;}
        .mf-flow-chips{display:flex;gap:10px;flex-wrap:wrap;align-items:center;}
        .mf-flow-chip{display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border-radius:999px;border:1px solid #dbe4f0;background:#fff;color:#0f172a;font-size:13px;font-weight:700;box-shadow:0 8px 22px rgba(15,23,42,.05);}
        .mf-flow-actions{display:flex;gap:10px;flex-wrap:wrap;}
        .mf-flow-link{display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border-radius:999px;text-decoration:none;font-size:13px;font-weight:700;border:1px solid #dbe4f0;background:#fff;color:#0f172a;box-shadow:0 8px 22px rgba(15,23,42,.05);}
        .mf-flow-link.is-primary{background:#0f172a;border-color:#0f172a;color:#fff;}
        .mf-flow-grid{display:grid;grid-template-columns:minmax(0,1.3fr) minmax(320px,.7fr);gap:18px;align-items:start;}
        .mf-flow-canvas-card,.mf-flow-side-card{padding:18px;border:1px solid #dbe4f0;border-radius:22px;background:#fff;box-shadow:0 16px 36px rgba(15,23,42,.05);}
        .mf-flow-side-card{display:grid;gap:16px;}
        .mf-flow-canvas-wrap{position:relative;overflow:auto;max-height:72vh;border-radius:18px;border:1px solid #dbe4f0;background:linear-gradient(180deg,#f8fbff 0%,#ffffff 100%);}
        .mf-flow-canvas{position:relative;min-width:1000px;}
        .mf-flow-svg{position:absolute;inset:0;pointer-events:none;}
        .mf-flow-lane{position:absolute;left:24px;right:24px;border-radius:20px;border:1px dashed rgba(148,163,184,.55);background:rgba(255,255,255,.75);box-shadow:inset 0 0 0 1px rgba(255,255,255,.3);}
        .mf-flow-lane-label{position:absolute;left:18px;top:14px;padding:6px 10px;border-radius:999px;background:#0f172a;color:#fff;font-size:11px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;}
        .mf-flow-node{position:absolute;width:220px;border-radius:22px;border:1px solid #cbd5e1;background:#fff;box-shadow:0 18px 34px rgba(15,23,42,.12);padding:16px;display:grid;gap:10px;}
        .mf-flow-node.is-start{border-color:#86efac;background:linear-gradient(180deg,#f0fdf4 0%,#ffffff 100%);}
        .mf-flow-node.is-approval{border-color:#93c5fd;background:linear-gradient(180deg,#eff6ff 0%,#ffffff 100%);}
        .mf-flow-node.is-end{border-color:#fdba74;background:linear-gradient(180deg,#fff7ed 0%,#ffffff 100%);}
        .mf-flow-node.is-action{border-color:#cbd5e1;background:linear-gradient(180deg,#f8fafc 0%,#ffffff 100%);}
        .mf-flow-node-top{display:flex;justify-content:space-between;gap:10px;align-items:flex-start;}
        .mf-flow-node-type{display:inline-flex;align-items:center;padding:5px 10px;border-radius:999px;background:#e2e8f0;color:#334155;font-size:11px;font-weight:800;letter-spacing:.04em;text-transform:uppercase;}
