    private async Task SwitchStarterRoleAsync()
    {
        if (_starterRoleBusy)
        {
            return;
        }

        var profile = GetStarterQaProfile();
        var selectedRole = profile?.Roles?.FirstOrDefault(r =>
            string.Equals(r.UserName, _selectedStarterRoleUserName, StringComparison.OrdinalIgnoreCase));

        if (profile == null || selectedRole == null)
        {
            _saveMessage = "Starter role switcher is not available for this form.";
            return;
        }

        var targetUrl = BuildStarterRoleTargetUrl(selectedRole);
        var currentUser = GetCurrentUserName();
        if (!string.IsNullOrWhiteSpace(currentUser) &&
            string.Equals(currentUser, selectedRole.UserName, StringComparison.OrdinalIgnoreCase))
        {
            NavigationManager.NavigateTo(targetUrl, forceLoad: true);
            return;
        }

        _starterRoleBusy = true;
        _saveMessage = string.Empty;
        StateHasChanged();

        try
        {
            await Js.InvokeVoidAsync("MFStarter.switchRole", new
            {
                username = selectedRole.UserName,
                password = selectedRole.Password,
                targetUrl = targetUrl,
                currentUrl = NavigationManager?.Uri ?? string.Empty
            });
        }
        catch (Exception ex)
        {
            _saveMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to switch starter roles right now."
                : ex.Message;
            _starterRoleBusy = false;
        }
    }

    private void EnsureStarterRoleSelection()
    {
        var profile = GetStarterQaProfile();
        if (profile == null || profile.Roles == null || profile.Roles.Count == 0)
        {
            _selectedStarterRoleUserName = string.Empty;
            return;
        }

        if (!string.IsNullOrWhiteSpace(_selectedStarterRoleUserName) &&
            profile.Roles.Any(r => string.Equals(r.UserName, _selectedStarterRoleUserName, StringComparison.OrdinalIgnoreCase)))
        {
            return;
        }

        var currentUser = GetCurrentUserName();
        var matched = profile.Roles.FirstOrDefault(r =>
            !string.IsNullOrWhiteSpace(currentUser) &&
            string.Equals(r.UserName, currentUser, StringComparison.OrdinalIgnoreCase));

        _selectedStarterRoleUserName = matched?.UserName ?? profile.Roles[0].UserName;
    }

    private string GetCurrentUserName()
    {
        var user = PageState?.User;
        if (user == null)
        {
            return string.Empty;
        }

        foreach (var propertyName in new[] { "Username", "UserName", "Name", "DisplayName" })
        {
            var property = user.GetType().GetProperty(propertyName);
            if (property?.GetValue(user) is string text && !string.IsNullOrWhiteSpace(text))
            {
                return text.Trim();
            }
        }

        return string.Empty;
    }

    private string GetCurrentStarterRoleLabel()
    {
        var profile = GetStarterQaProfile();
        if (profile == null)
        {
            return "No starter role mapping";
        }

        var currentUser = GetCurrentUserName();
        var matched = profile.Roles.FirstOrDefault(r =>
            !string.IsNullOrWhiteSpace(currentUser) &&
            string.Equals(r.UserName, currentUser, StringComparison.OrdinalIgnoreCase));

        return matched != null ? matched.DisplayName : "Custom / host session";
    }

    private string BuildStarterRoleTargetUrl(StarterQaRoleOption role)
    {
        if (role == null)
        {
            return GetCurrentPageRendererHostUrl();
        }

        if (string.Equals(role.TargetType, "vk", StringComparison.OrdinalIgnoreCase))
        {
            return BuildCurrentModuleUrl("vk", role.TargetValue);
        }

        if (string.Equals(role.TargetType, "mfpanel", StringComparison.OrdinalIgnoreCase))
        {
            return BuildCurrentModuleUrl("mfpanel", role.TargetValue);
        }

        return BuildCurrentModuleUrl("view", string.IsNullOrWhiteSpace(role.TargetValue) ? "form" : role.TargetValue);
    }

