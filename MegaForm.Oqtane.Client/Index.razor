        .mf-flow-list-item-meta{font-size:12px;color:#475569;line-height:1.6;}
        @@media (max-width: 1080px){.mf-flow-grid{grid-template-columns:1fr;}.mf-flow-canvas{min-width:960px;}}
    </style>
}

@if (_loading)
{
    @* [FastPaint v20260620] _formId is resolved synchronously from the module settings
       BEFORE the first await, so during the post-circuit load window we already know whether
       this module renders a form. Show the form-shaped skeleton (not a bare spinner) so the
       form FRAME appears together with the admin dock and stays until the renderer paints —
       no blank gap. Falls back to the spinner for panels / list views / unconfigured modules. *@
    @if (_formId > 0 && IsFormMode && !IsPopupMode && _panelMode == MfPanelMode.None && !_embedMode)
    {
        @RenderFormSkeleton
    }
    else
    {
        <div class="mf-load-spinner" role="status" aria-label="Loading"></div>
    }
}
else if (_formId == 0)
{
    if (_isAdmin)
    {
        <div class="alert alert-info">
            <strong>MegaForm:</strong> No form configured.
            Use the <i class="fas fa-cog"></i> <strong>Module Settings</strong> (gear icon)
            or <a class="alert-link" href="@BuildPanelUrl("builder")">Form Builder</a> to choose a form.
        </div>
    }
}
else if (!_isPublished)
{
    if (_isAdmin)
    {
        <div class="alert alert-warning">
            <strong>MegaForm:</strong> This form is not published yet.
            <a class="alert-link" href="@BuildPanelUrl("builder")">Open Builder â†—</a>
        </div>
    }
}
else
{
    @* [SingleSource v20260624-B260] ONE CSS block per form. The former separate
       mf-inline-preset-{id} block is folded into this one by ModuleCssComposer.Compose
       (preset first, then scoped/customCss/compat). The public renderer early-returns on
       data-mf-ssr="1" so it never rebuilds this node — this is the single source at runtime. *@
    @if (!string.IsNullOrWhiteSpace(_ssrCustomCss))
    {
        <style id="mf-custom-css-@_formId">@((MarkupString)_ssrCustomCss)</style>
    }
@if (_isAdmin && !_liveRenderMode && !IsFormMode)
{
        @* [ListViewDiagnostic v20260507-28] Tiny admin-only badge so it's
           obvious which view mode the page actually loaded â€” useful when the
           page seems to "fall back" silently. Hidden in live render mode. *@
    <div style="margin:0 0 8px;padding:6px 12px;background:#fef3c7;border:1px solid #fcd34d;border-radius:8px;font-size:12px;color:#92400e;font-family:'Inter',system-ui,sans-serif">
        <strong>View mode:</strong> @_viewMode
        <span style="color:#a16207;margin-left:8px">Â· form #@_formId Â· @(IsWorkflowInboxMode ? "workflow inbox" : (IsListViewMode ? "MFListView (new)" : (IsListMode ? "data-mf-view=list (legacy)" : (IsCardMode ? "data-mf-view=card (legacy)" : "form"))))</span>
    </div>
}
