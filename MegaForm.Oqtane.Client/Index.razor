        .mf-flow-note{font-size:12px;line-height:1.6;color:#475569;border-top:1px dashed #e2e8f0;padding-top:10px;}
        .mf-flow-head{display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:14px;}
        .mf-flow-head h3{margin:0;font-size:16px;font-weight:800;color:#0f172a;}
        .mf-flow-head p{margin:6px 0 0;font-size:13px;line-height:1.6;color:#475569;}
        .mf-flow-side-block{display:grid;gap:10px;padding:14px;border:1px solid #e2e8f0;border-radius:18px;background:#f8fafc;}
        .mf-flow-side-block h4{margin:0;font-size:13px;font-weight:800;color:#0f172a;text-transform:uppercase;letter-spacing:.06em;}
        .mf-flow-list{display:grid;gap:10px;}
