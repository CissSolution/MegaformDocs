    // Reload target after saving settings: current page minus mfpanel/mfconfig so the
    // newly-applied role/view renders (preserves other query params like edit).
    private string BuildSettingsReturnUrl()
    {
        var uri = NavigationManager.Uri ?? "/";
        var path = uri.Split('?')[0].Split('#')[0];
        var kept = new List<string>();
        var qIdx = uri.IndexOf('?');
        if (qIdx >= 0)
        {
            var query = uri.Substring(qIdx + 1).Split('#')[0];
            foreach (var part in query.Split('&', StringSplitOptions.RemoveEmptyEntries))
            {
                var key = part.Split('=', 2)[0];
                if (key.Equals("mfpanel", StringComparison.OrdinalIgnoreCase)) continue;
                if (key.Equals("mfconfig", StringComparison.OrdinalIgnoreCase)) continue;
                kept.Add(part);
            }
        }
        return kept.Count == 0 ? path : path + "?" + string.Join("&", kept);
    }

