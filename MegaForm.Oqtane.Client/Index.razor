        WorkflowNodeType.Loop => "Loop Activity",
        WorkflowNodeType.SendEmail => "Service Task",
        WorkflowNodeType.Webhook => "Service Task",
        WorkflowNodeType.Database => "Service Task",
        WorkflowNodeType.GoogleSheets => "Service Task",
        WorkflowNodeType.Calculate => "Service Task",
