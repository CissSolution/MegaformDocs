    private async Task SaveInlineSettingsAsync()
    {
        if (_settingsBusy) return;
        _settingsBusy = true;
        _saveMessage = string.Empty;
        StateHasChanged();

        try
        {
            var config = new ModuleConfigDto
            {
                ModuleId = ModuleState?.ModuleId ?? 0,
                FormId = _formId,
                ViewMode = "form", // [FormOnly 2026-06-17] inline View Mode removed — always persist form view
                ModuleRole = _moduleRole,
                DisplayMode = _displayMode,
                PopupSize = _popupSize,
                TriggerType = _triggerType,
                DelaySeconds = _delaySeconds,
                ScrollPercent = _scrollPercent,
                ClickSelector = _clickSelector
            };
            await MegaFormService.SaveModuleConfigAsync(config, GetCurrentSiteId());
            // [SaveApplies 2026-06-11] ModuleState.Settings is cached by Blazor, so the
            // new role/settings only take effect on a fresh module load. Force a full
            // reload to the page WITHOUT mfpanel/mfconfig so the saved surface (e.g. the
            // inline Dashboard) renders immediately instead of silently doing nothing.
            _settingsBusy = false;
            NavigationManager.NavigateTo(BuildSettingsReturnUrl(), forceLoad: true);
            return;
        }
        catch (Exception ex)
        {
            _saveMessage = "Save failed: " + ex.Message;
        }
        finally
        {
            _settingsBusy = false;
            StateHasChanged();
        }
    }

