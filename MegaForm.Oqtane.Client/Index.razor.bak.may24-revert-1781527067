    private void LoadWorkflowPreview(string workflowJson)
    {
        _workflowPreview = WorkflowPreviewModel.Empty();
        if (string.IsNullOrWhiteSpace(workflowJson))
        {
            return;
        }

        try
        {
            var envelope = WorkflowEnvelope.ParseOrMigrate(workflowJson);
            var definition = envelope?.AppliedWorkflow ?? envelope?.DraftWorkflow;
            if (definition == null || definition.Nodes == null || definition.Nodes.Count == 0)
            {
                return;
            }

        var previewNodes = new List<WorkflowPreviewNode>();
        var laneSequence = new List<string>();
        var maxRight = 0d;
        var maxBottom = 0d;

        for (var i = 0; i < definition.Nodes.Count; i++)
        {
            var node = definition.Nodes[i];
            var left = (node?.Position?.X ?? 0d) + 64d;
            if (left <= 64d)
            {
                left = 84d + (i * 250d);
            }

            var roles = GetWorkflowConfigValues(node?.Config, "candidateRoles", "CandidateRoles");
            var users = GetWorkflowConfigValues(node?.Config, "candidateUsers", "CandidateUsers");
            var laneLabel = ResolveWorkflowLaneLabel(node, roles, users, definition.StartNodeId);
            var laneIndex = laneSequence.FindIndex(l => string.Equals(l, laneLabel, StringComparison.OrdinalIgnoreCase));
            if (laneIndex < 0)
            {
                laneSequence.Add(laneLabel);
                laneIndex = laneSequence.Count - 1;
            }

            var laneTop = 40d + (laneIndex * 224d);
            var top = laneTop + 54d;

            maxRight = Math.Max(maxRight, left + 260d);
            maxBottom = Math.Max(maxBottom, top + 200d);

            var statuses = new List<string>();
            AddWorkflowConfigStatus(statuses, node?.Config, "pendingSubmissionStatus", "PendingSubmissionStatus");
            AddWorkflowConfigStatus(statuses, node?.Config, "approvedSubmissionStatus", "ApprovedSubmissionStatus");
            AddWorkflowConfigStatus(statuses, node?.Config, "rejectedSubmissionStatus", "RejectedSubmissionStatus");

                previewNodes.Add(new WorkflowPreviewNode
                {
                Id = node?.Id ?? ("node-" + i),
                Label = string.IsNullOrWhiteSpace(node?.Label) ? ("Step " + (i + 1)) : node.Label,
                TypeLabel = GetWorkflowNodeTypeLabel(node?.Type ?? WorkflowNodeType.FormField),
                ZoneLabel = laneLabel,
                CssClass = GetWorkflowNodeCssClass(node?.Type ?? WorkflowNodeType.FormField),
                Left = left,
                Top = top,
                    CenterX = left + 110d,
                    CenterY = top + 90d,
                    MetaText = string.IsNullOrWhiteSpace(node?.Id) ? "Runtime step" : ("Node: " + node.Id),
                    RoleAssignments = roles,
                    UserAssignments = users,
                    StatusHints = statuses,
                    Note = BuildWorkflowNodeNote(node, roles, users)
                });
            }

            var nodeLookup = previewNodes.ToDictionary(n => n.Id, n => n, StringComparer.OrdinalIgnoreCase);
            var previewEdges = new List<WorkflowPreviewEdge>();
            foreach (var edge in definition.Edges ?? Enumerable.Empty<WorkflowEdge>())
            {
                if (edge == null ||
                    string.IsNullOrWhiteSpace(edge.SourceNodeId) ||
                    string.IsNullOrWhiteSpace(edge.TargetNodeId) ||
                    !nodeLookup.TryGetValue(edge.SourceNodeId, out var sourceNode) ||
                    !nodeLookup.TryGetValue(edge.TargetNodeId, out var targetNode))
                {
                    continue;
                }

                var x1 = sourceNode.CenterX + 104d;
                var y1 = sourceNode.CenterY;
                var x2 = targetNode.CenterX - 104d;
                var y2 = targetNode.CenterY;
                previewEdges.Add(new WorkflowPreviewEdge
                {
                    SourceId = sourceNode.Id,
                    TargetId = targetNode.Id,
                    Label = edge.Label ?? string.Empty,
                    X1 = x1,
                    Y1 = y1,
                    X2 = x2,
                    Y2 = y2,
                    LabelX = (x1 + x2) / 2d,
                    LabelY = (y1 + y2) / 2d,
                    Color = string.Equals(edge.SourceHandle, "rejected", StringComparison.OrdinalIgnoreCase) ? "#f97316" : "#94a3b8"
                });
            }

        var lanes = new List<WorkflowPreviewLane>();
        for (var laneIndex = 0; laneIndex < laneSequence.Count; laneIndex++)
        {
            var laneLabel = laneSequence[laneIndex];
            lanes.Add(new WorkflowPreviewLane
            {
                Label = laneLabel,
                Top = 40d + (laneIndex * 224d),
                Height = 188d
            });
        }

        if (lanes.Count == 0)
        {
            lanes.Add(new WorkflowPreviewLane { Label = "BPMN 2.0 Process", Top = 40d, Height = Math.Max(320d, maxBottom) });
        }

            var startNode = previewNodes.FirstOrDefault(n => string.Equals(n.Id, definition.StartNodeId, StringComparison.OrdinalIgnoreCase))
                ?? previewNodes.FirstOrDefault();

            _workflowPreview = new WorkflowPreviewModel
            {
                Title = string.IsNullOrWhiteSpace(definition.Name) ? (GetSelectedFormTitle() + " Workflow") : definition.Name,
                VersionText = !string.IsNullOrWhiteSpace(envelope?.AppliedVersion) ? ("Applied " + envelope.AppliedVersion) : (!string.IsNullOrWhiteSpace(definition.Version) ? ("Version " + definition.Version) : string.Empty),
                Nodes = previewNodes,
                Edges = previewEdges,
                Lanes = lanes,
                CanvasWidth = Math.Max(1080d, maxRight + 120d),
                CanvasHeight = Math.Max(540d, Math.Max(maxBottom + 80d, lanes.Max(l => l.Top + l.Height) + 24d)),
                StartNodeLabel = startNode?.Label ?? "Unknown",
                TotalAssignments = previewNodes.Sum(n => n.RoleAssignments.Count + n.UserAssignments.Count)
            };
        }
        catch
        {
            _workflowPreview = WorkflowPreviewModel.Empty();
        }
    }

    private static List<string> GetWorkflowConfigValues(Dictionary<string, object> config, params string[] keys)
    {
        var values = new List<string>();
        if (config == null || keys == null || keys.Length == 0)
        {
            return values;
        }

        foreach (var key in keys)
        {
            var actualKey = config.Keys.FirstOrDefault(k => string.Equals(k, key, StringComparison.OrdinalIgnoreCase));
            if (string.IsNullOrWhiteSpace(actualKey) || !config.TryGetValue(actualKey, out var raw) || raw == null)
            {
                continue;
            }

            if (raw is string text)
            {
                foreach (var item in text.Split(new[] { ',', ';', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
                {
                    var trimmed = item.Trim();
                    if (!string.IsNullOrWhiteSpace(trimmed) && !values.Any(v => string.Equals(v, trimmed, StringComparison.OrdinalIgnoreCase)))
                    {
                        values.Add(trimmed);
                    }
                }
                continue;
            }

            if (raw is System.Collections.IEnumerable seq)
            {
                foreach (var item in seq)
                {
                    var textValue = Convert.ToString(item)?.Trim();
                    if (!string.IsNullOrWhiteSpace(textValue) && !values.Any(v => string.Equals(v, textValue, StringComparison.OrdinalIgnoreCase)))
                    {
                        values.Add(textValue);
                    }
                }
            }
        }

        return values;
    }

    private static void AddWorkflowConfigStatus(List<string> target, Dictionary<string, object> config, params string[] keys)
    {
        if (target == null || config == null)
        {
            return;
        }

        foreach (var key in keys ?? Array.Empty<string>())
        {
            var actualKey = config.Keys.FirstOrDefault(k => string.Equals(k, key, StringComparison.OrdinalIgnoreCase));
            if (string.IsNullOrWhiteSpace(actualKey) || !config.TryGetValue(actualKey, out var raw) || raw == null)
            {
                continue;
            }

            var value = Convert.ToString(raw)?.Trim();
            if (!string.IsNullOrWhiteSpace(value) && !target.Any(v => string.Equals(v, value, StringComparison.OrdinalIgnoreCase)))
            {
                target.Add(value);
            }
        }
    }

