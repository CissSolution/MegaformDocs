    private async Task BuildDashboardAsync()
    {
        try
        {
            var siteId = SiteState?.Alias?.SiteId ?? 0;
            var forms = await MegaFormService.ListFormsAsync(0, siteId) ?? new List<FormDto>();
            forms = forms.OrderByDescending(f => f.UpdatedOnUtc ?? f.CreatedOnUtc).ThenByDescending(f => f.FormId).ToList();

            _dashboardFormsCount = forms.Count;
            _dashboardPublishedCount = forms.Count(f => string.Equals(f.Status, "Published", StringComparison.OrdinalIgnoreCase));

            var recentSubmissions = new List<SubmissionDto>();
            var submissionsTotal = 0;
            foreach (var form in forms.Take(8))
            {
                try
                {
                    var page = await MegaFormService.GetSubmissionsAsync(form.FormId, 0, 6);
                    if (page?.Items != null)
                    {
                        recentSubmissions.AddRange(page.Items);
                        submissionsTotal += page.TotalCount > 0 ? page.TotalCount : page.Items.Count;
                    }
                }
                catch
                {
                }
            }

            _dashboardSubmissionsCount = submissionsTotal;
            _recentForms = forms.Select(f => new DashboardFormRow
            {
                FormId = f.FormId,
                Title = string.IsNullOrWhiteSpace(f.Title) ? $"Form #{f.FormId}" : f.Title,
                Status = string.IsNullOrWhiteSpace(f.Status) ? "Draft" : f.Status,
                ModifiedText = (f.UpdatedOnUtc ?? f.CreatedOnUtc).ToString("yyyy-MM-dd HH:mm")
            }).ToList();
        }
        catch
        {
            _dashboardFormsCount = 0;
            _dashboardPublishedCount = 0;
            _dashboardSubmissionsCount = 0;
            _recentForms = new List<DashboardFormRow>();
        }
    }

