    protected override async Task OnParametersSetAsync()
    {
        var apiBase = "/api/MegaForm/";
        var token = SiteState?.AuthorizationToken ?? string.Empty;
        var tokenJs = string.IsNullOrEmpty(token) ? "null" : $"'{token.Replace("'", "\\'")}'";
        AddHeadContent(
            $"<script>window.__MF_PLATFORM__=window.__MF_PLATFORM__||{{}};" +
            $"window.__MF_PLATFORM__.platform='oqtane';" +
            $"window.__MF_PLATFORM__.apiBase='{apiBase}';" +
            $"window.__MF_PLATFORM__.moduleId={(ModuleState?.ModuleId ?? 0)};" +
            $"window.__MF_PLATFORM__.portalId={(SiteState?.Alias?.SiteId ?? 0)};" +
            $"window.__MF_PLATFORM__.siteId={(SiteState?.Alias?.SiteId ?? 0)};" +
            $"window.__MF_PLATFORM__.pageId={(PageState?.Page?.PageId ?? 0)};" +
            $"window.__MF_PLATFORM__.authToken={tokenJs};" +
            $"</script>");

        _loading = true;
        _isAdmin = UserSecurity.IsAuthorized(PageState.User, PermissionNames.Edit, ModuleState.PermissionList);
        _formId = 0;
        _cssClass = string.Empty;
        _isPublished = false;
        _liveRenderMode = false;
        _embedMode = false;
        _moduleConfigured = false;
        _rendererHostUrl = string.Empty;
        _rendererHostPageId = 0;
        _rendererHostModuleId = 0;
        _moduleViewConfigJson = "{}";
        _saveMessage = string.Empty;
        _activeViewKey = string.Empty;
        _workflowPreview = WorkflowPreviewModel.Empty();

        var currentUri = NavigationManager.Uri ?? string.Empty;
        var requested = GetQueryValue(currentUri, "formid") ?? GetQueryValue(currentUri, "FormId");
        if (!string.IsNullOrWhiteSpace(requested))
        {
            var raw = requested;
            if (!int.TryParse(raw, out _formId))
            {
                var digits = new string(raw.Where(char.IsDigit).ToArray());
                int.TryParse(digits, out _formId);
            }
            _liveRenderMode = _formId > 0;
        }

        var embedRaw = GetQueryValue(currentUri, "embed");
        if (!string.IsNullOrWhiteSpace(embedRaw))
        {
            _embedMode = embedRaw == "1" || string.Equals(embedRaw, "true", StringComparison.OrdinalIgnoreCase) || string.Equals(embedRaw, "yes", StringComparison.OrdinalIgnoreCase);
        }

        if (ModuleState?.Settings != null)
        {
            if (_formId <= 0)
            {
                var legacyFormIdValue = ReadModuleSetting("FormId");
                var prefixedFormIdValue = ReadModuleSetting("MegaForm:FormId");
                var rawFormId = !string.IsNullOrWhiteSpace(prefixedFormIdValue) ? prefixedFormIdValue : legacyFormIdValue;
                if (int.TryParse(rawFormId, out var configuredId))
                {
                    _formId = configuredId;
                }
            }

            _cssClass = ReadModuleSetting("MegaForm:CssClass") ?? ReadModuleSetting("CssClass") ?? string.Empty;
            _moduleViewConfigJson = ReadModuleSetting("MegaForm:ViewConfig") ?? ReadModuleSetting("ViewConfig") ?? "{}";
            _selectedPresetThemeKey = ReadModuleSetting("MegaForm:SelectedThemePresetKey") ?? ReadModuleSetting("SelectedThemePresetKey") ?? string.Empty;
            _moduleConfigured = ReadModuleBool("MegaForm:ModuleConfigured") || ReadModuleBool("ModuleConfigured") || _formId > 0;

            // [ViewDesigner v20260503-06] Parse viewMode + list/card config out of
            // ModuleState.Settings so anonymous visitors AND admins both render the
            // right mount. Previously these fields were only populated inside
            // LoadAdminConfigAsync — meaning anonymous users always saw the form
            // even when the module was set to List/Card view, and even admins
            // would silently fall back to the form if the GetModuleConfigAsync
            // call threw before reaching the viewMode block.
            ApplyViewConfigFromJson(_moduleViewConfigJson);
        }

        var workflowEditRaw = GetQueryValue(currentUri, "wfedit");
        _workflowEditorAutoOpenPending =
            _isAdmin &&
            _formId > 0 &&
            IsWorkflowMapMode &&
            (string.Equals(workflowEditRaw, "1", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(workflowEditRaw, "true", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(workflowEditRaw, "yes", StringComparison.OrdinalIgnoreCase));

        AddPlatformHeadContent();

        if (_isAdmin)
        {
            await LoadAdminConfigAsync();
            await BuildDashboardAsync();
            AddPlatformHeadContent();
        }
        else if (!_liveRenderMode)
        {
            // [OqtaneCanonicalModuleBinding v20260511-06] Non-admin visitors were
            // still reading stale ModuleState.Settings, while admins refreshed the
            // true module binding from ModuleConfig. Result: named views could point
            // at the new form, but generic ?view=form still rendered the previous
            // schema for regular users. Reuse the same canonical ModuleConfig read
            // for authenticated/public visitors and quietly fall back if the host
            // blocks the API.
            try
            {
                await LoadAdminConfigAsync();
                AddPlatformHeadContent();
            }
            catch
            {
                // Keep the stale ModuleState fallback rather than breaking render.
            }
        }

        if (_formId > 0)
        {
            try
            {
                // Keep workflow preview reads under the same ViewModule auth context
                // as the rest of the Oqtane module; otherwise the API may 403 and
                // the BPMN map silently falls back to an empty preview.
                var form = await MegaFormService.GetFormAsync(_formId, ModuleState?.ModuleId ?? 0, GetCurrentSiteId());
                _isPublished = string.Equals(form?.Status, "Published", StringComparison.OrdinalIgnoreCase);
                _initialInlineCss = form?.InitialInlineCss ?? string.Empty;
                LoadWorkflowPreview(form?.WorkflowJson);
            }
            catch
            {
                _isPublished = false;
                _initialInlineCss = string.Empty;
                _workflowPreview = WorkflowPreviewModel.Empty();
            }

            // [OQ-difix20260418-12] Bug F: same Oqtane ServiceBase JSON quirk that
            // emptied response.Forms (Bug D) sometimes leaves FormDto.Status as the
            // C# default "Draft" even when the JSON payload says "status":"Published".
            // Result: orange "This form is not published yet" warning shows for an
            // already-published form.
            //
            // Defense-in-depth:
            //   1. If _forms (loaded by reliable Form/List endpoint via v11-D
            //      fallback) confirms the form exists and is Published → trust it.
            //   2. Otherwise — for non-admin live render — re-query Form/List
            //      directly here (since LoadAdminConfigAsync only ran for admins)
            //      and read the status from there.
            if (!_isPublished)
            {
                FormListItem match = null;
                if (_forms != null && _forms.Count > 0)
                {
                    match = _forms.FirstOrDefault(f => f.FormId == _formId);
                }
                if (match == null)
                {
                    try
                    {
                        var allForms = await MegaFormService.ListFormsAsync(ModuleState.ModuleId, GetCurrentSiteId());
                        if (allForms != null)
                        {
                            var hit = allForms.FirstOrDefault(f => f.FormId == _formId);
                            if (hit != null)
                            {
                                match = new FormListItem { FormId = hit.FormId, Title = hit.Title, Status = hit.Status };
                            }
                        }
                    }
                    catch { /* non-fatal */ }
                }
                if (match != null && string.Equals(match.Status, "Published", StringComparison.OrdinalIgnoreCase))
                {
                    _isPublished = true;
                }
            }
        }

        // [OQ-difix20260420-09] Stash, don't inject. OnAfterRenderAsync will eval
        // via IJSRuntime so the boot script is guaranteed to run even when it's
        // built after async awaits have already ended the current resource pass.
        // [ListViewBootSkip v20260508-04] ONLY run the form-renderer boot when
        // the module is actually in form mode. In list/card/listview mode the
        // page emits a different mount div (data-mf-view="list", data-mf-listview)
        // and the form-renderer boot would wait 10s for `mf-form-{module}-{form}`
        // — which never exists — then log "MegaForm core wait timed out".
        if (_formId > 0 && _isPublished && !_embedMode && IsFormMode)
        {
            _pendingRendererBoot = BuildRendererBootScript();
            _rendererBootExecuted = false;
        }
        else
        {
            _pendingRendererBoot = string.Empty;
        }

        EnsureStarterRoleSelection();
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Oqtane ModuleBase injects ResourceType.Script entries here on first render.
        // If we short-circuit and skip base.OnAfterRenderAsync, the live renderer core
        // files declared in Resources never reach the page, leaving MegaFormRenderer undefined.
        await base.OnAfterRenderAsync(firstRender);

        // [OQ-difix20260420-09] Run the stashed renderer boot once the mount div is
        // guaranteed in the DOM. Eval gives us the same "inline <script>" semantics
        // UpsertModuleInlineScript was supposed to produce, minus the timing hazard.
        if (!_rendererBootExecuted && !string.IsNullOrEmpty(_pendingRendererBoot))
        {
            _rendererBootExecuted = true;
            try
            {
                await Js.InvokeVoidAsync("eval", _pendingRendererBoot);
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"MegaForm: renderer boot eval failed: {ex.Message}");
            }
        }

        // [BrowseViewAutoMount v20260509-06] Oqtane/Blazor can render the
        // browse-mode mount divs after the JS bundles have already passed their
        // DOMContentLoaded auto-bind. Nudge all browse renderers after every
        // render so list/card/listview surfaces re-mount even if the host swaps
        // or re-creates their nodes late.
        try
        {
            await Js.InvokeVoidAsync("eval", @"
(function(){
  try { if (window.MFListViewRebind) window.MFListViewRebind(); } catch {}
  try { if (window.MFSubmissionListRebind) window.MFSubmissionListRebind(); } catch {}
  try { if (window.MFSubmissionCardRebind) window.MFSubmissionCardRebind(); } catch {}
  try {
    var root = document.getElementById('mf-dnn-tasks-root');
    if (root && window.MegaForm && window.MegaForm.initWorkflowInbox) {
      window.MegaForm.initWorkflowInbox(root);
    }
  } catch {}
})();
");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"MegaForm: browse rebind eval failed: {ex.Message}");
        }

        if (_workflowEditorAutoOpenPending)
        {
            _workflowEditorAutoOpenPending = false;
            try
            {
                await OpenWorkflowEditorAsync();
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"MegaForm: workflow editor launch failed: {ex.Message}");
            }
        }
    }

    private async Task LoadAdminConfigAsync()
    {
        try
        {
            var response = await MegaFormService.GetModuleConfigAsync(ModuleState.ModuleId, GetCurrentSiteId());
            _forms = response?.Forms ?? new List<FormListItem>();

            // [OQ-difix20260418-11] Bug D fix: response.Forms occasionally arrives
            // empty even when the API returned forms (deserialization quirk in
            // Oqtane's ServiceBase). Fall back to ListFormsAsync — the dedicated
            // Form/List endpoint that we know returns the full list reliably.
            // Result: the "Module form" dropdown is always populated when the DB
            // has forms.
            if (_forms.Count == 0)
            {
                try
                {
                    var allForms = await MegaFormService.ListFormsAsync(ModuleState.ModuleId, GetCurrentSiteId());
                    if (allForms != null && allForms.Count > 0)
                    {
                        _forms = allForms.Select(f => new FormListItem
                        {
                            FormId = f.FormId,
                            Title  = string.IsNullOrWhiteSpace(f.Title) ? $"Form #{f.FormId}" : f.Title,
                            Status = string.IsNullOrWhiteSpace(f.Status) ? "Draft" : f.Status,
                        }).ToList();
                    }
                }
                catch
                {
                    // Non-fatal — dropdown stays with the "-- Select a Form --" placeholder.
                }
            }

            // [OQ-fixedrender v20260420-01] In page render mode, trust the
            // ModuleConfig API as the canonical module binding source instead of the
            // potentially stale ModuleState.Settings snapshot. This keeps the current
            // page's fixed form in sync immediately after Save Module Settings.
            if (!_liveRenderMode && response?.Config != null)
            {
                _formId = response.Config.FormId > 0 ? response.Config.FormId : 0;
            }
            else if (_formId <= 0 && response?.Config != null && response.Config.FormId > 0)
            {
                _formId = response.Config.FormId;
            }

            if (response?.Config != null)
            {
                _moduleViewConfigJson = string.IsNullOrWhiteSpace(response.Config.ViewConfig) ? _moduleViewConfigJson : response.Config.ViewConfig;
                _cssClass = string.IsNullOrWhiteSpace(response.Config.CssClass) ? _cssClass : response.Config.CssClass;
                _moduleConfigured = response.Config.ModuleConfigured || response.Config.FormId > 0 || _moduleConfigured;
                _displayMode = string.Equals(response.Config.DisplayMode, "popup", StringComparison.OrdinalIgnoreCase) ? "popup" : "fixed";
                _triggerType = NormalizeTriggerType(response.Config.TriggerType);
                _delaySeconds = response.Config.DelaySeconds > 0 ? response.Config.DelaySeconds : 5;
                _scrollPercent = response.Config.ScrollPercent > 0 ? response.Config.ScrollPercent : 50;
                _clickSelector = response.Config.ClickSelector ?? string.Empty;
                _showOncePerSession = response.Config.ShowOncePerSession;
                _closeOnOverlay = response.Config.CloseOnOverlay;
                _startAt = response.Config.StartAt ?? string.Empty;
                _endAt = response.Config.EndAt ?? string.Empty;
                // [SubmissionViews v20260503-01] + [ListViewRouting v20260507-23]
                var vm = (response.Config.ViewMode ?? string.Empty).Trim().ToLowerInvariant();
                _viewMode = (vm == "list" || vm == "card" || vm == "listview") ? vm : "form";
                _listFields = response.Config.ListFields ?? string.Empty;
                _listTemplate = response.Config.ListTemplate ?? string.Empty;
                _cardFields = response.Config.CardFields ?? string.Empty;
                _cardTemplate = response.Config.CardTemplate ?? string.Empty;
                ApplyViewConfigFromJson(_moduleViewConfigJson);
            }

            _rendererHostUrl = response?.RendererHostUrl ?? string.Empty;
            _rendererHostPageId = response?.RendererHostPageId ?? 0;
            _rendererHostModuleId = response?.RendererHostModuleId ?? 0;
            _useThisPageAsRendererHost = IsCurrentPageRendererHost();
        }
        catch
        {
            _forms = new List<FormListItem>();
        }
    }

    private async Task SaveManagePanelAsync()
    {
