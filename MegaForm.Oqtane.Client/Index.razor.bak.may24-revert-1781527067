            ScrollPercent = Math.Clamp(_scrollPercent <= 0 ? 50 : _scrollPercent, 5, 95),
            ClickSelector = (_clickSelector ?? string.Empty).Trim(),
            ShowOncePerSession = _showOncePerSession,
            CloseOnOverlay = _closeOnOverlay,
            StartAt = _startAt ?? string.Empty,
            EndAt = _endAt ?? string.Empty,
            UseCurrentPageAsRendererHost = _useThisPageAsRendererHost,
            CurrentPageUrl = GetCurrentPageRendererHostUrl(),
            CurrentPageId = PageState?.Page?.PageId ?? 0
        };

        await MegaFormService.SaveModuleConfigAsync(config, GetCurrentSiteId());
        _moduleConfigured = true;
        _saveMessage = "Module settings saved.";
        NavigationManager.NavigateTo(NavigationManager.Uri, true);
