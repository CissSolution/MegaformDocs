                                                    }
                                                </div>
                                            </div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(node.Note))
                                        {
                                            <div class="mf-flow-note">@node.Note</div>
                                        }
                                    </article>
                                }
                            </div>
                        </div>
                    </section>

                    <aside class="mf-flow-side-card">
                        <div class="mf-flow-side-block">
                            <h4>Assignment Rules</h4>
                            <div class="mf-flow-list">
                                @foreach (var node in _workflowPreview.Nodes.Where(n => n.RoleAssignments.Count > 0 || n.UserAssignments.Count > 0))
                                {
                                    <div class="mf-flow-list-item">
                                        <div class="mf-flow-list-item-title">@node.Label</div>
                                        <div class="mf-flow-list-item-meta">
                                            Roles: @(node.RoleAssignments.Count > 0 ? string.Join(", ", node.RoleAssignments) : "None")<br />
                                            Users: @(node.UserAssignments.Count > 0 ? string.Join(", ", node.UserAssignments) : "None")
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="mf-flow-side-block">
                            <h4>How To Change It</h4>
                            <div class="mf-flow-list-item">
                                <div class="mf-flow-list-item-title">Open Builder</div>
                                <div class="mf-flow-list-item-meta">The same executable workflow definition drives this BPMN 2.0 map, the inbox, and runtime routing. Change user tasks, service tasks, sequence flow, candidate roles, candidate users, claim rules, and status mapping in Builder, then return here to QA the updated process.</div>
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        }
        else if (IsListViewMode)
        {
            @* [ListViewRouting v20260507-23] NEW dedicated ListView module —
               own bundle (megaform-listview.js), own designer, own CSS.
               Emit the mount div with data-attrs the runtime auto-binds on
               (matches MegaForm.Core.ViewModes.ListViewSettings.BuildMountHtml
               byte-for-byte; kept inline here so this Razor project doesn't
               need a hard reference on MegaForm.Core). *@
            <div data-mf-listview="1"
                 data-mf-form-id="@_listViewFormId"
                 data-mf-api-base="/api/MegaForm/"
                 data-mf-module-id="@(ModuleState?.ModuleId ?? 0)"
                 data-mf-fields-json="@_listViewFieldsJson"
                 data-mf-row-template="@_listViewRowTemplate"
                 data-mf-detail-template="@_listViewDetailTemplate"
                 data-mf-wrapper-template="@_listViewWrapperTemplate"
                 data-mf-page-size="@_listViewPageSize"
                 data-mf-search="@(_listViewEnableSearch ? "true" : "false")"
                 data-mf-sort="@(_listViewEnableSort ? "true" : "false")"
                 data-mf-show-add="@(_listViewShowAddButton ? "true" : "false")"
                 data-mf-show-actions="@(_listViewShowRowActions ? "true" : "false")"
                 data-mf-renderer-host-url="@_rendererHostUrl"
                 data-mf-title="@_listViewTitle"
                 data-mf-empty-message="@_listViewEmptyMessage"
                 data-mf-query-key="@_activeQueryKey"
                 data-mf-context-json="@BuildTemplateContextJson()"
                 data-mf-listview-badge="ListViewSettings v20260524-01"
                 data-mf-debug-wraplen="@(_listViewWrapperTemplate?.Length ?? 0)"
                 data-mf-debug-rowlen="@(_listViewRowTemplate?.Length ?? 0)"
                 data-mf-debug-actvk="@_activeViewKey"></div>
        }
        else if (IsListMode)
        {
            @* [SubmissionViews v20260503-01] List bundle (megaform-submission-list.js)
               auto-binds any element with data-mf-view="list" on DOMContentLoaded
               and fetches /api/MegaForm/Submissions?formId=N. *@
            <div id="@FormMountId"
                 data-mf-view="list"
                 data-mf-form-id="@_formId"
                 data-mf-api-base="/api/MegaForm/"
                 data-mf-fields="@_listFields"
                 data-mf-template="@_listTemplate"
                 data-mf-query-key="@_activeQueryKey"
                 data-mf-context-json="@BuildTemplateContextJson()"
                 data-form-id="@_formId"
                 data-module-id="@(ModuleState?.ModuleId ?? 0)">
            </div>
        }
        else if (IsCardMode)
        {
            @* [SubmissionViews v20260503-01] Card bundle (megaform-submission-card.js). *@
            <div id="@FormMountId"
                 data-mf-view="card"
                 data-mf-form-id="@_formId"
                 data-mf-api-base="/api/MegaForm/"
                 data-mf-fields="@_cardFields"
                 data-mf-template="@_cardTemplate"
                 data-mf-query-key="@_activeQueryKey"
                 data-mf-context-json="@BuildTemplateContextJson()"
                 data-form-id="@_formId"
                 data-module-id="@(ModuleState?.ModuleId ?? 0)">
            </div>
        }
        else
        {
            <div id="@FormMountId"
                 data-form-id="@_formId"
                 data-module-id="@(ModuleState?.ModuleId ?? 0)">
            </div>
        }
    </div>
}

@code {
    protected new string ModulePath() => "Modules/MegaForm/";
    // [SignaturePlaceholder v20260502-07] bumped to force browsers to fetch the
    // updated megaform-renderer.js (adds .mf-signature-placeholder hint) and
    // related canonical bundles. Bump this whenever any of the 5 Resources
    // below changes server-side, OR a renderer fix needs to defeat browser
    // cache on the public form view.
    private const string OqtaneCoreAssetVersion = "20260524-01";
    private const string WorkflowBuilderAssetVersion = "20260512-04";

    public override List<Resource> Resources => new()
    {
        new Resource { ResourceType = ResourceType.Stylesheet, Url = "https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" },
        new Resource { ResourceType = ResourceType.Stylesheet, Url = "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" },
        new Resource { ResourceType = ResourceType.Stylesheet, Url = ModulePath() + "css/megaform.css" },
        new Resource { ResourceType = ResourceType.Stylesheet, Url = ModulePath() + "css/megaform-widgets.css" },
        new Resource { ResourceType = ResourceType.Stylesheet, Url = ModulePath() + "css/megaform-themes.css" },
        new Resource { ResourceType = ResourceType.Stylesheet, Url = ModulePath() + "css/plugins/megaform-widgets-builtin.css?v=20260404-05" },
        new Resource { ResourceType = ResourceType.Stylesheet, Url = ModulePath() + "css/megaform-admin-shell.css" },
        // [OQ-livecore v20260420-04] Load the 5 canonical root JS files in the
        // same dependency order the live renderer expects. Previously Oqtane only
        // registered widgets/rule-engine/renderer here and relied on Js.InvokeVoidAsync("eval", ...)
        // in OnAfterRenderAsync to lazy-load config+i18n+remaining files. When that
        // eval path did not run, the page had a mount div but MegaFormRenderer stayed undefined.
        new Resource { ResourceType = ResourceType.Script, Url = ModulePath() + $"js/megaform-config.js?v={OqtaneCoreAssetVersion}", Location = ResourceLocation.Body },
        new Resource { ResourceType = ResourceType.Script, Url = ModulePath() + $"js/megaform-i18n.js?v={OqtaneCoreAssetVersion}", Location = ResourceLocation.Body },
        new Resource { ResourceType = ResourceType.Script, Url = ModulePath() + $"js/megaform-widgets.js?v={OqtaneCoreAssetVersion}", Location = ResourceLocation.Body },
        new Resource { ResourceType = ResourceType.Script, Url = ModulePath() + "js/plugins/types.js", Location = ResourceLocation.Body },
        new Resource { ResourceType = ResourceType.Script, Url = ModulePath() + $"js/megaform-rule-engine.js?v={OqtaneCoreAssetVersion}", Location = ResourceLocation.Body },
        new Resource { ResourceType = ResourceType.Script, Url = ModulePath() + $"js/megaform-renderer.js?v={OqtaneCoreAssetVersion}", Location = ResourceLocation.Body },
