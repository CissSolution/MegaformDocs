                                {
                                    <div class="mf-flow-lane" style="top:@($"{lane.Top}px");height:@($"{lane.Height}px")">
                                        <div class="mf-flow-lane-label">@lane.Label</div>
                                    </div>
                                }
                                <svg class="mf-flow-svg" width="@_workflowPreview.CanvasWidth" height="@_workflowPreview.CanvasHeight" viewBox="@($"0 0 {_workflowPreview.CanvasWidth} {_workflowPreview.CanvasHeight}")" preserveAspectRatio="none">
                                    <defs>
                                        <marker id="mf-flow-arrow" markerWidth="12" markerHeight="12" refX="10" refY="6" orient="auto">
                                            <path d="M0,0 L12,6 L0,12 z" fill="#94a3b8"></path>
                                        </marker>
                                    </defs>
                                    @foreach (var edge in _workflowPreview.Edges)
                                    {
                                        <line x1="@edge.X1" y1="@edge.Y1" x2="@edge.X2" y2="@edge.Y2" stroke="@edge.Color" stroke-width="3" marker-end="url(#mf-flow-arrow)"></line>
                                    }
                                </svg>
                                @foreach (var edge in _workflowPreview.Edges.Where(e => !string.IsNullOrWhiteSpace(e.Label)))
                                {
                                    <div class="mf-flow-pill" style="position:absolute;left:@($"{edge.LabelX - 36}px");top:@($"{edge.LabelY - 14}px");background:#ffffff;box-shadow:0 10px 24px rgba(15,23,42,.08)">
                                        @edge.Label
                                    </div>
                                }
                                @foreach (var node in _workflowPreview.Nodes)
                                {
                                    <article class="mf-flow-node @node.CssClass" style="left:@($"{node.Left}px");top:@($"{node.Top}px")">
                                        <div class="mf-flow-node-top">
                                            <span class="mf-flow-node-type">@node.TypeLabel</span>
                                            <span class="mf-flow-node-zone">@node.ZoneLabel</span>
                                        </div>
                                        <h4 class="mf-flow-node-title">@node.Label</h4>
                                        <div class="mf-flow-node-id">@node.MetaText</div>
                                        @if (node.RoleAssignments.Count > 0)
                                        {
                                            <div class="mf-flow-node-meta">
                                                <div class="mf-flow-node-label">Role assignments</div>
                                                <div class="mf-flow-pillrow">
                                                    @foreach (var role in node.RoleAssignments)
                                                    {
                                                        <span class="mf-flow-pill is-role"><i class="fas fa-user-tag"></i> @role</span>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        @if (node.UserAssignments.Count > 0)
                                        {
                                            <div class="mf-flow-node-meta">
                                                <div class="mf-flow-node-label">User assignments</div>
                                                <div class="mf-flow-pillrow">
                                                    @foreach (var user in node.UserAssignments)
