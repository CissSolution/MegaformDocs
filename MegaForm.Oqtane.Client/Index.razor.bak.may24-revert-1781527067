@namespace MegaForm.Client
@inherits ModuleBase
@inject IMegaFormService MegaFormService
@inject NavigationManager NavigationManager
@inject IJSRuntime Js
@using System
@using System.Collections.Generic
@using System.Linq
@using System.Text.Json
@using MegaForm.Core.Models
@using MegaForm.Core.Workflow
@using MegaForm.Core.ViewModes
@using MegaForm.Oqtane.Shared.Models

@if (_isAdmin && !_liveRenderMode)
{
    <style>
        .mf-oq-admin-dock{display:flex;gap:8px;align-items:center;justify-content:flex-end;margin:0 0 12px;flex-wrap:wrap;font-family:'Inter',system-ui,sans-serif;}
        .mf-oq-pill,.mf-oq-btn,.mf-oq-linkbtn{border:1px solid #dbe4f0;background:#fff;color:#0f172a;border-radius:999px;padding:8px 14px;font-size:13px;font-weight:600;line-height:1;text-decoration:none;display:inline-flex;align-items:center;gap:8px;box-shadow:0 8px 20px rgba(15,23,42,.06);cursor:pointer;}
        .mf-oq-pill{background:linear-gradient(180deg,#eff6ff 0%,#ffffff 100%);color:#2563eb;border-color:#bfdbfe;}
        .mf-oq-btn.is-primary,.mf-oq-linkbtn.is-primary{background:#0f172a;color:#fff;border-color:#0f172a;}
        .mf-oq-panel{margin:0 0 14px;padding:18px;border:1px solid #dbe4f0;border-radius:20px;background:#fff;box-shadow:0 14px 40px rgba(15,23,42,.05);font-family:'Inter',system-ui,sans-serif;}
        .mf-oq-panel h3{margin:0 0 8px;font-size:16px;font-weight:700;color:#0f172a;display:flex;align-items:center;gap:10px;}
        .mf-oq-panel .mf-oq-help{color:#475569;font-size:13px;line-height:1.6;margin:0 0 14px;}
        .mf-oq-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;}
        .mf-oq-card{border:1px solid #dbe4f0;border-radius:18px;background:#f8fafc;padding:16px;}
        .mf-oq-card-title{font-size:12px;color:#64748b;text-transform:uppercase;letter-spacing:.04em;margin:0 0 6px;}
        .mf-oq-card-value{font-size:18px;font-weight:700;color:#0f172a;margin:0 0 4px;}
        .mf-oq-card-meta{font-size:13px;color:#475569;line-height:1.5;}
        .mf-oq-formgrid{display:grid;grid-template-columns:220px minmax(0,1fr);gap:12px 16px;align-items:center;margin-top:12px;}
        .mf-oq-formgrid label{font-size:13px;font-weight:600;color:#0f172a;}
        .mf-oq-formgrid select,.mf-oq-formgrid input[type='text'],.mf-oq-formgrid input[type='number']{width:100%;border:1px solid #cbd5e1;border-radius:12px;padding:10px 12px;font-size:14px;background:#fff;}
        .mf-oq-inline-check{display:flex;align-items:center;gap:10px;font-size:14px;color:#0f172a;}
        .mf-oq-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px;}
        .mf-oq-note{margin-top:16px;padding:12px 14px;border-radius:14px;background:#eef6ff;color:#1d4ed8;font-size:13px;line-height:1.6;}
        .mf-oq-list{margin:14px 0 0;padding:0;list-style:none;display:grid;gap:10px;}
        .mf-oq-list li{display:flex;justify-content:space-between;gap:12px;align-items:center;padding:12px 14px;border:1px solid #e2e8f0;border-radius:14px;background:#fff;}
        .mf-oq-list-main{min-width:0;}
        .mf-oq-list-title{font-size:14px;font-weight:600;color:#0f172a;margin:0 0 2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
        .mf-oq-list-meta{font-size:12px;color:#64748b;}
        .mf-oq-status{display:inline-flex;align-items:center;border-radius:999px;padding:4px 10px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;}
        .mf-oq-status.is-published{background:#dcfce7;color:#166534;}
        .mf-oq-status.is-draft{background:#fef3c7;color:#92400e;}
        .mf-oq-saved{margin:0 0 12px;padding:10px 12px;border-radius:12px;background:#ecfdf5;color:#166534;font-size:13px;font-weight:600;}
        @@media (max-width: 900px){.mf-oq-grid{grid-template-columns:1fr;}.mf-oq-formgrid{grid-template-columns:1fr;}}
    </style>

    @* [ViewDesigner v20260503-02] Inline settings panel removed in favour of
       a single cross-platform popup. The orchestrator (megaform-settings-popup.js)
       drives view-mode + form selection, and lazy-loads the List/Card designers
       on demand so the inline panel logic doesn't have to be duplicated here,
       in MegaForm.Oqtane.Client/Settings.razor, in DNN, or in Web. *@
    <div class="mf-oq-admin-dock">
        <span class="mf-oq-pill"><i class="fas @(_isRendererHostModule ? "fa-circle-check" : "fa-eye")"></i> @(_isRendererHostModule ? "Renderer Host" : "Render Module")</span>
        <button type="button" class="mf-oq-btn is-primary" @onclick="OpenSettingsPopupAsync"><i class="fas fa-sliders-h"></i> Settings</button>
        <button type="button" class="mf-oq-btn" @onclick="ToggleStarterPanel"><i class="fas fa-rocket"></i> Business Starters</button>
        <button type="button" class="mf-oq-btn" id="mf-oq-theme-preset-save" style="display:none;"><i class="fas fa-palette"></i> Update Theme</button>
        <a href="@BuildBuilderUrl()" class="mf-oq-linkbtn"><i class="fas fa-pen-ruler"></i> Form Builder</a>
        <a href="@BuildDashboardUrl()" class="mf-oq-linkbtn" data-mf-shared-dashboard-badge="OQDashboardLink v20260429-01"><i class="fas fa-table-columns"></i> Form Dashboard</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(_saveMessage))
    {
        <div class="mf-oq-saved">@_saveMessage</div>
    }

    @if (_showStarterPanel)
    {
        <div class="mf-oq-panel">
            <h3><i class="fas fa-rocket"></i> Business App Starters</h3>
            <p class="mf-oq-help">Bootstrap a full sample app into this module with forms, named views, queries, roles, users, workflow, and sample data. The page will hard refresh after setup so the current module immediately switches to the new starter.</p>

            <div class="mf-oq-grid">
                <div class="mf-oq-card">
                    <div class="mf-oq-card-title">Starter App</div>
                    <div class="mf-oq-card-value">Leave Request</div>
                    <div class="mf-oq-card-meta">Employee -> manager -> HR flow with boards, inbox, register, and printable business-ready sample data.</div>
                    <div class="mf-oq-actions">
                        <button type="button" class="mf-oq-btn is-primary" disabled="@_starterBusy" @onclick='() => RunStarterSetupAsync("leave")'><i class="fas fa-person-walking-luggage"></i> Launch Leave Request</button>
                    </div>
                </div>
                <div class="mf-oq-card">
                    <div class="mf-oq-card-title">Starter App</div>
                    <div class="mf-oq-card-value">Proposal</div>
                    <div class="mf-oq-card-meta">Requester -> manager -> finance approval path with proposal register, card view, review board, and seeded demo users.</div>
                    <div class="mf-oq-actions">
                        <button type="button" class="mf-oq-btn is-primary" disabled="@_starterBusy" @onclick='() => RunStarterSetupAsync("proposal")'><i class="fas fa-file-signature"></i> Launch Proposal</button>
                    </div>
                </div>
                <div class="mf-oq-card">
                    <div class="mf-oq-card-title">Starter App</div>
                    <div class="mf-oq-card-value">Document Exchange</div>
                    <div class="mf-oq-card-meta">Submitter -> department -> records routing with register, routing board, records board, card view, and sample registry data.</div>
                    <div class="mf-oq-actions">
                        <button type="button" class="mf-oq-btn is-primary" disabled="@_starterBusy" @onclick='() => RunStarterSetupAsync("documents")'><i class="fas fa-folder-tree"></i> Launch Document Exchange</button>
                    </div>
                </div>
                <div class="mf-oq-card">
                    <div class="mf-oq-card-title">Starter App</div>
                    <div class="mf-oq-card-value">Blog Publishing</div>
                    <div class="mf-oq-card-meta">Full content app with public views, rich posts, media, SEO/social metadata, legal review, calendar, feed, archive, and seeded lifecycle data.</div>
                    <div class="mf-oq-actions">
                        <button type="button" class="mf-oq-btn is-primary" disabled="@_starterBusy" @onclick='() => RunStarterSetupAsync("blog")'><i class="fas fa-newspaper"></i> Launch Blog</button>
                    </div>
                </div>
            </div>

            @if (_starterBusy)
            {
                <div class="mf-oq-note">Provisioning starter app and rebinding the current module. The page will refresh automatically when the setup finishes.</div>
            }

            <div class="mf-oq-actions">
                <button type="button" class="mf-oq-btn" @onclick="ClosePanels"><i class="fas fa-times"></i> Close</button>
            </div>
        </div>
    }

    @if (_showDashboardPanel)
    {
        <div class="mf-oq-panel">
            <h3><i class="fas fa-table-columns"></i> MegaForm Dashboard</h3>
            <p class="mf-oq-help">Quick Oqtane-safe dashboard for this site. It stays inside the current Blazor page so the circuit does not break.</p>

            <div class="mf-oq-grid">
                <div class="mf-oq-card">
                    <div class="mf-oq-card-title">Total Forms</div>
                    <div class="mf-oq-card-value">@_dashboardFormsCount</div>
                    <div class="mf-oq-card-meta">@_dashboardPublishedCount published</div>
                </div>
                <div class="mf-oq-card">
                    <div class="mf-oq-card-title">Submissions</div>
                    <div class="mf-oq-card-value">@_dashboardSubmissionsCount</div>
                    <div class="mf-oq-card-meta">Recent responses across this site</div>
                </div>
                <div class="mf-oq-card">
                    <div class="mf-oq-card-title">Current Form</div>
                    <div class="mf-oq-card-value">@GetSelectedFormTitle()</div>
                    <div class="mf-oq-card-meta">@(_formId > 0 ? GetSelectedFormStatus() : "No form bound to this module yet")</div>
                </div>
            </div>

            <ul class="mf-oq-list">
                @foreach (var item in _recentForms.Take(6))
                {
                    <li>
                        <div class="mf-oq-list-main">
                            <div class="mf-oq-list-title">@item.Title</div>
                            <div class="mf-oq-list-meta">ID @item.FormId · @item.ModifiedText</div>
                        </div>
                        <div>
                            <span class="mf-oq-status @(string.Equals(item.Status, "Published", StringComparison.OrdinalIgnoreCase) ? "is-published" : "is-draft")">@(string.IsNullOrWhiteSpace(item.Status) ? "Draft" : item.Status)</span>
                        </div>
                    </li>
                }
            </ul>

            <div class="mf-oq-actions">
                <button type="button" class="mf-oq-btn" @onclick="OpenSettingsPopupAsync"><i class="fas fa-sliders-h"></i> Module Settings</button>
                <a href="@BuildBuilderUrl()" class="mf-oq-linkbtn"><i class="fas fa-pen-ruler"></i> Open Builder</a>
                <a href="@BuildSubmissionsUrl()" class="mf-oq-linkbtn"><i class="fas fa-inbox"></i> View Submissions</a>
                <button type="button" class="mf-oq-btn" @onclick="ClosePanels"><i class="fas fa-times"></i> Close</button>
            </div>
        </div>
    }
}

@if (ShowStarterQaDock)
{
    var starterProfile = GetStarterQaProfile();
    var starterRoleOptions = starterProfile?.Roles ?? new List<StarterQaRoleOption>();
    var starterSurfaceLinks = starterProfile?.SurfaceLinks ?? new List<StarterQaSurfaceLink>();

    <style>
        .mf-qa-panel{margin:0 0 14px;padding:16px 18px;border:1px solid #dbe4f0;border-radius:18px;background:linear-gradient(180deg,#ffffff 0%,#f8fbff 100%);box-shadow:0 14px 38px rgba(15,23,42,.05);font-family:'Inter',system-ui,sans-serif;}
        .mf-qa-head{display:flex;justify-content:space-between;gap:16px;align-items:flex-start;flex-wrap:wrap;margin-bottom:14px;}
        .mf-qa-title{margin:0;font-size:16px;font-weight:800;color:#0f172a;display:flex;align-items:center;gap:10px;}
        .mf-qa-sub{margin:6px 0 0;font-size:13px;line-height:1.6;color:#475569;max-width:840px;}
        .mf-qa-badge{display:inline-flex;align-items:center;padding:5px 10px;border-radius:999px;background:#eff6ff;color:#2563eb;border:1px solid #bfdbfe;font-size:11px;font-weight:800;letter-spacing:.04em;text-transform:uppercase;}
        .mf-qa-grid{display:grid;grid-template-columns:minmax(0,1.2fr) minmax(260px,.8fr);gap:14px;}
        .mf-qa-card{border:1px solid #dbe4f0;border-radius:16px;background:#fff;padding:14px 16px;}
        .mf-qa-card h4{margin:0 0 6px;font-size:13px;font-weight:800;color:#0f172a;text-transform:uppercase;letter-spacing:.04em;}
        .mf-qa-meta{font-size:13px;color:#475569;line-height:1.6;}
        .mf-qa-meta strong{color:#0f172a;}
        .mf-qa-form{display:grid;grid-template-columns:180px minmax(0,1fr);gap:10px 14px;align-items:center;margin-top:12px;}
        .mf-qa-form label{font-size:13px;font-weight:700;color:#0f172a;}
        .mf-qa-form select{width:100%;border:1px solid #cbd5e1;border-radius:12px;padding:10px 12px;font-size:14px;background:#fff;color:#0f172a;}
        .mf-qa-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px;}
        .mf-qa-btn,.mf-qa-link{border:1px solid #dbe4f0;background:#fff;color:#0f172a;border-radius:999px;padding:9px 14px;font-size:13px;font-weight:700;line-height:1;text-decoration:none;display:inline-flex;align-items:center;gap:8px;cursor:pointer;box-shadow:0 8px 20px rgba(15,23,42,.05);}
        .mf-qa-btn.is-primary{background:#0f172a;color:#fff;border-color:#0f172a;}
        .mf-qa-btn[disabled]{opacity:.6;cursor:not-allowed;}
        .mf-qa-links{display:flex;flex-wrap:wrap;gap:10px;margin-top:12px;}
        .mf-qa-link.is-recommended{background:#eff6ff;border-color:#bfdbfe;color:#1d4ed8;}
        .mf-qa-note{margin-top:12px;padding:10px 12px;border-radius:12px;background:#f8fafc;color:#475569;font-size:12px;line-height:1.6;border:1px dashed #cbd5e1;}
        .mf-qa-help{margin-top:12px;padding:12px 14px;border-radius:14px;background:#eef6ff;color:#1d4ed8;font-size:13px;line-height:1.6;}
        @@media (max-width: 900px){.mf-qa-grid{grid-template-columns:1fr;}.mf-qa-form{grid-template-columns:1fr;}}
    </style>

    <div class="mf-qa-panel" data-mf-role-switch-badge="RoleSwitch v20260511-01">
        <div class="mf-qa-head">
            <div>
                <h3 class="mf-qa-title"><i class="fas fa-user-gear"></i> Starter Role QA Switcher</h3>
                <p class="mf-qa-sub">Chuyển nhanh giữa các role mẫu của starter app đang mở và nhảy thẳng vào surface phù hợp để QA quyền, dữ liệu, view, và workflow theo từng vai trò.</p>
            </div>
            <span class="mf-qa-badge">RoleSwitch v20260511-01</span>
        </div>

        <div class="mf-qa-grid">
            <div class="mf-qa-card">
                <h4>Current App</h4>
                <div class="mf-qa-meta">
                    <strong>@(starterProfile?.DisplayName ?? "Starter App")</strong><br />
                    Form: @GetSelectedFormTitle()<br />
                    Current user: @(string.IsNullOrWhiteSpace(GetCurrentUserName()) ? "Anonymous" : GetCurrentUserName())<br />
                    Current role target: @GetCurrentStarterRoleLabel()
                </div>

                <div class="mf-qa-form">
                    <label for="mf-qa-role-select">Switch to role</label>
                    <select id="mf-qa-role-select" @bind="_selectedStarterRoleUserName">
                        @foreach (var role in starterRoleOptions)
                        {
                            <option value="@role.UserName">@role.DisplayName - @role.Description</option>
                        }
                    </select>
                </div>

                <div class="mf-qa-actions">
                    <button type="button" class="mf-qa-btn is-primary" disabled="@_starterRoleBusy" @onclick="SwitchStarterRoleAsync">
                        <i class="fas @(_starterRoleBusy ? "fa-spinner fa-spin" : "fa-right-left")"></i>
                        @(_starterRoleBusy ? "Switching role..." : "Switch Role")
                    </button>
                    <a class="mf-qa-link" href="/login?returnurl=%2Fbusiness">
                        <i class="fas fa-arrow-right-to-bracket"></i> Login Page
                    </a>
                </div>

                <div class="mf-qa-note">Host không nằm trong dropdown để tránh auto-login tài khoản quản trị. Khi cần quay lại host, dùng <strong>Login Page</strong>.</div>
            </div>

            <div class="mf-qa-card">
                <h4>QA / Admin Surfaces</h4>
                <div class="mf-qa-meta">Các link này giữ nguyên app hiện tại nhưng cho bạn nhảy nhanh qua từng surface để QA visual, dữ liệu, token, và workflow.</div>
                <div class="mf-qa-links">
                    @foreach (var link in starterSurfaceLinks)
                    {
                        <a class="mf-qa-link @(link.IsRecommended ? "is-recommended" : null)" href="@link.Url">
                            <i class="fas @link.Icon"></i> @link.Label
                        </a>
                    }
                </div>
                <div class="mf-qa-help">Gợi ý: bắt đầu bằng role requester/employee/submitter, sau đó đổi sang manager/reviewer, cuối cùng sang finance/records hoặc HR để kiểm toàn bộ vòng đời của app.</div>
            </div>
        </div>
    </div>
}

@if (IsWorkflowMapMode && _workflowPreview != null && _workflowPreview.Nodes.Count > 0)
{
    <style>
        .mf-flow-shell{display:grid;gap:18px;font-family:'Inter',system-ui,sans-serif;}
        .mf-flow-hero{display:grid;gap:14px;padding:22px 24px;border:1px solid #bfdbfe;border-radius:24px;background:linear-gradient(135deg,#eff6ff 0%,#ffffff 55%,#f8fafc 100%);box-shadow:0 18px 42px rgba(15,23,42,.08);}
        .mf-flow-hero-main{display:flex;justify-content:space-between;gap:18px;align-items:flex-start;flex-wrap:wrap;}
        .mf-flow-eyebrow{font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:#2563eb;font-weight:800;}
        .mf-flow-title{margin:6px 0 0;font-size:30px;line-height:1.12;color:#0f172a;}
        .mf-flow-sub{margin:10px 0 0;font-size:14px;line-height:1.7;color:#475569;max-width:900px;}
        .mf-flow-chips{display:flex;gap:10px;flex-wrap:wrap;align-items:center;}
        .mf-flow-chip{display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border-radius:999px;border:1px solid #dbe4f0;background:#fff;color:#0f172a;font-size:13px;font-weight:700;box-shadow:0 8px 22px rgba(15,23,42,.05);}
        .mf-flow-actions{display:flex;gap:10px;flex-wrap:wrap;}
        .mf-flow-link{display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border-radius:999px;text-decoration:none;font-size:13px;font-weight:700;border:1px solid #dbe4f0;background:#fff;color:#0f172a;box-shadow:0 8px 22px rgba(15,23,42,.05);}
        .mf-flow-link.is-primary{background:#0f172a;border-color:#0f172a;color:#fff;}
        .mf-flow-grid{display:grid;grid-template-columns:minmax(0,1.3fr) minmax(320px,.7fr);gap:18px;align-items:start;}
        .mf-flow-canvas-card,.mf-flow-side-card{padding:18px;border:1px solid #dbe4f0;border-radius:22px;background:#fff;box-shadow:0 16px 36px rgba(15,23,42,.05);}
        .mf-flow-side-card{display:grid;gap:16px;}
        .mf-flow-canvas-wrap{position:relative;overflow:auto;max-height:72vh;border-radius:18px;border:1px solid #dbe4f0;background:linear-gradient(180deg,#f8fbff 0%,#ffffff 100%);}
        .mf-flow-canvas{position:relative;min-width:1000px;}
        .mf-flow-svg{position:absolute;inset:0;pointer-events:none;}
        .mf-flow-lane{position:absolute;left:24px;right:24px;border-radius:20px;border:1px dashed rgba(148,163,184,.55);background:rgba(255,255,255,.75);box-shadow:inset 0 0 0 1px rgba(255,255,255,.3);}
        .mf-flow-lane-label{position:absolute;left:18px;top:14px;padding:6px 10px;border-radius:999px;background:#0f172a;color:#fff;font-size:11px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;}
        .mf-flow-node{position:absolute;width:220px;border-radius:22px;border:1px solid #cbd5e1;background:#fff;box-shadow:0 18px 34px rgba(15,23,42,.12);padding:16px;display:grid;gap:10px;}
        .mf-flow-node.is-start{border-color:#86efac;background:linear-gradient(180deg,#f0fdf4 0%,#ffffff 100%);}
        .mf-flow-node.is-approval{border-color:#93c5fd;background:linear-gradient(180deg,#eff6ff 0%,#ffffff 100%);}
        .mf-flow-node.is-end{border-color:#fdba74;background:linear-gradient(180deg,#fff7ed 0%,#ffffff 100%);}
        .mf-flow-node.is-action{border-color:#cbd5e1;background:linear-gradient(180deg,#f8fafc 0%,#ffffff 100%);}
        .mf-flow-node-top{display:flex;justify-content:space-between;gap:10px;align-items:flex-start;}
        .mf-flow-node-type{display:inline-flex;align-items:center;padding:5px 10px;border-radius:999px;background:#e2e8f0;color:#334155;font-size:11px;font-weight:800;letter-spacing:.04em;text-transform:uppercase;}
        .mf-flow-node-zone{font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.08em;}
        .mf-flow-node-title{margin:0;font-size:18px;line-height:1.25;color:#0f172a;font-weight:800;}
        .mf-flow-node-id{font-size:12px;color:#64748b;line-height:1.5;}
        .mf-flow-node-meta{display:grid;gap:8px;}
        .mf-flow-node-label{font-size:11px;font-weight:800;color:#64748b;letter-spacing:.08em;text-transform:uppercase;}
        .mf-flow-pillrow{display:flex;flex-wrap:wrap;gap:8px;}
        .mf-flow-pill{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;background:#f8fafc;border:1px solid #dbe4f0;color:#0f172a;font-size:12px;font-weight:700;}
        .mf-flow-pill.is-role{background:#eff6ff;border-color:#bfdbfe;color:#1d4ed8;}
        .mf-flow-pill.is-user{background:#f5f3ff;border-color:#ddd6fe;color:#6d28d9;}
        .mf-flow-pill.is-status{background:#ecfeff;border-color:#bae6fd;color:#0f766e;}
        .mf-flow-note{font-size:12px;line-height:1.6;color:#475569;border-top:1px dashed #e2e8f0;padding-top:10px;}
        .mf-flow-head{display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:14px;}
        .mf-flow-head h3{margin:0;font-size:16px;font-weight:800;color:#0f172a;}
        .mf-flow-head p{margin:6px 0 0;font-size:13px;line-height:1.6;color:#475569;}
