    // [ViewDesigner v20260503-02] Launch the unified settings popup (TS bundle
    // megaform-settings-popup.js). The popup loads ModuleConfig over the same
    // /api/MegaForm/ModuleConfig/{moduleId} endpoint the inline panel used to
    // POST to, so persistence is unchanged. After Save, force a full reload so
    // the renderer mount picks up the new ViewMode / ListFields / etc.
    private async Task OpenSettingsPopupAsync()
    {
        _showDashboardPanel = false;
        _showStarterPanel = false;
        _saveMessage = string.Empty;
        var moduleId = ModuleState?.ModuleId ?? 0;
        if (moduleId <= 0) return;
        var pageId = PageState?.Page?.PageId ?? 0;
        var pageUrl = NavigationManager?.Uri ?? string.Empty;
        // [ViewDesigner v20260503-04] Pass SiteState.SiteId so the popup can
        // resolve the form list when calling /api/MegaForm/ModuleConfig over a
        // plain (non-alias-prefixed) URL — without it, AuthEntityId returns
        // -1 and the Forms dropdown comes back empty.
        var siteId = SiteState?.Alias?.SiteId ?? 0;
        try
        {
            await Js.InvokeVoidAsync("MFSettings.open", new
            {
                moduleId = moduleId,
                siteId = siteId,
                currentPageId = pageId,
                currentPageUrl = pageUrl
            });
        }
        catch
        {
            _saveMessage = "Settings popup script not loaded yet — refresh the page and try again.";
        }
    }

