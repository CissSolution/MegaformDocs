                                                        <span class="mf-flow-pill is-user"><i class="fas fa-user"></i> @user</span>
                                                    }
                                                </div>
                                            </div>
                                        }
                                        @if (node.StatusHints.Count > 0)
                                        {
                                            <div class="mf-flow-node-meta">
                                                <div class="mf-flow-node-label">Runtime statuses</div>
