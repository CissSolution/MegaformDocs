    private void UpsertModuleInlineScript(string marker, string script)
    {
        if (PageState?.Page == null || string.IsNullOrWhiteSpace(marker) || string.IsNullOrWhiteSpace(script))
        {
            return;
        }

        PageState.Page.Resources ??= new List<Resource>();
        var ns = GetType().Namespace ?? string.Empty;
        PageState.Page.Resources.RemoveAll(r =>
            r.ResourceType == ResourceType.Script &&
            r.Level == ResourceLevel.Module &&
            string.Equals(r.Namespace, ns, StringComparison.Ordinal) &&
            !string.IsNullOrEmpty(r.Content) &&
            r.Content.Contains(marker, StringComparison.Ordinal));

        PageState.Page.Resources.Add(new Resource
        {
            ResourceType = ResourceType.Script,
            Location = ResourceLocation.Body,
            Level = ResourceLevel.Module,
            Namespace = ns,
            Content = $"window['{marker}']=true;" + script
        });
    }

