        new Resource { ResourceType = ResourceType.Script, Url = ModulePath() + $"js/megaform-submission-list.js?v={OqtaneCoreAssetVersion}", Location = ResourceLocation.Body },
        new Resource { ResourceType = ResourceType.Script, Url = ModulePath() + $"js/megaform-submission-card.js?v={OqtaneCoreAssetVersion}", Location = ResourceLocation.Body },
        // [ListViewRouting v20260507-23] NEW dedicated ListView bundle (own
        // designer + runtime + CSS). Always loaded so the admin's view-mode
        // toggle works without a resource refresh; ~5 KB gz.
        new Resource { ResourceType = ResourceType.Stylesheet, Url = ModulePath() + $"css/megaform-submissions-ts.css?v={OqtaneCoreAssetVersion}" },
        new Resource { ResourceType = ResourceType.Stylesheet, Url = ModulePath() + $"css/megaform-listview.css?v={OqtaneCoreAssetVersion}" },
        new Resource { ResourceType = ResourceType.Script,     Url = ModulePath() + $"js/megaform-listview.js?v={OqtaneCoreAssetVersion}",   Location = ResourceLocation.Body },
        new Resource { ResourceType = ResourceType.Stylesheet, Url = ModulePath() + $"css/megaform-workflow-inbox-ts.css?v={OqtaneCoreAssetVersion}" },
        new Resource { ResourceType = ResourceType.Script,     Url = ModulePath() + $"js/megaform-workflow-inbox.js?v={OqtaneCoreAssetVersion}", Location = ResourceLocation.Body },
        // [ViewDesigner v20260503-02] Cross-platform settings popup (replaces
        // the inline panel + Settings.razor logic). Visible to admins only via
        // the "Settings" button — script is small (~6 KB gz) so it's cheap to
        // ship for everyone. Designer bundles (list/card) load lazily from the
        // popup itself, so they only download when an admin opens them.
        new Resource { ResourceType = ResourceType.Script, Url = ModulePath() + $"js/megaform-settings-popup.js?v={OqtaneCoreAssetVersion}", Location = ResourceLocation.Body }
    };

